// © ScriptMasterLabs — SML Fibonacci Matrix + Macro Anchor [Licensed]
// ================================================================
// Fibonacci cascade mapped to price action and liquidity structure.
//
// CORE CAPITAL RULE (non-negotiable):
//   Price ABOVE Macro Anchor → DEPLOY ZONE   — entries permitted
//   Price BELOW Macro Anchor → LOCKED OUT    — no new positions
//
// Use on DAILY chart. Macro Anchor = one calendar year of closing prices.
// ================================================================
//@version=6
indicator("SML Fibonacci Matrix + Macro Anchor [Licensed]",
          shorttitle="SML·FibMatrix", overlay=true)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
f1_len = input.int(1, "Level 1 (Fastest)", group="SML Licensed — Fibonacci Cascade", minval=1)
f2_len = input.int(1, "Level 2",           group="SML Licensed — Fibonacci Cascade", minval=1)
f3_len = input.int(1, "Level 3",           group="SML Licensed — Fibonacci Cascade", minval=1)
f4_len = input.int(1, "Level 4 (Slowest)", group="SML Licensed — Fibonacci Cascade", minval=1)
fa_len = input.int(1, "Macro Anchor",      group="SML Licensed — Fibonacci Cascade", minval=1)

// ═══ INPUTS ═══════════════════════════════════════════════════════
anchor_zone = input.float(1.0,  "Anchor Test Zone ±%",  group="Structure",
              tooltip="Within this % of macro anchor = decision point. Default 1%.",
              minval=0.1, step=0.1)
show_labels = input.bool(true,  "Show Signal Label",     group="Display")
show_bands  = input.bool(true,  "Show Background",       group="Display")

// ═══ CASCADE EMAs ══════════════════════════════════════════════════
e_f1 = ta.ema(close, f1_len)
e_f2 = ta.ema(close, f2_len)
e_f3 = ta.ema(close, f3_len)
e_f4 = ta.ema(close, f4_len)
e_fa = ta.ema(close, fa_len)    // LINE IN THE SAND — capital deployment gate

// ═══ STRUCTURAL ALIGNMENT ═════════════════════════════════════════

// Capital deployment gate
above_anchor = close > e_fa
below_anchor = close < e_fa

// Anchor proximity
anchor_stretch = (close - e_fa) / e_fa * 100
anchor_test    = math.abs(anchor_stretch) < anchor_zone

// Cascade alignment
fib_bull = e_f1 > e_f2 and e_f2 > e_f3 and e_f3 > e_f4
fib_bear = e_f1 < e_f2 and e_f2 < e_f3 and e_f3 < e_f4

// Pair scores
bull_pairs = (e_f1 > e_f2 ? 1 : 0) + (e_f2 > e_f3 ? 1 : 0) + (e_f3 > e_f4 ? 1 : 0)
bear_pairs = (e_f1 < e_f2 ? 1 : 0) + (e_f2 < e_f3 ? 1 : 0) + (e_f3 < e_f4 ? 1 : 0)

// Highest-conviction combined states
full_bull = fib_bull and above_anchor
full_bear = fib_bear and below_anchor

// Cascade coil
cascade_spread = math.abs((e_f1 - e_f4) / e_f4 * 100)
cascade_coil   = cascade_spread < 1.5

// Crossover signals
fib_ignition  = ta.crossover( e_f1, e_f2)
fib_breakdown = ta.crossunder(e_f1, e_f2)

// ═══ PLOTS ════════════════════════════════════════════════════════

plot(e_f1, "Level 1 (Fastest)", color=color.new(color.aqua,    5), linewidth=1)
plot(e_f2, "Level 2",           color=color.new(color.teal,    5), linewidth=1)
plot(e_f3, "Level 3",           color=color.new(color.orange,  5), linewidth=2)
plot(e_f4, "Level 4 (Slowest)", color=color.new(color.purple,  5), linewidth=2)

// Macro Anchor — the line in the sand (always visible)
plot(e_fa, "Macro Anchor (Line in the Sand)",
     color=color.new(color.red, 0), linewidth=3)

// ═══ BACKGROUND ═══════════════════════════════════════════════════

bg = full_bull                          ? color.new(color.green,  58) :
     full_bear                          ? color.new(color.red,    58) :
     above_anchor and bull_pairs == 2   ? color.new(color.teal,   82) :
     above_anchor and anchor_test       ? color.new(color.yellow, 84) :
     below_anchor and anchor_test       ? color.new(color.orange, 84) :
     cascade_coil                       ? color.new(color.blue,   84) :
     above_anchor                       ? color.new(color.green,  92) :
                                          color.new(color.red,    92)

bgcolor(show_bands ? bg : na, title="SML FibMatrix Background")

// ═══ SIGNAL LABEL ════════════════════════════════════════════════

var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)

    deploy_tag = above_anchor ? "DEPLOY ZONE ✓" : "LOCKED OUT ✗"
    pct_tag    = str.tostring(math.abs(anchor_stretch), "#.##") + "% " +
                 (above_anchor ? "above" : "below") + " anchor"
    pair_tag   = str.tostring(above_anchor ? bull_pairs : bear_pairs) + "/3 cascade pairs"

    sig_txt =
      full_bull    ? "FIB MATRIX: FULL BULL CASCADE\nAll levels aligned · " + deploy_tag + "\n+" + str.tostring(anchor_stretch, "#.##") + "% above macro anchor" :
      full_bear    ? "FIB MATRIX: FULL BEAR CASCADE\nAll levels aligned · " + deploy_tag + "\n" + str.tostring(anchor_stretch, "#.##") + "% below macro anchor" :
      anchor_test  ? "FIB MATRIX: ANCHOR TEST\n" + deploy_tag + " · " + pct_tag + "\n" + pair_tag + " aligned" :
      cascade_coil ? "FIB MATRIX: CASCADE COIL\nLevels compressing · " + deploy_tag + "\n" + pair_tag + " · " + pct_tag :
      above_anchor ? "FIB MATRIX: DEPLOY ZONE ✓\n" + pair_tag + " aligned\n+" + str.tostring(anchor_stretch, "#.##") + "% above anchor" :
                     "FIB MATRIX: LOCKED OUT ✗\nNo entries. No averaging down.\n" + pct_tag + " · " + pair_tag

    lbl_col = full_bull                        ? color.green  :
              full_bear                        ? color.red    :
              anchor_test                      ? color.orange :
              cascade_coil                     ? color.blue   :
              above_anchor                     ? color.teal   : color.red

    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ═══ ALERTS ══════════════════════════════════════════════════════

alertcondition(full_bull,
    "Fib Matrix — Full Bull Cascade + Deploy Zone",
    "{{ticker}} — FIB CASCADE BULL: All levels aligned, price above macro anchor. DEPLOY ZONE active.")

alertcondition(full_bear,
    "Fib Matrix — Full Bear Cascade + Locked Out",
    "{{ticker}} — FIB CASCADE BEAR: All levels aligned, price below macro anchor. LOCKED OUT.")

alertcondition(ta.crossover(close, e_fa),
    "Fib Matrix — Macro Anchor Reclaimed (Deploy Zone Opens)",
    "{{ticker}} — ANCHOR RECLAIMED: Price crossed above macro anchor. Capital deployment now permitted.")

alertcondition(ta.crossunder(close, e_fa),
    "Fib Matrix — Macro Anchor Lost (Locked Out)",
    "{{ticker}} — ANCHOR LOST: Price crossed below macro anchor. NO new entries. NO averaging down.")

alertcondition(anchor_test,
    "Fib Matrix — Anchor Test (Price within ±1% of Macro Anchor)",
    "{{ticker}} — ANCHOR TEST: Price testing the macro anchor line in the sand. Deploy zone decision imminent.")

alertcondition(cascade_coil,
    "Fib Matrix — Cascade Coil",
    "{{ticker}} — CASCADE COIL: Fibonacci cascade compressing. Expansion imminent. Check anchor side.")

alertcondition(fib_ignition,
    "Fib Matrix — Fast Level Ignition",
    "{{ticker}} — FIB IGNITION: Fast level crossed above second level. Fastest pair flipping bullish.")

alertcondition(fib_breakdown,
    "Fib Matrix — Fast Level Breakdown",
    "{{ticker}} — FIB BREAKDOWN: Fast level dropped below second level. Fastest pair flipping bearish.")
