//@version=6
// SML Sniper Day Trader v1.1 — Institutional Intraday Execution Bridge
// Webhook: https://squeezeos-api.onrender.com/api/webhooks/tradingview
indicator("SML Sniper Day Trader v1.1", overlay=true, max_labels_count=500, max_boxes_count=500, max_bars_back=1000)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
i_trig1 = input.int(1, "Trigger Fast", group="SML Licensed — Trigger", minval=1)
i_trig2 = input.int(1, "Trigger Slow", group="SML Licensed — Trigger", minval=1)

ip2 = input.int(1, "Pillar L2", group="SML Licensed — Pillar Stack", minval=1)
ip3 = input.int(1, "Pillar L3", group="SML Licensed — Pillar Stack", minval=1)
ip4 = input.int(1, "Pillar L4", group="SML Licensed — Pillar Stack", minval=1)
ip5 = input.int(1, "Pillar L5 (Anchor)", group="SML Licensed — Pillar Stack", minval=1)

it1 = input.int(1, "Tracker L1 (Fastest)", group="SML Licensed — Tracker Stack", minval=1)
it2 = input.int(1, "Tracker L2",           group="SML Licensed — Tracker Stack", minval=1)
it3 = input.int(1, "Tracker L3",           group="SML Licensed — Tracker Stack", minval=1)
it4 = input.int(1, "Tracker L4",           group="SML Licensed — Tracker Stack", minval=1)
it5 = input.int(1, "Tracker L5 (Anchor)",  group="SML Licensed — Tracker Stack", minval=1)

color c_teal = #40E0D0

var string G_VIS = "▶  VISUALS & UI"
string dashSize  = input.string("small", "Dashboard Font Size", options=["tiny","small","normal","large","huge"], group=G_VIS)
string tradeSize = input.string("small", "Trade Label Size", options=["tiny","small","normal","large","huge"], group=G_VIS)
int ribOpac = input.int(75, "EMA Ribbon Opacity", minval=0, maxval=100, group=G_VIS)
int lblOff  = input.int(12, "Label Right Offset (Bars)", minval=1, group=G_VIS)

var string G_RISK = "▶  RISK MANAGEMENT"
float atrMult = input.float(1.5, "SL ATR Multiplier", minval=0.1, step=0.1, group=G_RISK)

var string G_EXEC = "▶  EXECUTION GATE"
float minScore    = input.float(60.0, "Min Score % to fire", minval=0.0, maxval=100.0, step=5.0, group=G_EXEC)
bool requireVwap  = input.bool(true,  "Require VWAP side", group=G_EXEC)
bool requireAdx   = input.bool(true,  "Require ADX > 25", group=G_EXEC)
bool requirePillar = input.bool(true, "Require Pillar Stack alignment", group=G_EXEC)
bool requireTrack  = input.bool(false,"Require Tracker Stack alignment", group=G_EXEC)

var string G_WH = "▶  SQUEEZEOS WEBHOOK"
string wh_pass   = input.string("SQUEEZE_AUTH_992", "Webhook Passphrase", group=G_WH)
string wh_system = input.string("SML_Sniper", "System Name", group=G_WH)

float ema_trig1 = ta.ema(close, i_trig1)
float ema_trig2 = ta.ema(close, i_trig2)
float vwapV  = ta.vwap(hlc3)
float atr    = ta.atr(14)
float rsiVal = ta.rsi(close, 14)
float rsi5m  = request.security(syminfo.tickerid, "5", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
[macdMain, macdSig, _] = ta.macd(close, 12, 26, 9)
[_, _, adxVal] = ta.dmi(14, 14)
float volAvg = ta.sma(volume, 20)

float eP_l2 = ta.ema(close, ip2)
float eP_l3 = ta.ema(close, ip3)
float eP_l4 = ta.ema(close, ip4)
float eP_l5 = ta.ema(close, ip5)
bool P13_bull = ema_trig1 > eP_l2 and eP_l2 > eP_l3 and eP_l3 > eP_l4 and eP_l4 > eP_l5
bool P13_bear = ema_trig1 < eP_l2 and eP_l2 < eP_l3 and eP_l3 < eP_l4 and eP_l4 < eP_l5

float eT_l1 = ta.ema(close, it1)
float eT_l2 = ta.ema(close, it2)
float eT_l3 = ta.ema(close, it3)
float eT_l4 = ta.ema(close, it4)
float eT_l5 = ta.ema(close, it5)
bool T9_bull = eT_l1 > eT_l2 and eT_l2 > eT_l3 and eT_l3 > eT_l4 and eT_l4 > eT_l5
bool T9_bear = eT_l1 < eT_l2 and eT_l2 < eT_l3 and eT_l3 < eT_l4 and eT_l4 < eT_l5

bool macroAlignBull = (not requirePillar or P13_bull) and (not requireTrack or T9_bull)
bool macroAlignBear = (not requirePillar or P13_bear) and (not requireTrack or T9_bear)

float bScore = 0.0
bScore += (close > vwapV ? 1.0 : 0.0)
bScore += (rsiVal > 50 ? 1.0 : 0.0)
bScore += (macdMain > macdSig ? 1.0 : 0.0)
bScore += (ema_trig1 > ema_trig2 ? 1.0 : 0.0)
bScore += (adxVal > 25 and close > ema_trig1 ? 1.0 : 0.0)
bScore += (volume > volAvg and close > open ? 1.0 : 0.0)
bScore += (rsi5m > 50 ? 1.0 : 0.0)
float bullPct = (bScore / 7.0) * 100.0

float rScore = 0.0
rScore += (close < vwapV ? 1.0 : 0.0)
rScore += (rsiVal < 50 ? 1.0 : 0.0)
rScore += (macdMain < macdSig ? 1.0 : 0.0)
rScore += (ema_trig1 < ema_trig2 ? 1.0 : 0.0)
rScore += (adxVal > 25 and close < ema_trig1 ? 1.0 : 0.0)
rScore += (volume > volAvg and close < open ? 1.0 : 0.0)
rScore += (rsi5m < 50 ? 1.0 : 0.0)
float bearPct = (rScore / 7.0) * 100.0

string biasText = (bullPct - bearPct) >= 40 ? "STRONG BULL" : (bearPct - bullPct) >= 40 ? "STRONG BEAR" : bullPct > bearPct ? "MILD BULL" : "MILD BEAR"
color  biasCol  = biasText == "STRONG BULL" ? color.green : biasText == "STRONG BEAR" ? color.red : color.gray

bool buyGated  = bullPct >= minScore and (not requireVwap or close > vwapV) and (not requireAdx or adxVal > 25) and macroAlignBull
bool sellGated = bearPct >= minScore and (not requireVwap or close < vwapV) and (not requireAdx or adxVal > 25) and macroAlignBear

var int   lastSig = 0
var float entryP  = 0.0
var float slP     = 0.0
var float t1      = 0.0
var float t2      = 0.0
var float t3      = 0.0
var float t4      = 0.0
var float t5      = 0.0
var bool  t1Hit   = false
var bool  t2Hit   = false
var bool  t3Hit   = false
var bool  t4Hit   = false
var bool  t5Hit   = false

bool xBuy  = ta.crossover(ema_trig1, ema_trig2)
bool xSell = ta.crossunder(ema_trig1, ema_trig2)
bool triggerBuy  = xBuy  and lastSig <= 0 and buyGated
bool triggerSell = xSell and lastSig >= 0 and sellGated

if triggerBuy or triggerSell
    lastSig := triggerBuy ? 1 : -1
    entryP  := close
    float r  = atr * atrMult
    slP := triggerBuy ? entryP - r : entryP + r
    t1  := triggerBuy ? entryP + r * 1.0 : entryP - r * 1.0
    t2  := triggerBuy ? entryP + r * 2.0 : entryP - r * 2.0
    t3  := triggerBuy ? entryP + r * 3.0 : entryP - r * 3.0
    t4  := triggerBuy ? entryP + r * 4.0 : entryP - r * 4.0
    t5  := triggerBuy ? entryP + r * 5.0 : entryP - r * 5.0
    t1Hit := false
    t2Hit := false
    t3Hit := false
    t4Hit := false
    t5Hit := false

if lastSig == 1
    t1Hit := t1Hit or high >= t1
    t2Hit := t2Hit or high >= t2
    t3Hit := t3Hit or high >= t3
    t4Hit := t4Hit or high >= t4
    t5Hit := t5Hit or high >= t5

if lastSig == -1
    t1Hit := t1Hit or low <= t1
    t2Hit := t2Hit or low <= t2
    t3Hit := t3Hit or low <= t3
    t4Hit := t4Hit or low <= t4
    t5Hit := t5Hit or low <= t5

plot(eP_l2, "Pillar L2", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP_l3, "Pillar L3", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP_l4, "Pillar L4", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP_l5, "Pillar L5", color=color.new(#FF8C00, 55), linewidth=2)

int rAlpha = P13_bull ? 0 : P13_bear ? 0 : 30
p13 = plot(ema_trig1, "Trigger Fast", color=color.new(color.green, rAlpha), linewidth=2)
p34 = plot(ema_trig2, "Trigger Slow", color=color.new(color.red,   rAlpha), linewidth=2)
fill(p13, p34, color=ema_trig1 > ema_trig2 ? color.new(color.green, 100 - ribOpac) : color.new(color.red, 100 - ribOpac))
plot(vwapV, "VWAP", color=close > vwapV ? color.green : color.red, linewidth=2)

bool isRetest = (lastSig == 1 and low <= ema_trig1 and low > ema_trig2) or (lastSig == -1 and high >= ema_trig1 and high < ema_trig2)
barcolor((triggerBuy or triggerSell) ? color.black : isRetest ? color.orange : na)
plotshape(triggerBuy,  text="BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, textcolor=color.white, size=size.normal)
plotshape(triggerSell, text="SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   textcolor=color.white, size=size.normal)
plotshape(P13_bull and not P13_bull[1], "Pillar Bull", shape.triangleup,   location.bottom, color=color.new(#FF8C00, 0), size=size.tiny)
plotshape(P13_bear and not P13_bear[1], "Pillar Bear", shape.triangledown, location.top,    color=color.new(#FF8C00, 0), size=size.tiny)

var line lE   = na
var line lSL  = na
var line lT1  = na
var line lT2  = na
var line lT3  = na
var line lT4  = na
var line lT5  = na
var label lbE  = label.new(na, na, "", color=color.blue,         textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT1 = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT2 = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT3 = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT4 = label.new(na, na, "", color=color.rgb(0,100,0), textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT5 = label.new(na, na, "", color=color.rgb(0,70,0),  textcolor=color.white, style=label.style_label_left, size=tradeSize)

if triggerBuy or triggerSell
    line.delete(lE)
    line.delete(lSL)
    line.delete(lT1)
    line.delete(lT2)
    line.delete(lT3)
    line.delete(lT4)
    line.delete(lT5)
    lE  := line.new(bar_index, entryP, bar_index + 20, entryP, color=color.blue,         width=2, extend=extend.right)
    lSL := line.new(bar_index, slP,    bar_index + 20, slP,    color=color.red,          width=2, extend=extend.right)
    lT1 := line.new(bar_index, t1,     bar_index + 20, t1,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT2 := line.new(bar_index, t2,     bar_index + 20, t2,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT3 := line.new(bar_index, t3,     bar_index + 20, t3,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT4 := line.new(bar_index, t4,     bar_index + 20, t4,     color=color.rgb(0,100,0), width=2, extend=extend.right)
    lT5 := line.new(bar_index, t5,     bar_index + 20, t5,     color=color.rgb(0,70,0),  width=3, extend=extend.right)

if lastSig != 0
    int tX = bar_index + lblOff
    line.set_color(lT1, t1Hit ? c_teal : color.green)
    line.set_color(lT2, t2Hit ? c_teal : color.green)
    line.set_color(lT3, t3Hit ? c_teal : color.green)
    line.set_color(lT4, t4Hit ? c_teal : color.rgb(0,100,0))
    line.set_color(lT5, t5Hit ? c_teal : color.rgb(0,70,0))
    label.set_xy(lbE,  tX, entryP)
    label.set_text(lbE,  "ENTRY: " + str.tostring(entryP, "#.##"))
    label.set_xy(lbT1, tX, t1)
    label.set_text(lbT1, "TP1: " + str.tostring(t1, "#.##") + (t1Hit ? " ✓" : ""))
    label.set_xy(lbT2, tX, t2)
    label.set_text(lbT2, "TP2: " + str.tostring(t2, "#.##") + (t2Hit ? " ✓" : ""))
    label.set_xy(lbT3, tX, t3)
    label.set_text(lbT3, "TP3: " + str.tostring(t3, "#.##") + (t3Hit ? " ✓" : ""))
    label.set_xy(lbT4, tX, t4)
    label.set_text(lbT4, "TP4: " + str.tostring(t4, "#.##") + (t4Hit ? " ✓" : ""))
    label.set_xy(lbT5, tX, t5)
    label.set_text(lbT5, "TP5: " + str.tostring(t5, "#.##") + (t5Hit ? " ✓" : ""))

f_row(_t, _r, _lbl, _val, _col, _sz) =>
    table.cell(_t, 0, _r, _lbl, text_color=color.black, text_halign=text.align_left,  text_size=_sz)
    table.cell(_t, 1, _r, _val, text_color=_col,        text_halign=text.align_right, text_size=_sz)

var table d = table.new(position.middle_left, 2, 22, bgcolor=color.new(#050505, 5), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    table.cell(d, 0, 0, "BULL SCORE", text_color=color.white, bgcolor=color.green, text_size=dashSize)
    table.cell(d, 1, 0, str.tostring(bullPct, "#") + "%", text_color=color.white, bgcolor=color.green, text_size=dashSize)
    table.cell(d, 0, 1, "BEAR SCORE", text_color=color.white, bgcolor=color.red, text_size=dashSize)
    table.cell(d, 1, 1, str.tostring(bearPct, "#") + "%", text_color=color.white, bgcolor=color.red, text_size=dashSize)
    table.cell(d, 0, 2, "MARKET BIAS", text_color=color.white, bgcolor=color.black, text_size=dashSize)
    table.cell(d, 1, 2, biasText, text_color=color.white, bgcolor=biasCol, text_size=dashSize)
    f_row(d,  3, "Score Gate",    str.tostring(minScore, "#") + "%", color.black, dashSize)
    f_row(d,  4, "Price/VWAP",   close > vwapV ? "ABOVE" : "BELOW", close > vwapV ? color.green : color.red, dashSize)
    f_row(d,  5, "RSI (14)",     str.tostring(rsiVal, "#.#"), rsiVal > 50 ? color.green : color.red, dashSize)
    f_row(d,  6, "MACD Trend",   macdMain > macdSig ? "BULL" : "BEAR", macdMain > macdSig ? color.green : color.red, dashSize)
    f_row(d,  7, "ADX Power",    str.tostring(adxVal, "#.#"), adxVal > 25 ? color.green : color.gray, dashSize)
    f_row(d,  8, "Primary Trigger", ema_trig1 > ema_trig2 ? "BULL CROSS" : "BEAR CROSS", ema_trig1 > ema_trig2 ? color.green : color.red, dashSize)
    f_row(d,  9, "ATR (14)",     str.tostring(atr, "#.##"), color.black, dashSize)
    f_row(d, 10, "Vol Status",   volume > volAvg ? "HIGH" : "LOW", volume > volAvg ? color.green : color.gray, dashSize)
    f_row(d, 11, "5m RSI",       str.tostring(rsi5m, "#.#"), rsi5m > 50 ? color.green : color.red, dashSize)
    string p13_txt = P13_bull ? "▲ ALIGNED BULL" : P13_bear ? "▼ ALIGNED BEAR" : "neutral"
    string t9_txt  = T9_bull  ? "▲ ALIGNED BULL" : T9_bear  ? "▼ ALIGNED BEAR" : "neutral"
    f_row(d, 12, "Pillar Stack",  p13_txt, P13_bull ? color.new(#FF8C00, 0) : P13_bear ? color.new(#FF8C00, 0) : color.gray, dashSize)
    f_row(d, 13, "Tracker Stack", t9_txt,  T9_bull  ? color.new(#00BFFF, 0) : T9_bear  ? color.new(#00BFFF, 0) : color.gray, dashSize)
    string mac_txt = macroAlignBull ? "MACRO BULL OPEN" : macroAlignBear ? "MACRO BEAR OPEN" : "MACRO GATED"
    f_row(d, 14, "Macro Conf",   mac_txt, macroAlignBull ? color.green : macroAlignBear ? color.red : color.gray, dashSize)
    f_row(d, 15, "SL Price",     str.tostring(slP, "#.##"), color.red, dashSize)
    f_row(d, 16, "Trend Str",    adxVal > 25 ? "STRONG" : "WEAK", adxVal > 25 ? color.green : color.red, dashSize)
    string gate_txt = buyGated ? "BUY OPEN" : sellGated ? "SELL OPEN" : "ALL GATED"
    f_row(d, 17, "Gate Status",  gate_txt, buyGated ? color.green : sellGated ? color.red : color.gray, dashSize)
    string sig_txt = triggerBuy ? "NEW BUY" : triggerSell ? "NEW SELL" : "WAIT"
    f_row(d, 18, "Signal",       sig_txt, triggerBuy ? color.green : triggerSell ? color.red : color.black, dashSize)
    f_row(d, 19, "System",       wh_system + "  v1.1", color.blue, dashSize)

alertcondition(triggerBuy  and buyGated,  "SML Sniper: BUY",  "SNIPER BUY — {{ticker}} @ {{close}} [SML]")
alertcondition(triggerSell and sellGated, "SML Sniper: SELL", "SNIPER SELL — {{ticker}} @ {{close}} [SML]")

string _px = str.tostring(close, "#.00")
string _tk = syminfo.ticker

if triggerBuy and buyGated
    alert("{\"passphrase\":\"" + wh_pass + "\",\"system\":\"" + wh_system + "\",\"ticker\":\"" + _tk + "\",\"action\":\"BUY\",\"price\":" + _px + "}", alert.freq_once_per_bar_close)
else if triggerSell and sellGated
    alert("{\"passphrase\":\"" + wh_pass + "\",\"system\":\"" + wh_system + "\",\"ticker\":\"" + _tk + "\",\"action\":\"SELL\",\"price\":" + _px + "}", alert.freq_once_per_bar_close)
