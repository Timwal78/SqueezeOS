//@version=6
// SML Sniper Day Trader v1.3 — Institutional Intraday Execution Bridge
// Trigger: EMA 55/144 crossover (SML Fibonacci Cascade), confirmed N bars later
// Gate: 7-factor score + VWAP + ADX + Pillar/Tracker + HTF trend + volatility regime + extension
// Webhook: https://squeezeos-api.onrender.com/api/webhooks/tradingview
//
// v1.3 changes vs v1.2 (research-backed signal-quality pass, not a bug fix —
// v1.1/v1.2 remain untouched so an existing live TradingView chart isn't
// silently altered; load this version deliberately when ready):
//   - Delayed crossover confirmation: instead of firing on the exact cross
//     bar, waits `confirmBars` bars and only fires if the stack still holds
//     at that point — filters the classic single-bar false breakout that
//     reverses immediately after a crossover confirms. Same technique (and
//     same default bar count) as the confirm_bars fix already shipped in
//     core/harmonic_matrix_engine.py server-side.
//   - Extension/chase guard: skips firing if price is already more than
//     Max Extension x ATR beyond the fast EMA at confirmation — a
//     well-documented trend-following pitfall is entering a move that has
//     already run too far, right before it mean-reverts.
//   - True higher-timeframe trend filter via request.security(): requires
//     the HTF's own EMA 55/144 trend to agree with the trade direction.
//     Multi-timeframe trend alignment ("trade with the higher timeframe")
//     is one of the most consistently validated techniques in trend-
//     following research — distinct from the Pillar/Tracker EMA stacks
//     below, which are same-timeframe.
//   - Volatility regime filter: skips signals when ATR is in an abnormal
//     percentile-rank tail versus its own recent history (news-spike
//     whipsaw), adapting per symbol/timeframe instead of a fixed threshold.
//   - Webhook JSON payload is UNCHANGED from v1.1/v1.2 (passphrase/system/
//     ticker/action/price) — verified against core/api/tradingview_webhook_bp.py's
//     _LONG_ACTIONS/_SHORT_ACTIONS mapping; do not add or rename fields
//     without checking that receiver first.
indicator("SML Sniper Day Trader v1.3", overlay=true, max_labels_count=500, max_boxes_count=500, max_bars_back=1000)

color c_teal = #40E0D0

var string G_VIS = "▶  VISUALS & UI"
string dashSize  = input.string("small", "Dashboard Font Size", options=["tiny","small","normal","large","huge"], group=G_VIS)
string tradeSize = input.string("small", "Trade Label Size", options=["tiny","small","normal","large","huge"], group=G_VIS)
int ribOpac = input.int(75, "EMA Ribbon Opacity", minval=0, maxval=100, group=G_VIS)
int lblOff  = input.int(12, "Label Right Offset (Bars)", minval=1, group=G_VIS)

var string G_RISK = "▶  RISK MANAGEMENT"
float atrMult   = input.float(1.5, "SL ATR Multiplier", minval=0.1, step=0.1, group=G_RISK)
bool  useCooldown  = input.bool(true, "Enable Signal Cooldown", group=G_RISK)
int   cooldownBars = input.int(5, "Min Bars Between Signals", minval=0, group=G_RISK)
bool  useSession   = input.bool(true, "Restrict to Session Window", group=G_RISK)
string sessStr     = input.session("0935-1555", "Trading Session (skip open/close chop)", group=G_RISK)
float acctSize   = input.float(25000, "Account Size ($)", minval=0, group=G_RISK)
float riskPctAcct = input.float(1.0, "Risk % of Account per Trade", minval=0.1, step=0.1, group=G_RISK)

var string G_EXEC = "▶  EXECUTION GATE"
float minScore    = input.float(60.0, "Min Score % to fire", minval=0.0, maxval=100.0, step=5.0, group=G_EXEC)
bool requireVwap  = input.bool(true,  "Require VWAP side", group=G_EXEC)
bool requireAdx   = input.bool(true,  "Require ADX > 25", group=G_EXEC)
bool requirePillar = input.bool(true, "Require Pillar 13→65 alignment", group=G_EXEC)
bool requireTrack  = input.bool(false,"Require Tracker 9→61 alignment", group=G_EXEC)

var string G_ADV = "▶  SIGNAL QUALITY (v1.3, research-backed)"
int    confirmBars    = input.int(2, "Crossover Confirmation Bars", minval=0, maxval=10, group=G_ADV, tooltip="Waits this many bars after the EMA 55/144 cross and only fires if the stack still holds then. 0 restores the old instant-fire behavior.")
bool   useExtGuard     = input.bool(true, "Extension Guard (skip if overextended)", group=G_ADV, tooltip="Skips a signal if price is already more than Max Extension x ATR beyond the fast EMA at confirmation — chasing an already-extended move raises immediate mean-reversion risk.")
float  maxExtAtr       = input.float(2.0, "Max Extension (×ATR)", minval=0.5, step=0.25, group=G_ADV)
bool   useHtfFilter    = input.bool(true, "Higher-Timeframe Trend Filter", group=G_ADV, tooltip="Requires the higher timeframe's own EMA 55/144 trend to agree with the trade direction — multi-timeframe trend alignment, distinct from the same-timeframe Pillar/Tracker stacks below.")
string htfRes          = input.timeframe("60", "Higher Timeframe", group=G_ADV)
bool   useVolRegime    = input.bool(true, "Volatility Regime Filter", group=G_ADV, tooltip="Skips signals when ATR is in an abnormal-volatility percentile tail (news-spike whipsaw) versus its own recent history.")
float  volRegimeMaxPct = input.float(90.0, "Max ATR Percentile", minval=50, maxval=100, group=G_ADV)

var string G_WH = "▶  SQUEEZEOS WEBHOOK"
string wh_pass   = input.string("SQUEEZE_AUTH_992", "Webhook Passphrase", group=G_WH)
string wh_system = input.string("SML_Sniper", "System Name", group=G_WH)

float emaFast = ta.ema(close, 55)
float emaSlow = ta.ema(close, 144)
float vwapV  = ta.vwap(hlc3)
float atr    = ta.atr(14)
float rsiVal = ta.rsi(close, 14)
float rsi5m  = request.security(syminfo.tickerid, "5", ta.rsi(close, 14), lookahead=barmerge.lookahead_off)
[macdMain, macdSig, _] = ta.macd(close, 12, 26, 9)
[_, _, adxVal] = ta.dmi(14, 14)
float volAvg = ta.sma(volume, 20)

// ─── Higher-timeframe trend filter — genuine MTF EMA, not a same-TF proxy ────
float htfEmaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, 55),  lookahead=barmerge.lookahead_off)
float htfEmaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, 144), lookahead=barmerge.lookahead_off)
bool  htfBull    = htfEmaFast > htfEmaSlow
bool  htfBear    = htfEmaFast < htfEmaSlow
bool  htfOkBull  = not useHtfFilter or htfBull
bool  htfOkBear  = not useHtfFilter or htfBear

// ─── Volatility regime — percentile rank, adapts per symbol/timeframe ─────────
float atrPctRank  = ta.percentrank(atr, 100)
bool  volRegimeOk = not useVolRegime or atrPctRank <= volRegimeMaxPct

float pillarE1 = ta.ema(close, 13)
float eP13b = ta.ema(close, 26)
float eP13c = ta.ema(close, 39)
float eP13d = ta.ema(close, 52)
float eP13e = ta.ema(close, 65)
bool P13_bull = pillarE1 > eP13b and eP13b > eP13c and eP13c > eP13d and eP13d > eP13e
bool P13_bear = pillarE1 < eP13b and eP13b < eP13c and eP13c < eP13d and eP13d < eP13e

float eT9a = ta.ema(close, 9)
float eT9b = ta.ema(close, 22)
float eT9c = ta.ema(close, 35)
float eT9d = ta.ema(close, 48)
float eT9e = ta.ema(close, 61)
bool T9_bull = eT9a > eT9b and eT9b > eT9c and eT9c > eT9d and eT9d > eT9e
bool T9_bear = eT9a < eT9b and eT9b < eT9c and eT9c < eT9d and eT9d < eT9e

bool macroAlignBull = (not requirePillar or P13_bull) and (not requireTrack or T9_bull)
bool macroAlignBear = (not requirePillar or P13_bear) and (not requireTrack or T9_bear)

float bScore = 0.0
bScore += (close > vwapV ? 1.0 : 0.0)
bScore += (rsiVal > 50 ? 1.0 : 0.0)
bScore += (macdMain > macdSig ? 1.0 : 0.0)
bScore += (emaFast > emaSlow ? 1.0 : 0.0)
bScore += (adxVal > 25 and close > emaFast ? 1.0 : 0.0)
bScore += (volume > volAvg and close > open ? 1.0 : 0.0)
bScore += (rsi5m > 50 ? 1.0 : 0.0)
float bullPct = (bScore / 7.0) * 100.0

float rScore = 0.0
rScore += (close < vwapV ? 1.0 : 0.0)
rScore += (rsiVal < 50 ? 1.0 : 0.0)
rScore += (macdMain < macdSig ? 1.0 : 0.0)
rScore += (emaFast < emaSlow ? 1.0 : 0.0)
rScore += (adxVal > 25 and close < emaFast ? 1.0 : 0.0)
rScore += (volume > volAvg and close < open ? 1.0 : 0.0)
rScore += (rsi5m < 50 ? 1.0 : 0.0)
float bearPct = (rScore / 7.0) * 100.0

string biasText = (bullPct - bearPct) >= 40 ? "STRONG BULL" : (bearPct - bullPct) >= 40 ? "STRONG BEAR" : bullPct > bearPct ? "MILD BULL" : "MILD BEAR"
color  biasCol  = biasText == "STRONG BULL" ? color.green : biasText == "STRONG BEAR" ? color.red : color.gray

// Session window: skips the first/last few minutes of the regular session,
// where spread and false-break rates are highest for a 55/144 EMA cross.
bool inSession = not useSession or not na(time(timeframe.period, sessStr, "America/New_York"))

bool baseBuyGated  = bullPct >= minScore and (not requireVwap or close > vwapV) and (not requireAdx or adxVal > 25) and macroAlignBull
bool baseSellGated = bearPct >= minScore and (not requireVwap or close < vwapV) and (not requireAdx or adxVal > 25) and macroAlignBear
bool buyGated  = baseBuyGated  and inSession and htfOkBull and volRegimeOk
bool sellGated = baseSellGated and inSession and htfOkBear and volRegimeOk

var int   lastSig = 0
var int   lastSigBar = na
var float entryP  = 0.0
var float slP     = 0.0
var float mgmtSL  = na  // trailing/managed stop — steps to breakeven after TP2, trails behind TP3/TP4
var float t1      = 0.0
var float t2      = 0.0
var float t3      = 0.0
var float t4      = 0.0
var float t5      = 0.0
var bool  t1Hit   = false
var bool  t2Hit   = false
var bool  t3Hit   = false
var bool  t4Hit   = false
var bool  t5Hit   = false

// ─── Delayed crossover confirmation ────────────────────────────────────────────
// Instead of firing the instant the cross confirms (v1.1/v1.2 behavior), wait
// `confirmBars` bars and only fire if the stack still holds then — a fakeout
// that reverses within the wait window never fires at all. confirmBars=0
// restores the old instant-fire behavior.
bool xBuy  = ta.crossover(emaFast, emaSlow)
bool xSell = ta.crossunder(emaFast, emaSlow)
var int crossBarBull = na
var int crossBarBear = na
if xBuy
    crossBarBull := bar_index
    crossBarBear := na
if xSell
    crossBarBear := bar_index
    crossBarBull := na

bool confirmedBull = not na(crossBarBull) and (bar_index - crossBarBull) == confirmBars and emaFast > emaSlow
bool confirmedBear = not na(crossBarBear) and (bar_index - crossBarBear) == confirmBars and emaFast < emaSlow

// ─── Extension/chase guard ──────────────────────────────────────────────────────
float extDistBull = confirmedBull ? (close - emaFast) / atr : 0.0
float extDistBear = confirmedBear ? (emaFast - close) / atr : 0.0
bool  overExtendedBull = useExtGuard and extDistBull > maxExtAtr
bool  overExtendedBear = useExtGuard and extDistBear > maxExtAtr

bool cooldownOk = not useCooldown or na(lastSigBar) or (bar_index - lastSigBar) >= cooldownBars
bool triggerBuy  = confirmedBull and lastSig <= 0 and buyGated  and cooldownOk and not overExtendedBull and barstate.isconfirmed
bool triggerSell = confirmedBear and lastSig >= 0 and sellGated and cooldownOk and not overExtendedBear and barstate.isconfirmed

if triggerBuy or triggerSell
    lastSig    := triggerBuy ? 1 : -1
    lastSigBar := bar_index
    entryP  := close
    float r  = atr * atrMult
    slP := triggerBuy ? entryP - r : entryP + r
    mgmtSL := slP
    t1  := triggerBuy ? entryP + r * 1.0 : entryP - r * 1.0
    t2  := triggerBuy ? entryP + r * 2.0 : entryP - r * 2.0
    t3  := triggerBuy ? entryP + r * 3.0 : entryP - r * 3.0
    t4  := triggerBuy ? entryP + r * 4.0 : entryP - r * 4.0
    t5  := triggerBuy ? entryP + r * 5.0 : entryP - r * 5.0
    t1Hit := false
    t2Hit := false
    t3Hit := false
    t4Hit := false
    t5Hit := false

if lastSig == 1
    t1Hit := t1Hit or high >= t1
    t2Hit := t2Hit or high >= t2
    t3Hit := t3Hit or high >= t3
    t4Hit := t4Hit or high >= t4
    t5Hit := t5Hit or high >= t5
    // Staircase trail: breakeven after TP2, then step behind each further target.
    if t4Hit
        mgmtSL := math.max(mgmtSL, t2)
    else if t3Hit
        mgmtSL := math.max(mgmtSL, t1)
    else if t2Hit
        mgmtSL := math.max(mgmtSL, entryP)

if lastSig == -1
    t1Hit := t1Hit or low <= t1
    t2Hit := t2Hit or low <= t2
    t3Hit := t3Hit or low <= t3
    t4Hit := t4Hit or low <= t4
    t5Hit := t5Hit or low <= t5
    if t4Hit
        mgmtSL := math.min(mgmtSL, t2)
    else if t3Hit
        mgmtSL := math.min(mgmtSL, t1)
    else if t2Hit
        mgmtSL := math.min(mgmtSL, entryP)

plot(eP13b, "Pillar 26", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP13c, "Pillar 39", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP13d, "Pillar 52", color=color.new(#FF8C00, 80), linewidth=1)
plot(eP13e, "Pillar 65", color=color.new(#FF8C00, 55), linewidth=2)

int rAlpha = P13_bull ? 0 : P13_bear ? 0 : 30
p13 = plot(emaFast, "EMA 55", color=color.new(color.green, rAlpha), linewidth=2)
p34 = plot(emaSlow, "EMA 144", color=color.new(color.red,   rAlpha), linewidth=2)
fill(p13, p34, color=emaFast > emaSlow ? color.new(color.green, 100 - ribOpac) : color.new(color.red, 100 - ribOpac))
plot(vwapV, "VWAP", color=close > vwapV ? color.green : color.red, linewidth=2)

bool isRetest = (lastSig == 1 and low <= emaFast and low > emaSlow) or (lastSig == -1 and high >= emaFast and high < emaSlow)
barcolor((triggerBuy or triggerSell) ? color.black : isRetest ? color.orange : na)
plotshape(triggerBuy,  text="BUY",  style=shape.labelup,   location=location.belowbar, color=color.green, textcolor=color.white, size=size.normal)
plotshape(triggerSell, text="SELL", style=shape.labeldown, location=location.abovebar, color=color.red,   textcolor=color.white, size=size.normal)
plotshape(P13_bull and not P13_bull[1], "Pillar Bull", shape.triangleup,   location.bottom, color=color.new(#FF8C00, 0), size=size.tiny)
plotshape(P13_bear and not P13_bear[1], "Pillar Bear", shape.triangledown, location.top,    color=color.new(#FF8C00, 0), size=size.tiny)

var line lE    = na
var line lSL   = na
var line lMgmt = na
var line lT1   = na
var line lT2   = na
var line lT3   = na
var line lT4   = na
var line lT5   = na
var label lbE    = label.new(na, na, "", color=color.blue,         textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbMgmt = label.new(na, na, "", color=c_teal,             textcolor=color.black, style=label.style_label_left, size=tradeSize)
var label lbT1   = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT2   = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT3   = label.new(na, na, "", color=color.green,        textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT4   = label.new(na, na, "", color=color.rgb(0,100,0), textcolor=color.white, style=label.style_label_left, size=tradeSize)
var label lbT5   = label.new(na, na, "", color=color.rgb(0,70,0),  textcolor=color.white, style=label.style_label_left, size=tradeSize)

if triggerBuy or triggerSell
    line.delete(lE)
    line.delete(lSL)
    line.delete(lMgmt)
    line.delete(lT1)
    line.delete(lT2)
    line.delete(lT3)
    line.delete(lT4)
    line.delete(lT5)
    lE    := line.new(bar_index, entryP, bar_index + 20, entryP, color=color.blue, width=2, extend=extend.right)
    lSL   := line.new(bar_index, slP,    bar_index + 20, slP,    color=color.red,  width=1, style=line.style_dotted, extend=extend.right)
    lMgmt := line.new(bar_index, mgmtSL, bar_index + 20, mgmtSL, color=c_teal,     width=2, extend=extend.right)
    lT1   := line.new(bar_index, t1,     bar_index + 20, t1,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT2   := line.new(bar_index, t2,     bar_index + 20, t2,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT3   := line.new(bar_index, t3,     bar_index + 20, t3,     color=color.green,        style=line.style_dashed, extend=extend.right)
    lT4   := line.new(bar_index, t4,     bar_index + 20, t4,     color=color.rgb(0,100,0), width=2, extend=extend.right)
    lT5   := line.new(bar_index, t5,     bar_index + 20, t5,     color=color.rgb(0,70,0),  width=3, extend=extend.right)

if lastSig != 0
    int tX = bar_index + lblOff
    line.set_xy1(lMgmt, bar_index, mgmtSL)
    line.set_xy2(lMgmt, bar_index + 20, mgmtSL)
    line.set_color(lT1, t1Hit ? c_teal : color.green)
    line.set_color(lT2, t2Hit ? c_teal : color.green)
    line.set_color(lT3, t3Hit ? c_teal : color.green)
    line.set_color(lT4, t4Hit ? c_teal : color.rgb(0,100,0))
    line.set_color(lT5, t5Hit ? c_teal : color.rgb(0,70,0))
    label.set_xy(lbE,  tX, entryP)
    label.set_text(lbE,  "ENTRY: " + str.tostring(entryP, "#.##"))
    label.set_xy(lbMgmt, tX, mgmtSL)
    label.set_text(lbMgmt, "STOP: " + str.tostring(mgmtSL, "#.##") + (mgmtSL != slP ? " (trailed)" : " (initial)"))
    label.set_xy(lbT1, tX, t1)
    label.set_text(lbT1, "TP1: " + str.tostring(t1, "#.##") + (t1Hit ? " ✓" : ""))
    label.set_xy(lbT2, tX, t2)
    label.set_text(lbT2, "TP2: " + str.tostring(t2, "#.##") + (t2Hit ? " ✓" : ""))
    label.set_xy(lbT3, tX, t3)
    label.set_text(lbT3, "TP3: " + str.tostring(t3, "#.##") + (t3Hit ? " ✓" : ""))
    label.set_xy(lbT4, tX, t4)
    label.set_text(lbT4, "TP4: " + str.tostring(t4, "#.##") + (t4Hit ? " ✓" : ""))
    label.set_xy(lbT5, tX, t5)
    label.set_text(lbT5, "TP5: " + str.tostring(t5, "#.##") + (t5Hit ? " ✓" : ""))

f_row(_t, _r, _lbl, _val, _col, _sz) =>
    table.cell(_t, 0, _r, _lbl, text_color=color.black, text_halign=text.align_left,  text_size=_sz)
    table.cell(_t, 1, _r, _val, text_color=_col,        text_halign=text.align_right, text_size=_sz)

var table d = table.new(position.middle_left, 2, 27, bgcolor=color.new(#050505, 5), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    table.cell(d, 0, 0, "BULL SCORE", text_color=color.white, bgcolor=color.green, text_size=dashSize)
    table.cell(d, 1, 0, str.tostring(bullPct, "#") + "%", text_color=color.white, bgcolor=color.green, text_size=dashSize)
    table.cell(d, 0, 1, "BEAR SCORE", text_color=color.white, bgcolor=color.red, text_size=dashSize)
    table.cell(d, 1, 1, str.tostring(bearPct, "#") + "%", text_color=color.white, bgcolor=color.red, text_size=dashSize)
    table.cell(d, 0, 2, "MARKET BIAS", text_color=color.white, bgcolor=color.black, text_size=dashSize)
    table.cell(d, 1, 2, biasText, text_color=color.white, bgcolor=biasCol, text_size=dashSize)
    f_row(d,  3, "Score Gate",    str.tostring(minScore, "#") + "%", color.black, dashSize)
    f_row(d,  4, "Price/VWAP",   close > vwapV ? "ABOVE" : "BELOW", close > vwapV ? color.green : color.red, dashSize)
    f_row(d,  5, "RSI (14)",     str.tostring(rsiVal, "#.#"), rsiVal > 50 ? color.green : color.red, dashSize)
    f_row(d,  6, "MACD Trend",   macdMain > macdSig ? "BULL" : "BEAR", macdMain > macdSig ? color.green : color.red, dashSize)
    f_row(d,  7, "ADX Power",    str.tostring(adxVal, "#.#"), adxVal > 25 ? color.green : color.gray, dashSize)
    f_row(d,  8, "EMA 55/144",   emaFast > emaSlow ? "BULL CROSS" : "BEAR CROSS", emaFast > emaSlow ? color.green : color.red, dashSize)
    f_row(d,  9, "ATR (14)",     str.tostring(atr, "#.##"), color.black, dashSize)
    f_row(d, 10, "Vol Status",   volume > volAvg ? "HIGH" : "LOW", volume > volAvg ? color.green : color.gray, dashSize)
    f_row(d, 11, "5m RSI",       str.tostring(rsi5m, "#.#"), rsi5m > 50 ? color.green : color.red, dashSize)
    string p13_txt = P13_bull ? "▲ ALIGNED BULL" : P13_bear ? "▼ ALIGNED BEAR" : "neutral"
    string t9_txt  = T9_bull  ? "▲ ALIGNED BULL" : T9_bear  ? "▼ ALIGNED BEAR" : "neutral"
    f_row(d, 12, "Pillar 13→65", p13_txt, P13_bull ? color.new(#FF8C00, 0) : P13_bear ? color.new(#FF8C00, 0) : color.gray, dashSize)
    f_row(d, 13, "Tracker 9→61", t9_txt,  T9_bull  ? color.new(#00BFFF, 0) : T9_bear  ? color.new(#00BFFF, 0) : color.gray, dashSize)
    string mac_txt = macroAlignBull ? "MACRO BULL OPEN" : macroAlignBear ? "MACRO BEAR OPEN" : "MACRO GATED"
    f_row(d, 14, "Macro Conf",   mac_txt, macroAlignBull ? color.green : macroAlignBear ? color.red : color.gray, dashSize)
    f_row(d, 15, "Session",      inSession ? "OPEN" : "SKIPPED", inSession ? color.green : color.gray, dashSize)
    f_row(d, 16, "Cooldown",     cooldownOk ? "READY" : "WAITING", cooldownOk ? color.green : color.gray, dashSize)
    string htf_txt = htfBull ? "HTF BULL" : htfBear ? "HTF BEAR" : "HTF MIXED"
    f_row(d, 17, "HTF (" + htfRes + ")", htf_txt, htfBull ? color.green : htfBear ? color.red : color.gray, dashSize)
    f_row(d, 18, "Vol Regime",  volRegimeOk ? "OK" : "EXTREME (skip)", volRegimeOk ? color.green : color.red, dashSize)
    string ext_txt = overExtendedBull or overExtendedBear ? "OVEREXTENDED (skip)" : "OK"
    f_row(d, 19, "Extension",   ext_txt, (overExtendedBull or overExtendedBear) ? color.red : color.green, dashSize)
    f_row(d, 20, "Initial SL",   str.tostring(slP, "#.##"), color.red, dashSize)
    f_row(d, 21, "Managed Stop", str.tostring(mgmtSL, "#.##"), c_teal, dashSize)
    float slDist = math.abs(entryP - slP)
    float sizedShares = slDist > 0 and lastSig != 0 ? math.floor((acctSize * riskPctAcct / 100.0) / slDist) : 0.0
    f_row(d, 22, "Sized Qty",    str.tostring(sizedShares, "#"), color.blue, dashSize)
    string gate_txt = buyGated ? "BUY OPEN" : sellGated ? "SELL OPEN" : "ALL GATED"
    f_row(d, 23, "Gate Status",  gate_txt, buyGated ? color.green : sellGated ? color.red : color.gray, dashSize)
    string sig_txt = triggerBuy ? "NEW BUY" : triggerSell ? "NEW SELL" : "WAIT"
    f_row(d, 24, "Signal",       sig_txt, triggerBuy ? color.green : triggerSell ? color.red : color.black, dashSize)
    string pend_txt = not na(crossBarBull) and lastSig <= 0 ? "BULL x" + str.tostring(bar_index - crossBarBull) + "/" + str.tostring(confirmBars) : not na(crossBarBear) and lastSig >= 0 ? "BEAR x" + str.tostring(bar_index - crossBarBear) + "/" + str.tostring(confirmBars) : "—"
    f_row(d, 25, "Confirm Wait", pend_txt, color.gray, dashSize)
    f_row(d, 26, "System",       wh_system + "  v1.3", color.blue, dashSize)

alertcondition(triggerBuy,  "SML Sniper: BUY",  "SNIPER BUY 55/144 — {{ticker}} @ {{close}} [SML]")
alertcondition(triggerSell, "SML Sniper: SELL", "SNIPER SELL 55/144 — {{ticker}} @ {{close}} [SML]")

string _px = str.tostring(close, "#.00")
string _tk = syminfo.ticker

if triggerBuy
    alert("{\"passphrase\":\"" + wh_pass + "\",\"system\":\"" + wh_system + "\",\"ticker\":\"" + _tk + "\",\"action\":\"BUY\",\"price\":" + _px + "}", alert.freq_once_per_bar_close)
else if triggerSell
    alert("{\"passphrase\":\"" + wh_pass + "\",\"system\":\"" + wh_system + "\",\"ticker\":\"" + _tk + "\",\"action\":\"SELL\",\"price\":" + _px + "}", alert.freq_once_per_bar_close)
