// © ScriptMasterLabs — SML 9·45·81·117 Harmonic Stack
// ================================================================
// Discovery: Timothy Walton | ScriptMasterLabs
//
// THE MATH:
//   Every EMA is separated by a constant delta of 36.
//   9 (+36) = 45 → (+36) = 81 → (+36) = 117
//   This is NOT accidental — it is a perfectly equidistant harmonic grid.
//
// WHY IT WORKS:
//   9   — The spearhead. Pure daily micro-trend (9 sessions).
//   45  — Front-runs the standard 50 EMA. You see the institutional
//         move before the retail algo crowd does.
//   81  — The intermediate trend validator. Kills the chop.
//   117 — The deep macro anchor. 6-month memory. If price is above
//         this line, the long-term trend is unambiguously bullish.
//
// 65-MINUTE CHART ALIGNMENT (390-min day = 6 candles):
//   9  EMA = 1.5 trading days
//   45 EMA = 7.5 trading days  (front-runs the 50MA crowd)
//   81 EMA = 13.5 trading days
//  117 EMA = 19.5 trading days (rolling 1-month institutional baseline)
//
// RIBBON BEHAVIOR:
//   Strong trend  → perfect uniform fan-out (36-period spacing preserved)
//   Consolidation → all 4 lines coil into a single knot — when this
//                   knot breaks, the move is violent and directional
// ================================================================
//@version=5
indicator("SML 9·45·81·117 Harmonic Stack [ScriptMasterLabs]",
          shorttitle="SML·9·45·81·117", overlay=true)

// ── Inputs ────────────────────────────────────────────────────────
src         = input.source(close, "Source")
show_ribbon = input.bool(true,  "Show Ribbon Fill")
show_labels = input.bool(true,  "Show Signal Labels")
show_alerts = input.bool(true,  "Show Alert Shapes")

// ── EMA Calculations ──────────────────────────────────────────────
e9   = ta.ema(src, 9)
e45  = ta.ema(src, 45)
e81  = ta.ema(src, 81)
e117 = ta.ema(src, 117)

// ── Ribbon Width (gap uniformity metric) ─────────────────────────
// When the ribbon is perfectly fanned, all gaps should be equal.
// Compression = all gaps → 0. Expansion = gaps widen uniformly.
gap_1 = e9  - e45
gap_2 = e45 - e81
gap_3 = e81 - e117

// Ribbon uniformity: 1.0 = perfectly equidistant, <0.5 = compressing
uniformity = math.abs(gap_1) > 0.0001
    ? (math.abs(gap_1 - gap_2) + math.abs(gap_2 - gap_3)) / math.abs(gap_1)
    : 0.0
ribbon_compressed = math.abs(gap_1) < (e9 * 0.003) and
                    math.abs(gap_2) < (e9 * 0.003) and
                    math.abs(gap_3) < (e9 * 0.003)

// ── Stack States ──────────────────────────────────────────────────
full_bull  = src > e9 and e9 > e45 and e45 > e81 and e81 > e117
full_bear  = src < e9 and e9 < e45 and e45 < e81 and e81 < e117
above_117  = src > e117   // macro bullish
front_runs = src > e45 and src < e50 // can't reference e50 — noted below
            // 45 EMA front-runs the 50: price above 45 but watch for 50 crowd entry

// Full Bull with price reclaiming above all 4 levels from below
ignition   = ta.crossover(src, e117) and full_bull

// ── Color Logic ───────────────────────────────────────────────────
ribbon_col = full_bull ? color.new(#00FF66, 75) :
             full_bear ? color.new(#FF0055, 75) :
             color.new(#888888, 85)

// ── Plots ─────────────────────────────────────────────────────────
p9   = plot(e9,   "9 EMA  (Spearhead)",              color=color.new(#00FFFF, 10), linewidth=1)
p45  = plot(e45,  "45 EMA (Front-Run Baseline)",     color=color.new(#00FF66, 10), linewidth=2)
p81  = plot(e81,  "81 EMA (Intermediate Validator)", color=color.new(#FF8C00, 10), linewidth=2)
p117 = plot(e117, "117 EMA (Macro Anchor — 6Mo)",    color=color.new(#FF0055, 5),  linewidth=3)

// ── Ribbon Fill ───────────────────────────────────────────────────
fill(p9,   p45,  color=full_bull ? color.new(#00FF66, 88) :
                        full_bear ? color.new(#FF0055, 88) :
                        color.new(#888888, 92),
     title="Ribbon 9→45")
fill(p45,  p81,  color=full_bull ? color.new(#00FF66, 92) :
                        full_bear ? color.new(#FF0055, 92) :
                        color.new(#888888, 94),
     title="Ribbon 45→81")
fill(p81,  p117, color=full_bull ? color.new(#00FF66, 94) :
                        full_bear ? color.new(#FF0055, 94) :
                        color.new(#888888, 95),
     title="Ribbon 81→117")

// ── Compression Knot Background ───────────────────────────────────
bgcolor(ribbon_compressed ? color.new(#9900FF, 70) : na,
    title="Ribbon Compressed — Breakout Imminent")

// ── Ignition Shape ────────────────────────────────────────────────
plotshape(show_alerts and ignition,
    title="Macro Ignition — Price Reclaims 117",
    style=shape.star,
    location=location.belowbar,
    color=color.new(#00FF66, 0),
    size=size.normal)

// ── Signal Label ──────────────────────────────────────────────────
var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)
    sig_txt = ribbon_compressed ? "◈ KNOT COMPRESSION\nAll 4 EMAs coiled — Breakout loading" :
              full_bull         ? "▲ FULL BULL STACK\n9 > 45 > 81 > 117\nUniform fan confirmed" :
              full_bear         ? "▼ FULL BEAR STACK\n9 < 45 < 81 < 117\nInstitutional downtrend" :
              above_117         ? "ABOVE MACRO ANCHOR\nLong-term trend bullish" :
                                  "MIXED — Await Stack Alignment"
    lbl_col = ribbon_compressed ? #9900FF :
              full_bull         ? #00FF66 :
              full_bear         ? #FF0055 :
              above_117         ? #00BFFF : #888888
    sig_lbl := label.new(bar_index, full_bear ? low * 0.997 : high * 1.003,
        text=sig_txt,
        color=lbl_col,
        textcolor=color.white,
        style=full_bear ? label.style_label_up : label.style_label_down,
        size=size.normal)

// ── Ribbon Uniformity Info Table ──────────────────────────────────
var table info = table.new(position.top_right, 2, 5,
    bgcolor=#0A0A0A, border_color=#333333, border_width=1, frame_color=#222222, frame_width=1)
if barstate.islast
    gap_lbl_col = uniformity < 0.3 ? color.new(#00FF66, 0) :
                  uniformity < 0.7 ? color.new(#FFE600, 0) :
                  color.new(#FF0055, 0)
    table.cell(info, 0, 0, "SML 9·45·81·117",     bgcolor=#111111, text_color=#AAAAAA, text_size=size.small)
    table.cell(info, 1, 0, "Harmonic Δ = 36",      bgcolor=#111111, text_color=#00FFFF, text_size=size.small)
    table.cell(info, 0, 1, "Gap 9→45",             bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(gap_1, "#.##"), bgcolor=#0A0A0A, text_color=#00FFFF, text_size=size.small)
    table.cell(info, 0, 2, "Gap 45→81",            bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(gap_2, "#.##"), bgcolor=#0A0A0A, text_color=#00FF66, text_size=size.small)
    table.cell(info, 0, 3, "Gap 81→117",           bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(gap_3, "#.##"), bgcolor=#0A0A0A, text_color=#FF8C00, text_size=size.small)
    table.cell(info, 0, 4, "Status",               bgcolor=#111111, text_color=#888888, text_size=size.small)
    state_txt = ribbon_compressed ? "KNOT" : full_bull ? "BULL" : full_bear ? "BEAR" : "MIXED"
    state_col = ribbon_compressed ? #9900FF : full_bull ? #00FF66 : full_bear ? #FF0055 : #888888
    table.cell(info, 1, 4, state_txt,              bgcolor=#111111, text_color=state_col, text_size=size.small)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(ribbon_compressed and not ribbon_compressed[1],
    "9·45·81·117 Compression Knot",
    "{{ticker}} — All 4 EMAs coiling into harmonic knot. Explosive breakout or breakdown loading.")

alertcondition(full_bull and not full_bull[1],
    "9·45·81·117 Full Bull Stack Achieved",
    "{{ticker}} — Uniform bull stack: 9 > 45 > 81 > 117. Institutional uptrend confirmed.")

alertcondition(full_bear and not full_bear[1],
    "9·45·81·117 Full Bear Stack Achieved",
    "{{ticker}} — Uniform bear stack: 9 < 45 < 81 < 117. Institutional downtrend confirmed.")

alertcondition(ta.crossover(src, e117),
    "9·45·81·117 Macro Reclaim",
    "{{ticker}} — Price reclaims 117 EMA. 6-month macro floor defended — potential ignition point.")

alertcondition(ta.crossunder(src, e117),
    "9·45·81·117 Macro Breakdown",
    "{{ticker}} — Price lost 117 EMA. 6-month macro anchor broken — trend change warning.")
