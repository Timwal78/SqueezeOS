// © ScriptMasterLabs — SML Harmonic Stack [ScriptMasterLabs]
// Discovery: Timothy Walton | ScriptMasterLabs
//@version=5
indicator("SML Harmonic Stack [ScriptMasterLabs]",
          shorttitle="SML·HStack", overlay=true)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
i_l1 = input.int(1, "L1 (Fastest)", group="SML Licensed — Harmonic Stack", minval=1)
i_l2 = input.int(1, "L2",          group="SML Licensed — Harmonic Stack", minval=1)
i_l3 = input.int(1, "L3",          group="SML Licensed — Harmonic Stack", minval=1)
i_l4 = input.int(1, "L4 (Anchor)", group="SML Licensed — Harmonic Stack", minval=1)

// ── Inputs ────────────────────────────────────────────────────────
src         = input.source(close, "Source")
show_ribbon = input.bool(true,  "Show Ribbon Fill")
show_labels = input.bool(true,  "Show Signal Labels")
show_alerts = input.bool(true,  "Show Alert Shapes")

// ── EMA Calculations ──────────────────────────────────────────────
e_l1 = ta.ema(src, i_l1)
e_l2 = ta.ema(src, i_l2)
e_l3 = ta.ema(src, i_l3)
e_l4 = ta.ema(src, i_l4)

// ── Ribbon Width (gap uniformity metric) ─────────────────────────
gap_1 = e_l1 - e_l2
gap_2 = e_l2 - e_l3
gap_3 = e_l3 - e_l4

uniformity = math.abs(gap_1) > 0.0001
    ? (math.abs(gap_1 - gap_2) + math.abs(gap_2 - gap_3)) / math.abs(gap_1)
    : 0.0
ribbon_compressed = math.abs(gap_1) < (e_l1 * 0.003) and
                    math.abs(gap_2) < (e_l1 * 0.003) and
                    math.abs(gap_3) < (e_l1 * 0.003)

// ── Stack States ──────────────────────────────────────────────────
full_bull  = src > e_l1 and e_l1 > e_l2 and e_l2 > e_l3 and e_l3 > e_l4
full_bear  = src < e_l1 and e_l1 < e_l2 and e_l2 < e_l3 and e_l3 < e_l4
above_l4   = src > e_l4

ignition   = ta.crossover(src, e_l4) and full_bull

// ── Color Logic ───────────────────────────────────────────────────
ribbon_col = full_bull ? color.new(#00FF66, 75) :
             full_bear ? color.new(#FF0055, 75) :
             color.new(#888888, 85)

// ── Plots ─────────────────────────────────────────────────────────
p_l1 = plot(e_l1, "L1 (Spearhead)",      color=color.new(#00FFFF, 10), linewidth=1)
p_l2 = plot(e_l2, "L2 (Baseline)",       color=color.new(#00FF66, 10), linewidth=2)
p_l3 = plot(e_l3, "L3 (Validator)",      color=color.new(#FF8C00, 10), linewidth=2)
p_l4 = plot(e_l4, "L4 (Macro Anchor)",   color=color.new(#FF0055,  5), linewidth=3)

// ── Ribbon Fill ───────────────────────────────────────────────────
fill(p_l1, p_l2, color=full_bull ? color.new(#00FF66, 88) :
                        full_bear ? color.new(#FF0055, 88) :
                        color.new(#888888, 92),
     title="Ribbon L1→L2")
fill(p_l2, p_l3, color=full_bull ? color.new(#00FF66, 92) :
                        full_bear ? color.new(#FF0055, 92) :
                        color.new(#888888, 94),
     title="Ribbon L2→L3")
fill(p_l3, p_l4, color=full_bull ? color.new(#00FF66, 94) :
                        full_bear ? color.new(#FF0055, 94) :
                        color.new(#888888, 95),
     title="Ribbon L3→L4")

// ── Compression Knot Background ───────────────────────────────────
bgcolor(ribbon_compressed ? color.new(#9900FF, 70) : na,
    title="Ribbon Compressed — Breakout Imminent")

// ── Ignition Shape ────────────────────────────────────────────────
plotshape(show_alerts and ignition,
    title="Macro Ignition — Price Reclaims Anchor",
    style=shape.star,
    location=location.belowbar,
    color=color.new(#00FF66, 0),
    size=size.normal)

// ── Signal Label ──────────────────────────────────────────────────
var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)
    sig_txt = ribbon_compressed ? "◈ KNOT COMPRESSION\nAll levels coiled — Breakout loading" :
              full_bull         ? "▲ FULL BULL STACK\nL1 > L2 > L3 > L4\nUniform fan confirmed" :
              full_bear         ? "▼ FULL BEAR STACK\nL1 < L2 < L3 < L4\nInstitutional downtrend" :
              above_l4          ? "ABOVE MACRO ANCHOR\nLong-term trend bullish" :
                                  "MIXED — Await Stack Alignment"
    lbl_col = ribbon_compressed ? #9900FF :
              full_bull         ? #00FF66 :
              full_bear         ? #FF0055 :
              above_l4          ? #00BFFF : #888888
    sig_lbl := label.new(bar_index, full_bear ? low * 0.997 : high * 1.003,
        text=sig_txt,
        color=lbl_col,
        textcolor=color.white,
        style=full_bear ? label.style_label_up : label.style_label_down,
        size=size.normal)

// ── Ribbon Uniformity Info Table ──────────────────────────────────
var table info = table.new(position.top_right, 2, 5,
    bgcolor=#0A0A0A, border_color=#333333, border_width=1, frame_color=#222222, frame_width=1)
if barstate.islast
    gap_lbl_col = uniformity < 0.3 ? color.new(#00FF66, 0) :
                  uniformity < 0.7 ? color.new(#FFE600, 0) :
                  color.new(#FF0055, 0)
    table.cell(info, 0, 0, "SML Harmonic Stack",  bgcolor=#111111, text_color=#AAAAAA, text_size=size.small)
    table.cell(info, 1, 0, "LICENSED",             bgcolor=#111111, text_color=#00FFFF, text_size=size.small)
    table.cell(info, 0, 1, "Gap L1→L2",            bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 1, str.tostring(gap_1, "#.##"), bgcolor=#0A0A0A, text_color=#00FFFF, text_size=size.small)
    table.cell(info, 0, 2, "Gap L2→L3",            bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 2, str.tostring(gap_2, "#.##"), bgcolor=#0A0A0A, text_color=#00FF66, text_size=size.small)
    table.cell(info, 0, 3, "Gap L3→L4",            bgcolor=#0A0A0A, text_color=#888888, text_size=size.small)
    table.cell(info, 1, 3, str.tostring(gap_3, "#.##"), bgcolor=#0A0A0A, text_color=#FF8C00, text_size=size.small)
    table.cell(info, 0, 4, "Status",               bgcolor=#111111, text_color=#888888, text_size=size.small)
    state_txt = ribbon_compressed ? "KNOT" : full_bull ? "BULL" : full_bear ? "BEAR" : "MIXED"
    state_col = ribbon_compressed ? #9900FF : full_bull ? #00FF66 : full_bear ? #FF0055 : #888888
    table.cell(info, 1, 4, state_txt,              bgcolor=#111111, text_color=state_col, text_size=size.small)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(ribbon_compressed and not ribbon_compressed[1],
    "Harmonic Stack Compression Knot",
    "{{ticker}} — All levels coiling into harmonic knot. Explosive breakout or breakdown loading.")

alertcondition(full_bull and not full_bull[1],
    "Harmonic Stack Full Bull Achieved",
    "{{ticker}} — Full bull stack: L1 > L2 > L3 > L4. Institutional uptrend confirmed.")

alertcondition(full_bear and not full_bear[1],
    "Harmonic Stack Full Bear Achieved",
    "{{ticker}} — Full bear stack: L1 < L2 < L3 < L4. Institutional downtrend confirmed.")

alertcondition(ta.crossover(src, e_l4),
    "Harmonic Stack Macro Reclaim",
    "{{ticker}} — Price reclaims macro anchor. Long-term floor defended — potential ignition point.")

alertcondition(ta.crossunder(src, e_l4),
    "Harmonic Stack Macro Breakdown",
    "{{ticker}} — Price lost macro anchor. Long-term trend change warning.")
