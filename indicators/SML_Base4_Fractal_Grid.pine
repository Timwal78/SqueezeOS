// © ScriptMasterLabs — SML Base-4 Fractal Grid
// Discovery: Timothy Walton | ScriptMasterLabs
// Proprietary Harmonic Matrix Engine
//@version=5
indicator("SML Base-4 Fractal Grid [ScriptMasterLabs]",
          shorttitle="SML·B4·Grid", overlay=true, max_lines_count=500)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
i_s1t = input.int(1, "S1 Trigger", group="SML Licensed — Set 1", minval=1)
i_s1b = input.int(1, "S1 Base",    group="SML Licensed — Set 1", minval=1)
i_s1v = input.int(1, "S1 Valid",   group="SML Licensed — Set 1", minval=1)
i_s1a = input.int(1, "S1 Anchor",  group="SML Licensed — Set 1", minval=1)

i_s2t = input.int(1, "S2 Trigger", group="SML Licensed — Set 2", minval=1)
i_s2b = input.int(1, "S2 Base",    group="SML Licensed — Set 2", minval=1)
i_s2v = input.int(1, "S2 Valid",   group="SML Licensed — Set 2", minval=1)
i_s2a = input.int(1, "S2 Anchor",  group="SML Licensed — Set 2", minval=1)

i_s3t = input.int(1, "S3 Trigger", group="SML Licensed — Set 3", minval=1)
i_s3b = input.int(1, "S3 Base",    group="SML Licensed — Set 3", minval=1)
i_s3v = input.int(1, "S3 Valid",   group="SML Licensed — Set 3", minval=1)
i_s3a = input.int(1, "S3 Anchor",  group="SML Licensed — Set 3", minval=1)

i_s4t = input.int(1, "S4 Trigger", group="SML Licensed — Set 4", minval=1)
i_s4b = input.int(1, "S4 Base",    group="SML Licensed — Set 4", minval=1)
i_s4v = input.int(1, "S4 Valid",   group="SML Licensed — Set 4", minval=1)
i_s4a = input.int(1, "S4 Anchor",  group="SML Licensed — Set 4", minval=1)

i_s5t = input.int(1, "S5 Trigger", group="SML Licensed — Set 5", minval=1)
i_s5b = input.int(1, "S5 Base",    group="SML Licensed — Set 5", minval=1)
i_s5v = input.int(1, "S5 Valid",   group="SML Licensed — Set 5", minval=1)
i_s5a = input.int(1, "S5 Anchor",  group="SML Licensed — Set 5", minval=1)

i_s6t = input.int(1, "S6 Trigger", group="SML Licensed — Set 6", minval=1)
i_s6b = input.int(1, "S6 Base",    group="SML Licensed — Set 6", minval=1)
i_s6v = input.int(1, "S6 Valid",   group="SML Licensed — Set 6", minval=1)
i_s6a = input.int(1, "S6 Anchor",  group="SML Licensed — Set 6", minval=1)

i_s7t = input.int(1, "S7 Trigger", group="SML Licensed — Set 7", minval=1)
i_s7b = input.int(1, "S7 Base",    group="SML Licensed — Set 7", minval=1)
i_s7v = input.int(1, "S7 Valid",   group="SML Licensed — Set 7", minval=1)
i_s7a = input.int(1, "S7 Anchor",  group="SML Licensed — Set 7", minval=1)

i_s8t = input.int(1, "S8 Trigger", group="SML Licensed — Set 8", minval=1)
i_s8b = input.int(1, "S8 Base",    group="SML Licensed — Set 8", minval=1)
i_s8v = input.int(1, "S8 Valid",   group="SML Licensed — Set 8", minval=1)
i_s8a = input.int(1, "S8 Anchor",  group="SML Licensed — Set 8", minval=1)

i_s9t = input.int(1, "S9 Trigger", group="SML Licensed — Set 9", minval=1)
i_s9b = input.int(1, "S9 Base",    group="SML Licensed — Set 9", minval=1)
i_s9v = input.int(1, "S9 Valid",   group="SML Licensed — Set 9", minval=1)
i_s9a = input.int(1, "S9 Anchor",  group="SML Licensed — Set 9", minval=1)

// ── Display Groups ────────────────────────────────────────────────
grp_sets   = "Active Sets"
grp_conv   = "Convergence Engine"
grp_vis    = "Visual"
grp_alerts = "Alerts"

// ── Set Toggles ───────────────────────────────────────────────────
show_s1  = input.bool(false, "Set 1", group=grp_sets, inline="s1")
show_s2  = input.bool(false, "Set 2", group=grp_sets, inline="s2")
show_s3  = input.bool(false, "Set 3", group=grp_sets, inline="s3")
show_s4  = input.bool(false, "Set 4", group=grp_sets, inline="s4")
show_s5  = input.bool(false, "Set 5", group=grp_sets, inline="s5")
show_s6  = input.bool(true,  "Set 6", group=grp_sets, inline="s6")
show_s7  = input.bool(false, "Set 7", group=grp_sets, inline="s7")
show_s8  = input.bool(false, "Set 8", group=grp_sets, inline="s8")
show_s9  = input.bool(true,  "Set 9", group=grp_sets, inline="s9")

// ── Convergence Settings ──────────────────────────────────────────
conv_threshold = input.int(3,   "Min Sets for Convergence Alert", minval=2, maxval=9, group=grp_conv)
conv_band_pct  = input.float(0.5, "Convergence Band % (±)",       minval=0.1, maxval=2.0, step=0.1, group=grp_conv)
show_conv_bg   = input.bool(true,  "Show Convergence Background",  group=grp_conv)
show_conv_lbl  = input.bool(true,  "Show Convergence Label",       group=grp_conv)

// ── Visual ────────────────────────────────────────────────────────
line_width_fast   = input.int(1, "Trigger Line Width",  minval=1, maxval=4, group=grp_vis)
line_width_anchor = input.int(2, "Anchor Line Width",   minval=1, maxval=4, group=grp_vis)

// ── Color Palette (neon on black) ─────────────────────────────────
c1 = color.new(#00BFFF, 20)
c2 = color.new(#00FFFF, 20)
c3 = color.new(#39FF14, 20)
c4 = color.new(#FFE600, 20)
c5 = color.new(#FF8C00, 20)
c6 = color.new(#FF00FF, 20)
c7 = color.new(#FF1744, 20)
c8 = color.new(#AA00FF, 20)
c9 = color.new(#7B00FF, 20)

// ── EMA Calculations ──────────────────────────────────────────────
s1_t = ta.ema(close, i_s1t)
s1_b = ta.ema(close, i_s1b)
s1_v = ta.ema(close, i_s1v)
s1_a = ta.ema(close, i_s1a)

s2_t = ta.ema(close, i_s2t)
s2_b = ta.ema(close, i_s2b)
s2_v = ta.ema(close, i_s2v)
s2_a = ta.ema(close, i_s2a)

s3_t = ta.ema(close, i_s3t)
s3_b = ta.ema(close, i_s3b)
s3_v = ta.ema(close, i_s3v)
s3_a = ta.ema(close, i_s3a)

s4_t = ta.ema(close, i_s4t)
s4_b = ta.ema(close, i_s4b)
s4_v = ta.ema(close, i_s4v)
s4_a = ta.ema(close, i_s4a)

s5_t = ta.ema(close, i_s5t)
s5_b = ta.ema(close, i_s5b)
s5_v = ta.ema(close, i_s5v)
s5_a = ta.ema(close, i_s5a)

s6_t = ta.ema(close, i_s6t)
s6_b = ta.ema(close, i_s6b)
s6_v = ta.ema(close, i_s6v)
s6_a = ta.ema(close, i_s6a)

s7_t = ta.ema(close, i_s7t)
s7_b = ta.ema(close, i_s7b)
s7_v = ta.ema(close, i_s7v)
s7_a = ta.ema(close, i_s7a)

s8_t = ta.ema(close, i_s8t)
s8_b = ta.ema(close, i_s8b)
s8_v = ta.ema(close, i_s8v)
s8_a = ta.ema(close, i_s8a)

s9_t = ta.ema(close, i_s9t)
s9_b = ta.ema(close, i_s9b)
s9_v = ta.ema(close, i_s9v)
s9_a = ta.ema(close, i_s9a)

// ── Plots — Set 1 ────────────────────────────────────────────────
plot(show_s1 ? s1_t : na, "S1 Trigger", color=color.new(c1, 40), linewidth=line_width_fast)
plot(show_s1 ? s1_b : na, "S1 Base",    color=c1,                linewidth=line_width_fast)
plot(show_s1 ? s1_v : na, "S1 Valid",   color=c1,                linewidth=line_width_anchor)
plot(show_s1 ? s1_a : na, "S1 Anchor",  color=c1,                linewidth=line_width_anchor)

// ── Plots — Set 2 ────────────────────────────────────────────────
plot(show_s2 ? s2_t : na, "S2 Trigger", color=color.new(c2, 40), linewidth=line_width_fast)
plot(show_s2 ? s2_b : na, "S2 Base",    color=c2,                linewidth=line_width_fast)
plot(show_s2 ? s2_v : na, "S2 Valid",   color=c2,                linewidth=line_width_anchor)
plot(show_s2 ? s2_a : na, "S2 Anchor",  color=c2,                linewidth=line_width_anchor)

// ── Plots — Set 3 ────────────────────────────────────────────────
plot(show_s3 ? s3_t : na, "S3 Trigger", color=color.new(c3, 40), linewidth=line_width_fast)
plot(show_s3 ? s3_b : na, "S3 Base",    color=c3,                linewidth=line_width_fast)
plot(show_s3 ? s3_v : na, "S3 Valid",   color=c3,                linewidth=line_width_anchor)
plot(show_s3 ? s3_a : na, "S3 Anchor",  color=c3,                linewidth=line_width_anchor)

// ── Plots — Set 4 ────────────────────────────────────────────────
plot(show_s4 ? s4_t : na, "S4 Trigger", color=color.new(c4, 40), linewidth=line_width_fast)
plot(show_s4 ? s4_b : na, "S4 Base",    color=c4,                linewidth=line_width_fast)
plot(show_s4 ? s4_v : na, "S4 Valid",   color=c4,                linewidth=line_width_anchor)
plot(show_s4 ? s4_a : na, "S4 Anchor",  color=c4,                linewidth=line_width_anchor)

// ── Plots — Set 5 ────────────────────────────────────────────────
plot(show_s5 ? s5_t : na, "S5 Trigger", color=color.new(c5, 40), linewidth=line_width_fast)
plot(show_s5 ? s5_b : na, "S5 Base",    color=c5,                linewidth=line_width_fast)
plot(show_s5 ? s5_v : na, "S5 Valid",   color=c5,                linewidth=line_width_anchor)
plot(show_s5 ? s5_a : na, "S5 Anchor",  color=c5,                linewidth=line_width_anchor)

// ── Plots — Set 6 ────────────────────────────────────────────────
plot(show_s6 ? s6_t : na, "S6 Trigger", color=color.new(c6, 40), linewidth=line_width_fast)
plot(show_s6 ? s6_b : na, "S6 Base",    color=c6,                linewidth=line_width_fast)
plot(show_s6 ? s6_v : na, "S6 Valid",   color=c6,                linewidth=line_width_anchor)
plot(show_s6 ? s6_a : na, "S6 Anchor",  color=c6,                linewidth=line_width_anchor + 1)

// ── Plots — Set 7 ────────────────────────────────────────────────
plot(show_s7 ? s7_t : na, "S7 Trigger", color=color.new(c7, 40), linewidth=line_width_fast)
plot(show_s7 ? s7_b : na, "S7 Base",    color=c7,                linewidth=line_width_fast)
plot(show_s7 ? s7_v : na, "S7 Valid",   color=c7,                linewidth=line_width_anchor)
plot(show_s7 ? s7_a : na, "S7 Anchor",  color=c7,                linewidth=line_width_anchor)

// ── Plots — Set 8 ────────────────────────────────────────────────
plot(show_s8 ? s8_t : na, "S8 Trigger", color=color.new(c8, 40), linewidth=line_width_fast)
plot(show_s8 ? s8_b : na, "S8 Base",    color=c8,                linewidth=line_width_fast)
plot(show_s8 ? s8_v : na, "S8 Valid",   color=c8,                linewidth=line_width_anchor)
plot(show_s8 ? s8_a : na, "S8 Anchor",  color=c8,                linewidth=line_width_anchor)

// ── Plots — Set 9 ────────────────────────────────────────────────
plot(show_s9 ? s9_t : na, "S9 Trigger", color=color.new(c9, 40), linewidth=line_width_fast)
plot(show_s9 ? s9_b : na, "S9 Base",    color=c9,                linewidth=line_width_fast)
plot(show_s9 ? s9_v : na, "S9 Valid",   color=c9,                linewidth=line_width_anchor)
plot(show_s9 ? s9_a : na, "S9 Anchor",  color=c9,                linewidth=line_width_anchor + 1)

// ── Convergence Engine ────────────────────────────────────────────
band = close * (conv_band_pct / 100)

s1_near = math.abs(close - s1_a) <= band
s2_near = math.abs(close - s2_a) <= band
s3_near = math.abs(close - s3_a) <= band
s4_near = math.abs(close - s4_a) <= band
s5_near = math.abs(close - s5_a) <= band
s6_near = math.abs(close - s6_a) <= band
s7_near = math.abs(close - s7_a) <= band
s8_near = math.abs(close - s8_a) <= band
s9_near = math.abs(close - s9_a) <= band

conv_count = (s1_near ? 1 : 0) + (s2_near ? 1 : 0) + (s3_near ? 1 : 0) +
             (s4_near ? 1 : 0) + (s5_near ? 1 : 0) + (s6_near ? 1 : 0) +
             (s7_near ? 1 : 0) + (s8_near ? 1 : 0) + (s9_near ? 1 : 0)

convergence_lock = conv_count >= conv_threshold
max_convergence  = conv_count == 9

// ── Convergence Background ────────────────────────────────────────
bgcolor(show_conv_bg and max_convergence  ? color.new(#9900FF, 55) : na, title="MAX CONVERGENCE (9 Sets)")
bgcolor(show_conv_bg and not max_convergence and convergence_lock ? color.new(#00FFFF, 80) : na, title="Convergence Lock")

// ── Convergence Label ─────────────────────────────────────────────
var label conv_lbl = na
if show_conv_lbl and barstate.islast and convergence_lock
    label.delete(conv_lbl)
    lbl_txt = max_convergence
        ? "⚡ MAX CONVERGENCE\nAll 9 Sets Locked\nExplosive breakout imminent"
        : "◈ CONVERGENCE LOCK\n" + str.tostring(conv_count) + "/9 Sets Aligned\nInstitutional S/R cluster"
    lbl_col = max_convergence ? #9900FF : #00FFFF
    conv_lbl := label.new(bar_index, high * 1.002,
        text=lbl_txt,
        color=lbl_col,
        textcolor=color.white,
        style=label.style_label_down,
        size=size.normal)

// ── Bull / Bear Stack Detection (per active set) ──────────────────
s6_bull = close > s6_t and s6_t > s6_b and s6_b > s6_v and s6_v > s6_a
s6_bear = close < s6_t and s6_t < s6_b and s6_b < s6_v and s6_v < s6_a
s9_bull = close > s9_t and s9_t > s9_b and s9_b > s9_v and s9_v > s9_a
s9_bear = close < s9_t and s9_t < s9_b and s9_b < s9_v and s9_v < s9_a

dual_bull = s6_bull and s9_bull
dual_bear = s6_bear and s9_bear

plotshape(dual_bull and barstate.isconfirmed,
    title="Dual Bull Stack", style=shape.triangleup,
    location=location.belowbar, color=color.new(#00FF66, 0),
    size=size.tiny)

plotshape(dual_bear and barstate.isconfirmed,
    title="Dual Bear Stack", style=shape.triangledown,
    location=location.abovebar, color=color.new(#FF0055, 0),
    size=size.tiny)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(convergence_lock and not convergence_lock[1],
    "B4 Convergence Lock Triggered",
    "{{ticker}} — Base-4 Fractal Grid: " + str.tostring(conv_count) + " sets converging. Institutional support/resistance cluster forming.")

alertcondition(max_convergence and not max_convergence[1],
    "B4 MAX CONVERGENCE — All 9 Sets",
    "{{ticker}} — MAXIMUM CONVERGENCE: All 9 fractal sets aligned. Explosive breakout or breakdown imminent.")

alertcondition(dual_bull and not dual_bull[1],
    "B4 Dual Bull Stack (Sets 6+9)",
    "{{ticker}} — Base-4 S6+S9 full bull stack engaged. Trend confirmed across harmonic gears.")

alertcondition(dual_bear and not dual_bear[1],
    "B4 Dual Bear Stack (Sets 6+9)",
    "{{ticker}} — Base-4 S6+S9 full bear stack engaged. Institutional downtrend confirmed.")
