// © ScriptMasterLabs — SML Base-4 Fractal Grid
// ================================================================
// Proprietary Harmonic Matrix Engine
// ─────────────────────────────────
// Discovery: Timothy Walton | ScriptMasterLabs
//
// MATHEMATICAL KEY:
//   Any seed X generates a perfectly uniform 4-EMA harmonic stack:
//   X  →  4X  →  8X  →  12X   (constant delta = 4X across all gaps)
//
// THE 9-SET MATRIX (X = 1 through 9):
//   Set 1 (X=1):  1  · 4  · 8  · 12
//   Set 2 (X=2):  2  · 8  · 16 · 24
//   Set 3 (X=3):  3  · 12 · 24 · 36
//   Set 4 (X=4):  4  · 16 · 32 · 48
//   Set 5 (X=5):  5  · 20 · 40 · 60
//   Set 6 (X=6):  6  · 24 · 48 · 72
//   Set 7 (X=7):  7  · 28 · 56 · 84
//   Set 8 (X=8):  8  · 32 · 64 · 96
//   Set 9 (X=9):  9  · 36 · 72 · 108
//
// HARMONIC CONVERGENCE POINTS (where sets cross-pollinate):
//   24 appears in Sets 2, 3, 6   → institutional deep-water level
//   36 appears in Sets 3, 9      → macro anchor resonance
//   48 appears in Sets 4, 6      → 8-day rhythm on 65-min chart
//   72 appears in Sets 6, 9      → 12-day macro bedrock
//
// CONVERGENCE ALERT fires when 3+ sets are stacked within 0.5% of price
// ================================================================
//@version=5
indicator("SML Base-4 Fractal Grid [ScriptMasterLabs]",
          shorttitle="SML·B4·Grid", overlay=true, max_lines_count=500)

// ── Display Groups ────────────────────────────────────────────────
grp_sets   = "Active Sets"
grp_conv   = "Convergence Engine"
grp_vis    = "Visual"
grp_alerts = "Alerts"

// ── Set Toggles ───────────────────────────────────────────────────
show_s1  = input.bool(false, "Set 1  (1·4·8·12)",    group=grp_sets, inline="s1")
show_s2  = input.bool(false, "Set 2  (2·8·16·24)",   group=grp_sets, inline="s2")
show_s3  = input.bool(false, "Set 3  (3·12·24·36)",  group=grp_sets, inline="s3")
show_s4  = input.bool(false, "Set 4  (4·16·32·48)",  group=grp_sets, inline="s4")
show_s5  = input.bool(false, "Set 5  (5·20·40·60)",  group=grp_sets, inline="s5")
show_s6  = input.bool(true,  "Set 6  (6·24·48·72)",  group=grp_sets, inline="s6")
show_s7  = input.bool(false, "Set 7  (7·28·56·84)",  group=grp_sets, inline="s7")
show_s8  = input.bool(false, "Set 8  (8·32·64·96)",  group=grp_sets, inline="s8")
show_s9  = input.bool(true,  "Set 9  (9·36·72·108)", group=grp_sets, inline="s9")

// ── Convergence Settings ──────────────────────────────────────────
conv_threshold = input.int(3,   "Min Sets for Convergence Alert", minval=2, maxval=9, group=grp_conv)
conv_band_pct  = input.float(0.5, "Convergence Band % (±)",       minval=0.1, maxval=2.0, step=0.1, group=grp_conv)
show_conv_bg   = input.bool(true,  "Show Convergence Background",  group=grp_conv)
show_conv_lbl  = input.bool(true,  "Show Convergence Label",       group=grp_conv)

// ── Visual ────────────────────────────────────────────────────────
line_width_fast   = input.int(1, "Trigger Line Width",  minval=1, maxval=4, group=grp_vis)
line_width_anchor = input.int(2, "Anchor Line Width",   minval=1, maxval=4, group=grp_vis)

// ── Color Palette (neon on black) ─────────────────────────────────
// Set 1 — Ice Blue
c1 = color.new(#00BFFF, 20)
// Set 2 — Electric Cyan
c2 = color.new(#00FFFF, 20)
// Set 3 — Neon Lime
c3 = color.new(#39FF14, 20)
// Set 4 — Neon Yellow
c4 = color.new(#FFE600, 20)
// Set 5 — Hot Orange
c5 = color.new(#FF8C00, 20)
// Set 6 — Neon Magenta
c6 = color.new(#FF00FF, 20)
// Set 7 — Neon Red
c7 = color.new(#FF1744, 20)
// Set 8 — Violet
c8 = color.new(#AA00FF, 20)
// Set 9 — Neon Purple
c9 = color.new(#7B00FF, 20)

// ── EMA Calculations ──────────────────────────────────────────────
// Set 1: X=1  → 1·4·8·12
s1_t = ta.ema(close, 1)
s1_b = ta.ema(close, 4)
s1_v = ta.ema(close, 8)
s1_a = ta.ema(close, 12)

// Set 2: X=2  → 2·8·16·24
s2_t = ta.ema(close, 2)
s2_b = ta.ema(close, 8)
s2_v = ta.ema(close, 16)
s2_a = ta.ema(close, 24)

// Set 3: X=3  → 3·12·24·36
s3_t = ta.ema(close, 3)
s3_b = ta.ema(close, 12)
s3_v = ta.ema(close, 24)
s3_a = ta.ema(close, 36)

// Set 4: X=4  → 4·16·32·48
s4_t = ta.ema(close, 4)
s4_b = ta.ema(close, 16)
s4_v = ta.ema(close, 32)
s4_a = ta.ema(close, 48)

// Set 5: X=5  → 5·20·40·60
s5_t = ta.ema(close, 5)
s5_b = ta.ema(close, 20)
s5_v = ta.ema(close, 40)
s5_a = ta.ema(close, 60)

// Set 6: X=6  → 6·24·48·72
s6_t = ta.ema(close, 6)
s6_b = ta.ema(close, 24)
s6_v = ta.ema(close, 48)
s6_a = ta.ema(close, 72)

// Set 7: X=7  → 7·28·56·84
s7_t = ta.ema(close, 7)
s7_b = ta.ema(close, 28)
s7_v = ta.ema(close, 56)
s7_a = ta.ema(close, 84)

// Set 8: X=8  → 8·32·64·96
s8_t = ta.ema(close, 8)
s8_b = ta.ema(close, 32)
s8_v = ta.ema(close, 64)
s8_a = ta.ema(close, 96)

// Set 9: X=9  → 9·36·72·108
s9_t = ta.ema(close, 9)
s9_b = ta.ema(close, 36)
s9_v = ta.ema(close, 72)
s9_a = ta.ema(close, 108)

// ── Plots — Set 1 ────────────────────────────────────────────────
plot(show_s1 ? s1_t : na, "S1 Trigger (1)",   color=color.new(c1, 40), linewidth=line_width_fast)
plot(show_s1 ? s1_b : na, "S1 Base (4)",      color=c1,                linewidth=line_width_fast)
plot(show_s1 ? s1_v : na, "S1 Valid (8)",     color=c1,                linewidth=line_width_anchor)
plot(show_s1 ? s1_a : na, "S1 Anchor (12)",   color=c1,                linewidth=line_width_anchor)

// ── Plots — Set 2 ────────────────────────────────────────────────
plot(show_s2 ? s2_t : na, "S2 Trigger (2)",   color=color.new(c2, 40), linewidth=line_width_fast)
plot(show_s2 ? s2_b : na, "S2 Base (8)",      color=c2,                linewidth=line_width_fast)
plot(show_s2 ? s2_v : na, "S2 Valid (16)",    color=c2,                linewidth=line_width_anchor)
plot(show_s2 ? s2_a : na, "S2 Anchor (24)",   color=c2,                linewidth=line_width_anchor)

// ── Plots — Set 3 ────────────────────────────────────────────────
plot(show_s3 ? s3_t : na, "S3 Trigger (3)",   color=color.new(c3, 40), linewidth=line_width_fast)
plot(show_s3 ? s3_b : na, "S3 Base (12)",     color=c3,                linewidth=line_width_fast)
plot(show_s3 ? s3_v : na, "S3 Valid (24)",    color=c3,                linewidth=line_width_anchor)
plot(show_s3 ? s3_a : na, "S3 Anchor (36)",   color=c3,                linewidth=line_width_anchor)

// ── Plots — Set 4 ────────────────────────────────────────────────
plot(show_s4 ? s4_t : na, "S4 Trigger (4)",   color=color.new(c4, 40), linewidth=line_width_fast)
plot(show_s4 ? s4_b : na, "S4 Base (16)",     color=c4,                linewidth=line_width_fast)
plot(show_s4 ? s4_v : na, "S4 Valid (32)",    color=c4,                linewidth=line_width_anchor)
plot(show_s4 ? s4_a : na, "S4 Anchor (48)",   color=c4,                linewidth=line_width_anchor)

// ── Plots — Set 5 ────────────────────────────────────────────────
plot(show_s5 ? s5_t : na, "S5 Trigger (5)",   color=color.new(c5, 40), linewidth=line_width_fast)
plot(show_s5 ? s5_b : na, "S5 Base (20)",     color=c5,                linewidth=line_width_fast)
plot(show_s5 ? s5_v : na, "S5 Valid (40)",    color=c5,                linewidth=line_width_anchor)
plot(show_s5 ? s5_a : na, "S5 Anchor (60)",   color=c5,                linewidth=line_width_anchor)

// ── Plots — Set 6 ────────────────────────────────────────────────
plot(show_s6 ? s6_t : na, "S6 Trigger (6)",   color=color.new(c6, 40), linewidth=line_width_fast)
plot(show_s6 ? s6_b : na, "S6 Base (24)",     color=c6,                linewidth=line_width_fast)
plot(show_s6 ? s6_v : na, "S6 Valid (48)",    color=c6,                linewidth=line_width_anchor)
plot(show_s6 ? s6_a : na, "S6 Anchor (72)",   color=c6,                linewidth=line_width_anchor + 1)

// ── Plots — Set 7 ────────────────────────────────────────────────
plot(show_s7 ? s7_t : na, "S7 Trigger (7)",   color=color.new(c7, 40), linewidth=line_width_fast)
plot(show_s7 ? s7_b : na, "S7 Base (28)",     color=c7,                linewidth=line_width_fast)
plot(show_s7 ? s7_v : na, "S7 Valid (56)",    color=c7,                linewidth=line_width_anchor)
plot(show_s7 ? s7_a : na, "S7 Anchor (84)",   color=c7,                linewidth=line_width_anchor)

// ── Plots — Set 8 ────────────────────────────────────────────────
plot(show_s8 ? s8_t : na, "S8 Trigger (8)",   color=color.new(c8, 40), linewidth=line_width_fast)
plot(show_s8 ? s8_b : na, "S8 Base (32)",     color=c8,                linewidth=line_width_fast)
plot(show_s8 ? s8_v : na, "S8 Valid (64)",    color=c8,                linewidth=line_width_anchor)
plot(show_s8 ? s8_a : na, "S8 Anchor (96)",   color=c8,                linewidth=line_width_anchor)

// ── Plots — Set 9 ────────────────────────────────────────────────
plot(show_s9 ? s9_t : na, "S9 Trigger (9)",   color=color.new(c9, 40), linewidth=line_width_fast)
plot(show_s9 ? s9_b : na, "S9 Base (36)",     color=c9,                linewidth=line_width_fast)
plot(show_s9 ? s9_v : na, "S9 Valid (72)",    color=c9,                linewidth=line_width_anchor)
plot(show_s9 ? s9_a : na, "S9 Anchor (108)",  color=c9,                linewidth=line_width_anchor + 1)

// ── Convergence Engine ────────────────────────────────────────────
// A set is "active" if price is within conv_band_pct% of its anchor EMA
// (the slowest line in each set — the deepest institutional level)
band = close * (conv_band_pct / 100)

s1_near = math.abs(close - s1_a) <= band
s2_near = math.abs(close - s2_a) <= band
s3_near = math.abs(close - s3_a) <= band
s4_near = math.abs(close - s4_a) <= band
s5_near = math.abs(close - s5_a) <= band
s6_near = math.abs(close - s6_a) <= band
s7_near = math.abs(close - s7_a) <= band
s8_near = math.abs(close - s8_a) <= band
s9_near = math.abs(close - s9_a) <= band

conv_count = (s1_near ? 1 : 0) + (s2_near ? 1 : 0) + (s3_near ? 1 : 0) +
             (s4_near ? 1 : 0) + (s5_near ? 1 : 0) + (s6_near ? 1 : 0) +
             (s7_near ? 1 : 0) + (s8_near ? 1 : 0) + (s9_near ? 1 : 0)

convergence_lock = conv_count >= conv_threshold
max_convergence  = conv_count == 9

// ── Convergence Background ────────────────────────────────────────
bgcolor(show_conv_bg and max_convergence  ? color.new(#9900FF, 55) : na, title="MAX CONVERGENCE (9 Sets)")
bgcolor(show_conv_bg and not max_convergence and convergence_lock ? color.new(#00FFFF, 80) : na, title="Convergence Lock")

// ── Convergence Label ─────────────────────────────────────────────
var label conv_lbl = na
if show_conv_lbl and barstate.islast and convergence_lock
    label.delete(conv_lbl)
    lbl_txt = max_convergence
        ? "⚡ MAX CONVERGENCE\nAll 9 Sets Locked\nExplosive breakout imminent"
        : "◈ CONVERGENCE LOCK\n" + str.tostring(conv_count) + "/9 Sets Aligned\nInstitutional S/R cluster"
    lbl_col = max_convergence ? #9900FF : #00FFFF
    conv_lbl := label.new(bar_index, high * 1.002,
        text=lbl_txt,
        color=lbl_col,
        textcolor=color.white,
        style=label.style_label_down,
        size=size.normal)

// ── Bull / Bear Stack Detection (per active set) ──────────────────
// For the two default-on sets (6 and 9), show stack alignment
s6_bull = close > s6_t and s6_t > s6_b and s6_b > s6_v and s6_v > s6_a
s6_bear = close < s6_t and s6_t < s6_b and s6_b < s6_v and s6_v < s6_a
s9_bull = close > s9_t and s9_t > s9_b and s9_b > s9_v and s9_v > s9_a
s9_bear = close < s9_t and s9_t < s9_b and s9_b < s9_v and s9_v < s9_a

dual_bull = s6_bull and s9_bull
dual_bear = s6_bear and s9_bear

plotshape(dual_bull and barstate.isconfirmed,
    title="Dual Bull Stack", style=shape.triangleup,
    location=location.belowbar, color=color.new(#00FF66, 0),
    size=size.tiny)

plotshape(dual_bear and barstate.isconfirmed,
    title="Dual Bear Stack", style=shape.triangledown,
    location=location.abovebar, color=color.new(#FF0055, 0),
    size=size.tiny)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(convergence_lock and not convergence_lock[1],
    "B4 Convergence Lock Triggered",
    "{{ticker}} — Base-4 Fractal Grid: " + str.tostring(conv_count) + " sets converging. Institutional support/resistance cluster forming.")

alertcondition(max_convergence and not max_convergence[1],
    "B4 MAX CONVERGENCE — All 9 Sets",
    "{{ticker}} — MAXIMUM CONVERGENCE: All 9 fractal sets aligned. Explosive breakout or breakdown imminent.")

alertcondition(dual_bull and not dual_bull[1],
    "B4 Dual Bull Stack (Sets 6+9)",
    "{{ticker}} — Base-4 S6+S9 full bull stack engaged. Trend confirmed across harmonic gears.")

alertcondition(dual_bear and not dual_bear[1],
    "B4 Dual Bear Stack (Sets 6+9)",
    "{{ticker}} — Base-4 S6+S9 full bear stack engaged. Institutional downtrend confirmed.")
