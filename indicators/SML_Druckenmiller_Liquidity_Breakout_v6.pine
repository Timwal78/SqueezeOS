// © scriptmasterlabs — Druckenmiller Liquidity Breakout Indicator (Pine Script v6)
// Indicator version — draws signals on chart, no strategy backtest engine.
// Trade the signals manually. Diamond = JUGULAR (high conviction), Triangle = breakout entry,
// Circle = mean-reversion entry, X = exit (stop or target hit).
//
// v6.1 fixes:
//  - Entry signals fire ONCE on the breakout/extreme crossover, not on every bar of a trend
//  - Mean-reversion entries no longer double-plot (circle only, no triangle)
//  - Position state machine: exits (stop/target hit) are detected and marked on chart
//  - Trailing stop reset actually works (old reset checked direction after it was overwritten)
//  - Max Pyramid Additions is enforced; each add requires another N ATRs beyond the last add
//  - Conviction is direction-aware (DXY filter no longer adds +1 for ANY dollar state)
//  - DXY default ticker fixed ("FX_IDC" was not a valid symbol)
//  - Signals confirm on bar close (barstate.isconfirmed) — no intrabar flicker/repaint
//
// v6.2: Higher-Timeframe default changed from Daily to 2H (120min) to match faster
// 9/20 EMA setups on 15-min charts hunting .30-.40 delta explosive moves — Daily was too
// slow to confirm those entries. Still an input, override on the chart as needed.

//@version=6
indicator("Druckenmiller Liquidity Breakout", shorttitle="DRUCK-LB", overlay=true,
     max_lines_count=50, max_labels_count=50, max_bars_back=500)

// =========================================================================
// INPUTS
// =========================================================================
grpRegime    = "Regime Detection"
adxLen       = input.int(14, "ADX Length", group=grpRegime)
adxTrend     = input.float(25.0, "ADX Trend Threshold", group=grpRegime, tooltip="Above this = trending regime")
atrLen       = input.int(14, "ATR Length", group=grpRegime)
atrPctLen    = input.int(100, "ATR Percentile Lookback", group=grpRegime)
atrVolPct    = input.float(85.0, "ATR Volatile Percentile", group=grpRegime, tooltip="Above this = volatile regime")

grpEntry     = "Entry Logic"
breakoutLen  = input.int(20, "Breakout Channel Length", group=grpEntry)
emaFast      = input.int(21, "Fast EMA", group=grpEntry)
emaSlow      = input.int(55, "Slow EMA", group=grpEntry)
volumeFilt   = input.bool(true, "Require Volume Expansion on Breakout", group=grpEntry)
volMult      = input.float(1.5, "Volume Expansion Multiplier", group=grpEntry)
rangeZScore  = input.float(2.0, "Range Z-Score Entry (mean-revert)", group=grpEntry)

grpRisk      = "Risk Management"
riskPct      = input.float(1.0, "Base Risk % per Trade", group=grpRisk)
jugRiskPct   = input.float(3.0, "Jugular Risk % (high conviction)", group=grpRisk, tooltip="Used when conviction score qualifies as JUGULAR")
rrRatio      = input.float(3.0, "Risk/Reward Ratio Minimum", group=grpRisk)
atrStopMult  = input.float(2.0, "ATR Stop Multiplier", group=grpRisk)
trailAtrMult = input.float(3.0, "Trailing ATR Multiplier", group=grpRisk)

grpPyramid   = "Pyramiding"
showPyramid  = input.bool(true, "Show Pyramid Signals", group=grpPyramid)
maxPyramids  = input.int(3, "Max Pyramid Additions", group=grpPyramid, minval=0)
pyramidTrigger = input.float(1.0, "Pyramid Trigger (ATRs in favor)", group=grpPyramid, tooltip="Add when price moves this many ATRs beyond the last add level")

grpFilter    = "Filters"
useDXY       = input.bool(false, "Use DXY as macro filter", group=grpFilter)
dxyTicker    = input.symbol("TVC:DXY", "DXY Ticker", group=grpFilter)
dxySmaLen    = input.int(50, "DXY SMA Length", group=grpFilter, tooltip="Dollar above its SMA = risk-off (bearish risk assets)")
useHigherTrend = input.bool(true, "Higher-Timeframe Trend Filter", group=grpFilter)
htfTimeframe = input.timeframe("120", "Higher Timeframe", group=grpFilter)

grpVis       = "Visualization"
showBg       = input.bool(true, "Show Regime Background", group=grpVis)
showLevels   = input.bool(true, "Show Breakout Levels", group=grpVis)
showStops    = input.bool(true, "Show Stop/Target Lines While In Signal", group=grpVis)

// =========================================================================
// REGIME DETECTION
// =========================================================================
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxLen)
atr = ta.atr(atrLen)
atrPctile = ta.percentrank(atr, atrPctLen)

isTrending  = adx >= adxTrend
isVolatile  = atrPctile >= atrVolPct

regime = isVolatile ? 0 : (isTrending ? 2 : 1)
// 0 = VOLATILE (flat), 1 = RANGE (mean-revert), 2 = TREND (breakout)

regimeColor = regime == 0 ? color.new(color.red, 85) :
              regime == 1 ? color.new(color.yellow, 90) :
              color.new(color.green, 88)

// =========================================================================
// TREND FILTERS
// =========================================================================
emaF = ta.ema(close, emaFast)
emaS = ta.ema(close, emaSlow)
trendUp   = emaF > emaS
trendDown = emaF < emaS

// Higher timeframe trend
htfEmaF  = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaFast), lookahead=barmerge.lookahead_off)
htfEmaS  = request.security(syminfo.tickerid, htfTimeframe, ta.ema(close, emaSlow), lookahead=barmerge.lookahead_off)
htfUp    = htfEmaF > htfEmaS
htfDown  = htfEmaF < htfEmaS

// DXY macro filter (dollar strength = risk-off). ta.sma runs inside request.security
// so it executes on every bar of the DXY series — never inside a conditional.
dxyClose = request.security(dxyTicker, timeframe.period, close, lookahead=barmerge.lookahead_off)
dxySma   = request.security(dxyTicker, timeframe.period, ta.sma(close, dxySmaLen), lookahead=barmerge.lookahead_off)
dxyRiskOff = useDXY and not na(dxyClose) and not na(dxySma) and dxyClose > dxySma   // strong dollar → favors shorts
dxyRiskOn  = useDXY and not na(dxyClose) and not na(dxySma) and dxyClose < dxySma   // weak dollar → favors longs

// =========================================================================
// BREAKOUT LOGIC — trigger on the crossover event, not on every bar above the level
// =========================================================================
hh = ta.highest(high, breakoutLen)
ll = ta.lowest(low, breakoutLen)
channelMid = (hh + ll) / 2

volAvg = ta.sma(volume, 20)
volExpanded = not volumeFilt or (volume > volAvg * volMult)

longBreakout  = ta.crossover(close, hh[1]) and volExpanded
shortBreakout = ta.crossunder(close, ll[1]) and volExpanded

// =========================================================================
// MEAN-REVERSION LOGIC (range regime) — trigger when z-score first reaches the extreme
// =========================================================================
mean = ta.sma(close, breakoutLen)
stdDev = ta.stdev(close, breakoutLen)
zScore = stdDev > 0 ? (close - mean) / stdDev : 0

longMR  = ta.crossunder(zScore, -rangeZScore) and close > ll
shortMR = ta.crossover(zScore, rangeZScore) and close < hh

// =========================================================================
// CONVICTION SCORING — direction-aware (a filter can only support ONE side)
// =========================================================================
convBase  = (adx > 35 ? 2 : 0)
convLong  = convBase + (trendUp and htfUp ? 1 : 0) + (dxyRiskOn and regime == 2 ? 1 : 0) + (diPlus - diMinus > 15 ? 1 : 0)
convShort = convBase + (trendDown and htfDown ? 1 : 0) + (dxyRiskOff and regime == 2 ? 1 : 0) + (diMinus - diPlus > 15 ? 1 : 0)

jugularLong  = convLong >= 4
jugularShort = convShort >= 4

// =========================================================================
// SIGNAL CONDITIONS — confirmed on bar close only (no intrabar repaint)
// =========================================================================
confirmed = barstate.isconfirmed

// TREND REGIME — breakout with trend alignment
longEntryCond  = regime == 2 and longBreakout and trendUp and (not useHigherTrend or htfUp) and confirmed
shortEntryCond = regime == 2 and shortBreakout and trendDown and (not useHigherTrend or htfDown) and confirmed

// RANGE REGIME — mean reversion at extremes
longMRCond  = regime == 1 and longMR and confirmed
shortMRCond = regime == 1 and shortMR and confirmed

longSignal  = longEntryCond or longMRCond
shortSignal = shortEntryCond or shortMRCond

// =========================================================================
// POSITION STATE MACHINE (for manual trading reference)
// =========================================================================
var int   sigDir       = 0      // 0=flat, 1=long, -1=short
var float entryPx      = na
var float stopPx       = na
var float targetPx     = na
var float trailStop    = na
var float atrAtEntry   = na
var int   entryBar     = na
var int   pyramidCount = 0
var bool  entryIsJugular = false

// Per-bar event flags (drive shapes + alerts)
bool evLongJug   = false
bool evShortJug  = false
bool evLongBrk   = false
bool evShortBrk  = false
bool evLongMR    = false
bool evShortMR   = false
bool evPyramid   = false
bool evStopHit   = false
bool evTargetHit = false

// --- 1. Exit detection (only when in a position and not on the entry bar) ---
if sigDir != 0 and confirmed and not na(entryBar) and bar_index > entryBar
    stopHit   = sigDir == 1 ? low <= stopPx : high >= stopPx
    targetHit = sigDir == 1 ? high >= targetPx : low <= targetPx
    if stopHit
        evStopHit := true
    else if targetHit
        evTargetHit := true
    if stopHit or targetHit
        sigDir := 0
        entryPx := na
        stopPx := na
        targetPx := na
        trailStop := na
        atrAtEntry := na
        entryBar := na
        pyramidCount := 0
        entryIsJugular := false

// --- 2. Entries (also handles reversal: opposite signal replaces the old one) ---
if longSignal and sigDir != 1
    sigDir := 1
    entryPx := close
    atrAtEntry := atr
    stopPx := close - atr * atrStopMult
    targetPx := close + atr * atrStopMult * rrRatio
    trailStop := close - atr * trailAtrMult
    entryBar := bar_index
    pyramidCount := 0
    entryIsJugular := jugularLong
    evLongJug := jugularLong
    evLongBrk := longEntryCond and not jugularLong
    evLongMR  := longMRCond and not longEntryCond and not jugularLong

if shortSignal and sigDir != -1
    sigDir := -1
    entryPx := close
    atrAtEntry := atr
    stopPx := close + atr * atrStopMult
    targetPx := close - atr * atrStopMult * rrRatio
    trailStop := close + atr * trailAtrMult
    entryBar := bar_index
    pyramidCount := 0
    entryIsJugular := jugularShort
    evShortJug := jugularShort
    evShortBrk := shortEntryCond and not jugularShort
    evShortMR  := shortMRCond and not shortEntryCond and not jugularShort

// --- 3. Trailing stop (rides winners; only ever tightens) ---
if sigDir == 1 and confirmed and bar_index > nz(entryBar, bar_index)
    trailStop := math.max(trailStop, close - atr * trailAtrMult)
    stopPx := math.max(stopPx, trailStop)
if sigDir == -1 and confirmed and bar_index > nz(entryBar, bar_index)
    trailStop := math.min(trailStop, close + atr * trailAtrMult)
    stopPx := math.min(stopPx, trailStop)

// --- 4. Pyramiding — capped at maxPyramids, each add needs another N ATRs beyond the last ---
if showPyramid and sigDir != 0 and confirmed and regime == 2 and pyramidCount < maxPyramids and not na(entryBar) and bar_index > entryBar
    nextAddLevel = sigDir == 1 ?
         entryPx + atrAtEntry * pyramidTrigger * (pyramidCount + 1) :
         entryPx - atrAtEntry * pyramidTrigger * (pyramidCount + 1)
    addTriggered = sigDir == 1 ? close >= nextAddLevel : close <= nextAddLevel
    if addTriggered
        pyramidCount := pyramidCount + 1
        evPyramid := true

currentRisk = (sigDir != 0 ? entryIsJugular : (jugularLong or jugularShort)) ? jugRiskPct : riskPct

// =========================================================================
// VISUALIZATION
// =========================================================================
// Regime background
bgcolor(showBg ? regimeColor : na)

// Breakout levels
plot(showLevels ? hh : na, "Donchian High", color=color.new(color.green, 50), style=plot.style_stepline)
plot(showLevels ? ll : na, "Donchian Low", color=color.new(color.red, 50), style=plot.style_stepline)
plot(showLevels ? channelMid : na, "Channel Mid", color=color.new(color.gray, 70))

// EMAs
plot(emaF, "EMA Fast", color=color.new(color.blue, 30), linewidth=1)
plot(emaS, "EMA Slow", color=color.new(color.orange, 30), linewidth=1)

// Stop/Target reference lines (only while a signal is active — cleared on exit)
plot(showStops and sigDir != 0 ? stopPx : na, "Stop Loss", color=color.red, style=plot.style_linebr, linewidth=2)
plot(showStops and sigDir != 0 ? targetPx : na, "Take Profit", color=color.green, style=plot.style_linebr, linewidth=2)

// Entry signals — one shape per entry, no overlap between shape types
plotshape(evLongJug, "JUGULAR LONG", style=shape.diamond, location=location.belowbar, color=color.yellow, size=size.small, text="JUG", textcolor=color.yellow)
plotshape(evShortJug, "JUGULAR SHORT", style=shape.diamond, location=location.abovebar, color=color.yellow, size=size.small, text="JUG", textcolor=color.yellow)
plotshape(evLongBrk, "Long Entry", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(evShortBrk, "Short Entry", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)
plotshape(evLongMR, "MR Long", style=shape.circle, location=location.belowbar, color=color.new(color.green, 40), size=size.tiny)
plotshape(evShortMR, "MR Short", style=shape.circle, location=location.abovebar, color=color.new(color.red, 40), size=size.tiny)

// Exit signals
plotshape(evStopHit, "Stop Hit", style=shape.xcross, location=location.abovebar, color=color.red, size=size.small, text="SL", textcolor=color.red)
plotshape(evTargetHit, "Target Hit", style=shape.xcross, location=location.belowbar, color=color.green, size=size.small, text="TP", textcolor=color.green)

// Pyramid signal
plotshape(evPyramid and sigDir == 1, "Pyramid Long", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 20), size=size.tiny, text="+", textcolor=color.lime)
plotshape(evPyramid and sigDir == -1, "Pyramid Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.fuchsia, 20), size=size.tiny, text="+", textcolor=color.fuchsia)

// Alert conditions
alertcondition(evLongJug or evLongBrk or evLongMR, "Long Signal", "DRUCK-LB: LONG signal")
alertcondition(evShortJug or evShortBrk or evShortMR, "Short Signal", "DRUCK-LB: SHORT signal")
alertcondition(evLongJug, "JUGULAR Long", "DRUCK-LB: JUGULAR LONG — high conviction")
alertcondition(evShortJug, "JUGULAR Short", "DRUCK-LB: JUGULAR SHORT — high conviction")
alertcondition(evPyramid, "Pyramid", "DRUCK-LB: Pyramid signal — add to position")
alertcondition(evStopHit, "Stop Hit", "DRUCK-LB: Stop hit — exit position")
alertcondition(evTargetHit, "Target Hit", "DRUCK-LB: Target hit — take profit")

// =========================================================================
// INFO PANEL
// =========================================================================
var table infoPanel = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 20), border_width=1)

if barstate.islast
    regimeText = regime == 0 ? "VOLATILE — FLAT" : regime == 1 ? "RANGE — Mean Revert" : "TREND — Breakout"
    regimeCol  = regime == 0 ? color.red : regime == 1 ? color.yellow : color.green

    table.cell(infoPanel, 0, 0, "REGIME", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 0, regimeText, text_color=regimeCol, text_size=size.small)

    table.cell(infoPanel, 0, 1, "ADX", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 1, str.tostring(adx, "#.0"), text_color=color.white, text_size=size.small)

    table.cell(infoPanel, 0, 2, "ATR %ile", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 2, str.tostring(atrPctile, "#0"), text_color=color.white, text_size=size.small)

    convDisp = math.max(convLong, convShort)
    isJugularNow = jugularLong or jugularShort
    table.cell(infoPanel, 0, 3, "Conviction", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 3, str.tostring(convDisp) + (isJugularNow ? " ★" : ""), text_color=isJugularNow ? color.yellow : color.white, text_size=size.small)

    table.cell(infoPanel, 0, 4, "Risk/Trade", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 4, str.tostring(currentRisk, "#.0") + "%", text_color=color.white, text_size=size.small)

    posText = sigDir == 1 ? "LONG" + (entryIsJugular ? " ★" : "") : sigDir == -1 ? "SHORT" + (entryIsJugular ? " ★" : "") : "FLAT"
    posCol = sigDir == 1 ? color.green : sigDir == -1 ? color.red : color.gray
    table.cell(infoPanel, 0, 5, "Signal", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 5, posText + (sigDir != 0 and pyramidCount > 0 ? " +" + str.tostring(pyramidCount) : ""), text_color=posCol, text_size=size.small)

    table.cell(infoPanel, 0, 6, "Stop", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 6, sigDir == 0 or na(stopPx) ? "—" : "$" + str.tostring(stopPx, "#.00"), text_color=color.red, text_size=size.small)

    table.cell(infoPanel, 0, 7, "Target", text_color=color.white, text_size=size.small)
    table.cell(infoPanel, 1, 7, sigDir == 0 or na(targetPx) ? "—" : "$" + str.tostring(targetPx, "#.00"), text_color=color.green, text_size=size.small)
