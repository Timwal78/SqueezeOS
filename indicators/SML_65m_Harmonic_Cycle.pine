// © ScriptMasterLabs — SML 65m Harmonic Cycle [+33 Sequence]
// ================================================================
// LOAD ON 65-MINUTE CHART ONLY
//
// 390 min/session ÷ 65 min/bar = 6 bars per day (exact, zero remainder)
// This is the only standard timeframe that divides the NYSE session perfectly.
//
// +33 Harmonic Sequence — anchored to session microstructure:
//
//   EMA 3   → Day 1   midday  (12:45 PM) ← REVERSAL node
//   EMA 36  → Day 6   close   ( 4:00 PM) ← SETTLEMENT node
//   EMA 69  → Day 12  midday  (12:45 PM) ← REVERSAL node
//   EMA 102 → Day 17  close   ( 4:00 PM) ← SETTLEMENT node
//   EMA 135 → Day 23  midday  (12:45 PM) ← REVERSAL node
//
// The sequence alternates: REVERSAL → SETTLEMENT → REVERSAL → ...
//   Reversal nodes  (3, 69, 135): dead center of the intraday session
//                                 where short-term reversals print
//   Settlement nodes (36, 102):   final closing print of the day
//                                 where institutional settlement volume spikes
//
// The daily chart gives the macro vector.
// This chart tells you the exact hour the energy shifts.
//
// Pair with: SML Sovereign Stack (daily) for 365/741 macro anchor
//            SML E1 Tactical Matrix  for 6·33·66·99·123 micro-coil overlay
// ================================================================
//@version=5
indicator("SML 65m Harmonic Cycle [+33 Sequence]",
          shorttitle="SML·65H·+33", overlay=true)

// ═══ INPUTS ═══════════════════════════════════════════════════════
show_reversal   = input.bool(true, "Reversal Nodes   (EMA 3 · 69 · 135)",   group="Nodes")
show_settlement = input.bool(true, "Settlement Nodes (EMA 36 · 102)",        group="Nodes")

show_labels = input.bool(true, "Show Signal Label",       group="Display")
show_bands  = input.bool(true, "Show Signal Background",  group="Display")
coil_thresh = input.float(0.8, "Harmonic Coil Width %",   group="Display", minval=0.1, step=0.1)

// ═══ EMAs ═════════════════════════════════════════════════════════
// +33 sequence starting at 3 — each step = 5.5 days × 6 bars/day
// Odd nodes (bar ÷ 6 has remainder 0.5) → midday reversal
// Even nodes (bar ÷ 6 is integer)       → closing settlement

e3   = ta.ema(close, 3)    // Day 1 midday  — REVERSAL  node (3 mod 6 = 3)
e36  = ta.ema(close, 36)   // Day 6 close   — SETTLEMENT node (36 mod 6 = 0)
e69  = ta.ema(close, 69)   // Day 12 midday — REVERSAL  node (69 mod 6 = 3)
e102 = ta.ema(close, 102)  // Day 17 close  — SETTLEMENT node (102 mod 6 = 0)
e135 = ta.ema(close, 135)  // Day 23 midday — REVERSAL  node (135 mod 6 = 3)

// ═══ SIGNAL LOGIC ═════════════════════════════════════════════════

// Full 5-node alignment
bull_stack = e3 > e36 and e36 > e69 and e69 > e102 and e102 > e135
bear_stack = e3 < e36 and e36 < e69 and e69 < e102 and e102 < e135

// Lock score: count aligned pairs (e3>e36, e36>e69, e69>e102, e102>e135)
bull_pairs = (e3 > e36 ? 1 : 0) + (e36 > e69 ? 1 : 0) + (e69 > e102 ? 1 : 0) + (e102 > e135 ? 1 : 0)
bear_pairs = (e3 < e36 ? 1 : 0) + (e36 < e69 ? 1 : 0) + (e69 < e102 ? 1 : 0) + (e102 < e135 ? 1 : 0)

// Stretch from slowest reversal anchor (EMA 135 = Day 23 midday)
stretch_135 = (close - e135) / e135 * 100

// Harmonic compression — all 5 nodes collapsing into a coil
spread = math.abs((e3 - e135) / e135 * 100)
harmonic_coil = spread < coil_thresh

// Key crossovers — fast reversal node crossing slow settlement node
rev_ignition   = ta.crossover( e3, e36)   // Rev node accelerating through Settlement — bullish ignition
rev_breakdown  = ta.crossunder(e3, e36)   // Rev node dropping through Settlement — bearish breakdown
settle_reclaim = ta.crossover( e36, e69)  // Settlement reclaiming the next Rev node — trend resuming

// ═══ PLOTS ════════════════════════════════════════════════════════

// Reversal nodes — gold/warm (midday session energy)
plot(show_reversal   ? e3   : na, "R · EMA 3   (Day 1  Midday — Reversal)",
     color=color.new(#FFD700, 10), linewidth=2)
plot(show_reversal   ? e69  : na, "R · EMA 69  (Day 12 Midday — Reversal)",
     color=color.new(#FF9900, 10), linewidth=2)
plot(show_reversal   ? e135 : na, "R · EMA 135 (Day 23 Midday — Reversal)",
     color=color.new(#FF6600,  5), linewidth=3)

// Settlement nodes — blue/institutional (closing bell energy)
plot(show_settlement ? e36  : na, "S · EMA 36  (Day 6  Close  — Settlement)",
     color=color.new(#0088FF, 10), linewidth=2, style=plot.style_line)
plot(show_settlement ? e102 : na, "S · EMA 102 (Day 17 Close  — Settlement)",
     color=color.new(#0044CC,  5), linewidth=3, style=plot.style_line)

// ═══ BACKGROUND ═══════════════════════════════════════════════════

bg_color = bull_stack    ? color.new(color.green,  55) :
           bear_stack    ? color.new(color.red,    55) :
           bull_pairs >= 3 ? color.new(color.teal,   80) :
           bear_pairs >= 3 ? color.new(color.orange, 80) :
           harmonic_coil ? color.new(color.blue,   82) : na

bgcolor(show_bands ? bg_color : na, title="SML 65H Signal Background")

// ═══ SIGNAL LABEL ════════════════════════════════════════════════

var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)

    // Node state tags
    n1 = e3   > e36  ? "3↑"  : "3↓"
    n2 = e36  > e69  ? "36↑" : "36↓"
    n3 = e69  > e102 ? "69↑" : "69↓"
    n4 = e102 > e135 ? "102↑": "102↓"
    node_line = n1 + " · " + n2 + " · " + n3 + " · " + n4

    sig_txt = bull_stack      ? "65H: HARMONIC BULL (5/5)\n+" + str.tostring(stretch_135, "#.##") + "% above EMA135\n" + node_line :
              bear_stack      ? "65H: HARMONIC BEAR (5/5)\n"  + str.tostring(stretch_135, "#.##") + "% below EMA135\n" + node_line :
              bull_pairs >= 3 ? "65H: PARTIAL BULL (" + str.tostring(bull_pairs) + "/4 pairs)\n" + node_line :
              bear_pairs >= 3 ? "65H: PARTIAL BEAR (" + str.tostring(bear_pairs) + "/4 pairs)\n" + node_line :
              harmonic_coil   ? "65H: HARMONIC COIL\nSpread " + str.tostring(spread, "#.##") + "% — nodes collapsing\n" + node_line :
              "65H: NEUTRAL (" + str.tostring(bull_pairs) + "B / " + str.tostring(bear_pairs) + "Be)\n" + node_line

    lbl_col = bull_stack or bull_pairs >= 3 ? color.green  :
              bear_stack or bear_pairs >= 3 ? color.red    :
              harmonic_coil                 ? color.blue   : color.gray

    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ═══ ALERTS ══════════════════════════════════════════════════════

alertcondition(bull_stack,
    "65H Full Harmonic Bull (5/5 nodes)",
    "{{ticker}} [65m] — HARMONIC BULL: All 5 +33 nodes aligned. Price above EMA3>36>69>102>135.")

alertcondition(bear_stack,
    "65H Full Harmonic Bear (5/5 nodes)",
    "{{ticker}} [65m] — HARMONIC BEAR: All 5 +33 nodes aligned. Price below EMA3<36<69<102<135.")

alertcondition(rev_ignition,
    "65H Reversal Ignition (EMA3 crosses EMA36)",
    "{{ticker}} [65m] — REVERSAL IGNITION: Midday reversal node (EMA3) crossed above settlement node (EMA36). Bullish harmonic sequence loading.")

alertcondition(rev_breakdown,
    "65H Reversal Breakdown (EMA3 crosses under EMA36)",
    "{{ticker}} [65m] — REVERSAL BREAKDOWN: Midday reversal node (EMA3) dropped below settlement node (EMA36). Bearish harmonic sequence loading.")

alertcondition(harmonic_coil,
    "65H Harmonic Coil — All Nodes Compressing",
    "{{ticker}} [65m] — HARMONIC COIL: All 5 nodes compressed within " + str.tostring(coil_thresh, "#.#") + "%. Energy loading before expansion.")

alertcondition(settle_reclaim,
    "65H Settlement Reclaim (EMA36 crosses EMA69)",
    "{{ticker}} [65m] — SETTLEMENT RECLAIM: Day 6 close node crossed Day 12 midday node — trend resuming bullish.")
