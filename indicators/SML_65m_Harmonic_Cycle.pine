// © ScriptMasterLabs — SML 65m Harmonic Cycle [Licensed]
// ================================================================
// LOAD ON 65-MINUTE CHART ONLY
//
// 390 min/session ÷ 65 min/bar = 6 bars per day (exact, zero remainder)
// This is the only standard timeframe that divides the NYSE session perfectly.
//
// The sequence alternates REVERSAL and SETTLEMENT nodes.
//   Reversal nodes:   fast-twitch reaction nodes at session midpoints
//   Settlement nodes: institutional closing-print nodes
//
// Pair with: SML Sovereign Stack (daily) for macro anchor alignment
//            SML E1 Tactical Matrix for micro-coil overlay
// ================================================================
//@version=5
indicator("SML 65m Harmonic Cycle [Licensed]",
          shorttitle="SML·65H", overlay=true)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
n1_len = input.int(1, "Reversal Node 1",    group="SML Licensed — 65H Sequence", minval=1)
n2_len = input.int(1, "Settlement Node 1",  group="SML Licensed — 65H Sequence", minval=1)
n3_len = input.int(1, "Reversal Node 2",    group="SML Licensed — 65H Sequence", minval=1)
n4_len = input.int(1, "Settlement Node 2",  group="SML Licensed — 65H Sequence", minval=1)
n5_len = input.int(1, "Reversal Node 3",    group="SML Licensed — 65H Sequence", minval=1)

// ═══ INPUTS ═══════════════════════════════════════════════════════
show_reversal   = input.bool(true, "Reversal Nodes",   group="Nodes")
show_settlement = input.bool(true, "Settlement Nodes", group="Nodes")

show_labels = input.bool(true, "Show Signal Label",       group="Display")
show_bands  = input.bool(true, "Show Signal Background",  group="Display")
coil_thresh = input.float(0.8, "Harmonic Coil Width %",   group="Display", minval=0.1, step=0.1)

// ═══ EMAs ═════════════════════════════════════════════════════════
e_n1 = ta.ema(close, n1_len)    // Reversal node 1
e_n2 = ta.ema(close, n2_len)    // Settlement node 1
e_n3 = ta.ema(close, n3_len)    // Reversal node 2
e_n4 = ta.ema(close, n4_len)    // Settlement node 2
e_n5 = ta.ema(close, n5_len)    // Reversal node 3

// ═══ SIGNAL LOGIC ═════════════════════════════════════════════════

// Full 5-node alignment
bull_stack = e_n1 > e_n2 and e_n2 > e_n3 and e_n3 > e_n4 and e_n4 > e_n5
bear_stack = e_n1 < e_n2 and e_n2 < e_n3 and e_n3 < e_n4 and e_n4 < e_n5

// Lock score: count aligned pairs
bull_pairs = (e_n1 > e_n2 ? 1 : 0) + (e_n2 > e_n3 ? 1 : 0) + (e_n3 > e_n4 ? 1 : 0) + (e_n4 > e_n5 ? 1 : 0)
bear_pairs = (e_n1 < e_n2 ? 1 : 0) + (e_n2 < e_n3 ? 1 : 0) + (e_n3 < e_n4 ? 1 : 0) + (e_n4 < e_n5 ? 1 : 0)

// Stretch from slowest reversal anchor (node 5)
stretch_n5 = (close - e_n5) / e_n5 * 100

// Harmonic compression — all 5 nodes collapsing into a coil
spread = math.abs((e_n1 - e_n5) / e_n5 * 100)
harmonic_coil = spread < coil_thresh

// Key crossovers — fast reversal node crossing settlement node
rev_ignition   = ta.crossover( e_n1, e_n2)
rev_breakdown  = ta.crossunder(e_n1, e_n2)
settle_reclaim = ta.crossover( e_n2, e_n3)

// ═══ PLOTS ════════════════════════════════════════════════════════

// Reversal nodes — gold/warm (midday session energy)
plot(show_reversal   ? e_n1 : na, "R · Node 1 (Reversal)",
     color=color.new(#FFD700, 10), linewidth=2)
plot(show_reversal   ? e_n3 : na, "R · Node 3 (Reversal)",
     color=color.new(#FF9900, 10), linewidth=2)
plot(show_reversal   ? e_n5 : na, "R · Node 5 (Reversal)",
     color=color.new(#FF6600,  5), linewidth=3)

// Settlement nodes — blue/institutional (closing bell energy)
plot(show_settlement ? e_n2 : na, "S · Node 2 (Settlement)",
     color=color.new(#0088FF, 10), linewidth=2, style=plot.style_line)
plot(show_settlement ? e_n4 : na, "S · Node 4 (Settlement)",
     color=color.new(#0044CC,  5), linewidth=3, style=plot.style_line)

// ═══ BACKGROUND ═══════════════════════════════════════════════════

bg_color = bull_stack    ? color.new(color.green,  55) :
           bear_stack    ? color.new(color.red,    55) :
           bull_pairs >= 3 ? color.new(color.teal,   80) :
           bear_pairs >= 3 ? color.new(color.orange, 80) :
           harmonic_coil ? color.new(color.blue,   82) : na

bgcolor(show_bands ? bg_color : na, title="SML 65H Signal Background")

// ═══ SIGNAL LABEL ════════════════════════════════════════════════

var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)

    // Node state tags
    n1t = e_n1 > e_n2 ? "N1↑" : "N1↓"
    n2t = e_n2 > e_n3 ? "N2↑" : "N2↓"
    n3t = e_n3 > e_n4 ? "N3↑" : "N3↓"
    n4t = e_n4 > e_n5 ? "N4↑" : "N4↓"
    node_line = n1t + " · " + n2t + " · " + n3t + " · " + n4t

    sig_txt = bull_stack      ? "65H: HARMONIC BULL (5/5)\n+" + str.tostring(stretch_n5, "#.##") + "% above Reversal Anchor\n" + node_line :
              bear_stack      ? "65H: HARMONIC BEAR (5/5)\n"  + str.tostring(stretch_n5, "#.##") + "% below Reversal Anchor\n" + node_line :
              bull_pairs >= 3 ? "65H: PARTIAL BULL (" + str.tostring(bull_pairs) + "/4 pairs)\n" + node_line :
              bear_pairs >= 3 ? "65H: PARTIAL BEAR (" + str.tostring(bear_pairs) + "/4 pairs)\n" + node_line :
              harmonic_coil   ? "65H: HARMONIC COIL\nSpread " + str.tostring(spread, "#.##") + "% — nodes collapsing\n" + node_line :
              "65H: NEUTRAL (" + str.tostring(bull_pairs) + "B / " + str.tostring(bear_pairs) + "Be)\n" + node_line

    lbl_col = bull_stack or bull_pairs >= 3 ? color.green  :
              bear_stack or bear_pairs >= 3 ? color.red    :
              harmonic_coil                 ? color.blue   : color.gray

    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ═══ ALERTS ══════════════════════════════════════════════════════

alertcondition(bull_stack,
    "65H Full Harmonic Bull (5/5 nodes)",
    "{{ticker}} [65m] — HARMONIC BULL: All 5 nodes aligned bullish.")

alertcondition(bear_stack,
    "65H Full Harmonic Bear (5/5 nodes)",
    "{{ticker}} [65m] — HARMONIC BEAR: All 5 nodes aligned bearish.")

alertcondition(rev_ignition,
    "65H Reversal Ignition",
    "{{ticker}} [65m] — REVERSAL IGNITION: Reversal node crossed above settlement node. Bullish harmonic sequence loading.")

alertcondition(rev_breakdown,
    "65H Reversal Breakdown",
    "{{ticker}} [65m] — REVERSAL BREAKDOWN: Reversal node dropped below settlement node. Bearish harmonic sequence loading.")

alertcondition(harmonic_coil,
    "65H Harmonic Coil — All Nodes Compressing",
    "{{ticker}} [65m] — HARMONIC COIL: All 5 nodes compressed within " + str.tostring(coil_thresh, "#.#") + "%. Energy loading before expansion.")

alertcondition(settle_reclaim,
    "65H Settlement Reclaim",
    "{{ticker}} [65m] — SETTLEMENT RECLAIM: Settlement node crossed reversal node — trend resuming bullish.")
