// © ScriptMasterLabs — SML Volume Kinetics
// ================================================================
// VOLUME DIMENSION ONLY — Add as a separate pane beneath price chart
// Tracks institutional accumulation kinetics through volume band
// structure and geometric expansion ratios.
//
// Mirror lock: ignition band and macro baseline trending the same
// direction signals coordinated institutional positioning.
//
// Cross-engine trigger (Lie Detector):
//   When price pane shows SUPPRESSED + this pane shows ceiling breach,
//   dark-pool accumulation is active.
// ================================================================
//@version=5
indicator("SML Volume Kinetics", shorttitle="SML·VolK", overlay=false)

// ── Inputs ───────────────────────────────────────────────────────
show_raw_vol   = input.bool(true,  "Show Raw Volume Bars")
show_labels    = input.bool(true,  "Show Signal Labels")
show_bands     = input.bool(true,  "Show Signal Backgrounds")

// ── VMAs — VOLUME only ────────────────────────────────────────────
vma11  = ta.ema(volume, 11)
vma47  = ta.ema(volume, 47)
vma123 = ta.ema(volume, 123)
vma321 = ta.ema(volume, 321)

// ── Band crossings ────────────────────────────────────────────────
vol_above_11  = volume > vma11
vol_above_47  = volume > vma47
vol_above_123 = volume > vma123
vol_above_321 = volume > vma321

// ── Mirror lock — purely volume-based ────────────────────────────
ignition_up  = vma11 > vma47
macro_up     = vma123 > vma321
mirror_bull  = ignition_up and macro_up
mirror_bear  = not ignition_up and not macro_up

// ── Geometric expansion check ─────────────────────────────────────
phi_sq_ratio  = vma47 / vma11
phi_expanding = phi_sq_ratio > 2.35 and phi_sq_ratio < 2.90

// ── Signals ───────────────────────────────────────────────────────
ceiling_breach    = vol_above_321 and mirror_bull
dark_pool_accum   = vol_above_123 and mirror_bull and not vol_above_321
phi_ignition      = vol_above_47  and phi_expanding and not dark_pool_accum
ignition_active   = vol_above_11  and not phi_ignition and not dark_pool_accum
distribution      = mirror_bear   and vol_above_47

// ── Volume bar color ──────────────────────────────────────────────
vol_color = ceiling_breach  ? color.new(color.purple, 10) :
            dark_pool_accum ? color.new(color.blue,   20) :
            phi_ignition    ? color.new(color.aqua,   20) :
            ignition_active ? color.new(color.teal,   40) :
            distribution    ? color.new(color.red,    30) :
            volume > vma11  ? color.new(color.gray,   50) :
                              color.new(color.gray,   75)

// ── Plots ─────────────────────────────────────────────────────────
plot(show_raw_vol ? volume : na, "Volume",
     style=plot.style_columns, color=vol_color)

plot(vma11,  "Fast Band Low",
     color=color.new(color.aqua,   10), linewidth=1)
plot(vma47,  "Fast Band High",
     color=color.new(color.teal,   5),  linewidth=2)
plot(vma123, "Macro Base",
     color=color.new(color.blue,   5),  linewidth=2)
plot(vma321, "Macro Ceiling",
     color=color.new(color.purple, 5),  linewidth=3)

// ── Signal backgrounds ────────────────────────────────────────────
bgcolor(show_bands and ceiling_breach  ? color.new(color.purple, 75) : na, title="Ceiling Breach")
bgcolor(show_bands and dark_pool_accum ? color.new(color.blue,   82) : na, title="Accumulation")
bgcolor(show_bands and phi_ignition    ? color.new(color.aqua,   85) : na, title="Geometric Ignition")
bgcolor(show_bands and distribution    ? color.new(color.red,    88) : na, title="Distribution")

// ── Ratio display ─────────────────────────────────────────────────
plot(vma47 > 0 ? vma47 / vma11 * vma11 : na, display=display.none)

// ── Labels ────────────────────────────────────────────────────────
var label sig_lbl  = na
var label phi_lbl  = na

if show_labels and barstate.islast
    label.delete(sig_lbl)
    label.delete(phi_lbl)

    sig_txt = ceiling_breach  ? "CEILING BREACH\nVol > Macro Ceiling" :
              dark_pool_accum ? "ACCUMULATION\nVol > Macro Base" :
              phi_ignition    ? "GEOMETRIC IGNITION\nExpansion ratio: " + str.tostring(phi_sq_ratio, "#.###") :
              ignition_active ? "IGNITION BAND\nVol > Fast Low" :
              distribution    ? "DISTRIBUTION\nMirror lock bear" : "NEUTRAL"
    sig_col = ceiling_breach  ? color.purple :
              dark_pool_accum ? color.blue   :
              phi_ignition    ? color.aqua   :
              ignition_active ? color.teal   :
              distribution    ? color.red    : color.gray

    sig_lbl := label.new(bar_index, volume * 1.05,
        text=sig_txt, color=sig_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

    phi_lbl := label.new(bar_index - 5, vma47,
        text="Expansion ratio: " + str.tostring(phi_sq_ratio, "#.###"),
        color=phi_expanding ? color.new(color.aqua, 40) : color.new(color.gray, 60),
        textcolor=color.white, style=label.style_label_left, size=size.small)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(ceiling_breach,
    "Volume Ceiling Breach",
    "{{ticker}} — CEILING BREACH: Volume above macro ceiling with mirror lock active.")

alertcondition(dark_pool_accum,
    "Volume Accumulation",
    "{{ticker}} — ACCUMULATION: Volume above macro base. Baseline engaged.")

alertcondition(phi_ignition,
    "Geometric Ignition",
    "{{ticker}} — GEOMETRIC IGNITION: Expansion ratio = " + str.tostring(phi_sq_ratio, "#.###") + ". Volume geometric expansion active.")

alertcondition(ta.crossover(volume, vma123),
    "Volume Crosses Macro Base",
    "{{ticker}} — Volume crossed above macro base. Watch for full ceiling breach.")

alertcondition(ta.crossover(volume, vma321),
    "Volume Crosses Macro Ceiling",
    "{{ticker}} — Volume crossed above macro ceiling. Maximum institutional kinetics.")
