// © ScriptMasterLabs — SML Sovereign Stack™
// ================================================================
// Four-layer institutional EMA architecture
//
// Layer 1 — Geometric Stack   (3 · 9 · 18 · 36 · 72)
//           Captures fractional momentum expansion in base-4 time
// Layer 2 — Arithmetic Stack  (13 · 26 · 39 · 52 · 65)
//           Classic institutional swing rhythm (13-bar cadence)
// Layer 3 — Annual Anchor     (365)
//           One calendar year of daily bars — primary daily-chart anchor
// Layer 4 — Macro Anchor      (741)
//           Long-cycle macro floor; aligns with Triple Lock Engine
//
// Triple Lock fires when all three stacks + anchors align.
// Use on DAILY timeframe for the 365 anchor to be meaningful.
// On 15m/1h, add SML E1 Tactical Matrix for micro-coil overlay.
//
// Related: SML Triple Lock Engine [Beastmode+] for full signal suite
// ================================================================
//@version=5
indicator("SML Sovereign Stack™", shorttitle="SML·Sovereign", overlay=true)

// ═══ INPUTS ═══════════════════════════════════════════════════════
show_geo  = input.bool(true, "Geometric Stack  (3 · 9 · 18 · 36 · 72)", group="Layers")
show_ari  = input.bool(true, "Arithmetic Stack (13 · 26 · 39 · 52 · 65)", group="Layers")
show_anc  = input.bool(true, "Annual Anchor    (365)",                     group="Layers")
show_mac  = input.bool(true, "Macro Anchor     (741)",                     group="Layers")

show_labels = input.bool(true, "Show Signal Label",      group="Display")
show_bands  = input.bool(true, "Show Signal Background", group="Display")

// ═══ EMAs ═════════════════════════════════════════════════════════

// Layer 1 — Geometric Stack
g1 = ta.ema(close, 3)
g2 = ta.ema(close, 9)
g3 = ta.ema(close, 18)
g4 = ta.ema(close, 36)
g5 = ta.ema(close, 72)

// Layer 2 — Arithmetic Stack
a1 = ta.ema(close, 13)
a2 = ta.ema(close, 26)
a3 = ta.ema(close, 39)
a4 = ta.ema(close, 52)
a5 = ta.ema(close, 65)

// Layer 3 — Annual Anchor (365 daily bars = 1 calendar year)
e365 = ta.ema(close, 365)

// Layer 4 — Macro Anchor
e741 = ta.ema(close, 741)

// ═══ SIGNAL LOGIC ═════════════════════════════════════════════════

// Geometric alignment
geo_bull = g1 > g2 and g2 > g3 and g3 > g4 and g4 > g5
geo_bear = g1 < g2 and g2 < g3 and g3 < g4 and g4 < g5

// Arithmetic alignment
ari_bull = a1 > a2 and a2 > a3 and a3 > a4 and a4 > a5
ari_bear = a1 < a2 and a2 < a3 and a3 < a4 and a4 < a5

// Anchor position
anc365_bull = close > e365
anc365_bear = close < e365
mac741_bull = close > e741
mac741_bear = close < e741

// Lock scores (0–4)
bull_locks = (geo_bull ? 1 : 0) + (ari_bull ? 1 : 0) + (anc365_bull ? 1 : 0) + (mac741_bull ? 1 : 0)
bear_locks = (geo_bear ? 1 : 0) + (ari_bear ? 1 : 0) + (anc365_bear ? 1 : 0) + (mac741_bear ? 1 : 0)

sovereign_bull = bull_locks == 4   // all four layers aligned bullish
sovereign_bear = bear_locks == 4   // all four layers aligned bearish
partial_bull   = bull_locks == 3
partial_bear   = bear_locks == 3

// Stretch from annual anchor (365-bar daily EMA)
stretch_365 = (close - e365) / e365 * 100

// Compression — price coiled within 1% of annual anchor
annual_coil = math.abs(stretch_365) < 1.0

// ═══ PLOTS ════════════════════════════════════════════════════════

// Geometric Stack (warm spectrum)
plot(show_geo ? g1 : na, "G · EMA 3  (Geo Seed)",   color=color.new(#ff9900, 30), linewidth=1)
plot(show_geo ? g2 : na, "G · EMA 9  (Geo Fast)",   color=color.new(#ffbb00, 25), linewidth=1)
plot(show_geo ? g3 : na, "G · EMA 18 (Geo Mid)",    color=color.new(#ffdd00, 20), linewidth=1)
plot(show_geo ? g4 : na, "G · EMA 36 (Geo Slow)",   color=color.new(#aadd00, 15), linewidth=1)
plot(show_geo ? g5 : na, "G · EMA 72 (Geo Anchor)", color=color.new(color.lime, 5), linewidth=2)

// Arithmetic Stack (cool spectrum)
plot(show_ari ? a1 : na, "A · EMA 13 (Ari Seed)",   color=color.new(#00ddff, 30), linewidth=1)
plot(show_ari ? a2 : na, "A · EMA 26 (Ari Fast)",   color=color.new(#00aaff, 25), linewidth=1)
plot(show_ari ? a3 : na, "A · EMA 39 (Ari Mid)",    color=color.new(#0077ff, 20), linewidth=1)
plot(show_ari ? a4 : na, "A · EMA 52 (Ari Slow)",   color=color.new(#0044ff, 15), linewidth=1)
plot(show_ari ? a5 : na, "A · EMA 65 (Ari Cap)",    color=color.new(#0022cc, 5),  linewidth=2)

// Annual Anchor — primary daily-chart reference line
plot(show_anc ? e365 : na, "S · EMA 365 (Annual Anchor)",
     color=color.new(color.yellow, 0), linewidth=3, style=plot.style_line)

// Macro Anchor
plot(show_mac ? e741 : na, "S · EMA 741 (Macro Anchor)",
     color=color.new(color.red, 0), linewidth=3, style=plot.style_line)

// ═══ BACKGROUND ═══════════════════════════════════════════════════

bg_color = sovereign_bull ? color.new(color.green,  55) :
           sovereign_bear ? color.new(color.red,    55) :
           partial_bull   ? color.new(color.teal,   80) :
           partial_bear   ? color.new(color.orange, 80) :
           annual_coil    ? color.new(color.blue,   85) : na

bgcolor(show_bands ? bg_color : na, title="SML Sovereign Background")

// ═══ SIGNAL LABEL ════════════════════════════════════════════════

var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)

    g_tag  = geo_bull  ? "GEO ▲"  : geo_bear  ? "GEO ▼"  : "GEO —"
    a_tag  = ari_bull  ? "ARI ▲"  : ari_bear  ? "ARI ▼"  : "ARI —"
    n_tag  = anc365_bull ? "365 ▲" : anc365_bear ? "365 ▼" : "365 —"
    m_tag  = mac741_bull ? "741 ▲" : mac741_bear ? "741 ▼" : "741 —"
    layers = g_tag + "  |  " + a_tag + "  |  " + n_tag + "  |  " + m_tag

    sig_txt = sovereign_bull ? "SOVEREIGN BULL (" + str.tostring(bull_locks) + "/4 locks)\n" + str.tostring(stretch_365, "#.##") + "% above Annual EMA\n" + layers :
              sovereign_bear ? "SOVEREIGN BEAR (" + str.tostring(bear_locks) + "/4 locks)\n" + str.tostring(stretch_365, "#.##") + "% below Annual EMA\n" + layers :
              partial_bull   ? "PARTIAL BULL ("   + str.tostring(bull_locks) + "/4 locks)\n" + layers :
              partial_bear   ? "PARTIAL BEAR ("   + str.tostring(bear_locks) + "/4 locks)\n" + layers :
              annual_coil    ? "ANNUAL COIL\nPrice within 1% of EMA365\n" + layers :
              "NEUTRAL (" + str.tostring(bull_locks) + "B / " + str.tostring(bear_locks) + "Be)\n" + layers

    lbl_col = sovereign_bull or partial_bull ? color.green  :
              sovereign_bear or partial_bear ? color.red    :
              annual_coil                   ? color.blue   : color.gray

    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ═══ ALERTS ══════════════════════════════════════════════════════

alertcondition(sovereign_bull,
    "Sovereign Stack — Full Bull Lock (4/4)",
    "{{ticker}} — SOVEREIGN BULL: All 4 layers aligned. GEO+ARI stacks bull, price above EMA365 and EMA741.")

alertcondition(sovereign_bear,
    "Sovereign Stack — Full Bear Lock (4/4)",
    "{{ticker}} — SOVEREIGN BEAR: All 4 layers aligned. GEO+ARI stacks bear, price below EMA365 and EMA741.")

alertcondition(annual_coil,
    "Sovereign Stack — Annual Coil (price pinned to EMA365)",
    "{{ticker}} — ANNUAL COIL: Price within 1% of EMA365 annual anchor — coil loading.")

alertcondition(ta.crossover(close, e365),
    "Sovereign Stack — Price Reclaims EMA365 (Annual Anchor)",
    "{{ticker}} — EMA365 RECLAIM: Price crossed above annual EMA — daily structure flipping bullish.")

alertcondition(ta.crossunder(close, e365),
    "Sovereign Stack — Price Loses EMA365 (Annual Anchor)",
    "{{ticker}} — EMA365 LOST: Price crossed below annual EMA — daily structure flipping bearish.")

alertcondition(ta.crossover(close, e741),
    "Sovereign Stack — Price Reclaims EMA741 (Macro Anchor)",
    "{{ticker}} — EMA741 RECLAIM: Price crossed above macro anchor.")
