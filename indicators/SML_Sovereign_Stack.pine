// © ScriptMasterLabs — SML Sovereign Stack™
// ================================================================
// Four-layer institutional EMA architecture
//
// Layer 1 — Geometric Stack   (fast momentum expansion)
// Layer 2 — Arithmetic Stack  (institutional swing rhythm)
// Layer 3 — Annual Anchor     (primary daily-chart anchor)
// Layer 4 — Macro Anchor      (long-cycle macro floor)
//
// Triple Lock fires when all three stacks + anchors align.
// Use on DAILY timeframe for the annual anchor to be meaningful.
// On 15m/1h, add SML E1 Tactical Matrix for micro-coil overlay.
//
// Related: SML Triple Lock Engine [Beastmode+] for full signal suite
// ================================================================
//@version=5
indicator("SML Sovereign Stack™", shorttitle="SML·Sovereign", overlay=true)

// ── Sequence Inputs (SML Licensed) ───────────────────────────────
ig1 = input.int(1, "Geo L1 (Fastest)", group="SML Licensed — Geometric Stack", minval=1)
ig2 = input.int(1, "Geo L2",           group="SML Licensed — Geometric Stack", minval=1)
ig3 = input.int(1, "Geo L3",           group="SML Licensed — Geometric Stack", minval=1)
ig4 = input.int(1, "Geo L4",           group="SML Licensed — Geometric Stack", minval=1)
ig5 = input.int(1, "Geo L5 (Anchor)",  group="SML Licensed — Geometric Stack", minval=1)

ia1 = input.int(1, "Ari L1 (Fastest)", group="SML Licensed — Arithmetic Stack", minval=1)
ia2 = input.int(1, "Ari L2",           group="SML Licensed — Arithmetic Stack", minval=1)
ia3 = input.int(1, "Ari L3",           group="SML Licensed — Arithmetic Stack", minval=1)
ia4 = input.int(1, "Ari L4",           group="SML Licensed — Arithmetic Stack", minval=1)
ia5 = input.int(1, "Ari L5 (Anchor)",  group="SML Licensed — Arithmetic Stack", minval=1)

i_anc = input.int(1, "Annual Anchor", group="SML Licensed — Anchors", minval=1)
i_mac = input.int(1, "Macro Anchor",  group="SML Licensed — Anchors", minval=1)

// ═══ INPUTS ═══════════════════════════════════════════════════════
show_geo  = input.bool(true, "Geometric Stack",  group="Layers")
show_ari  = input.bool(true, "Arithmetic Stack", group="Layers")
show_anc  = input.bool(true, "Annual Anchor",    group="Layers")
show_mac  = input.bool(true, "Macro Anchor",     group="Layers")

show_labels = input.bool(true, "Show Signal Label",      group="Display")
show_bands  = input.bool(true, "Show Signal Background", group="Display")

// ═══ EMAs ═════════════════════════════════════════════════════════

// Layer 1 — Geometric Stack
g1 = ta.ema(close, ig1)
g2 = ta.ema(close, ig2)
g3 = ta.ema(close, ig3)
g4 = ta.ema(close, ig4)
g5 = ta.ema(close, ig5)

// Layer 2 — Arithmetic Stack
a1 = ta.ema(close, ia1)
a2 = ta.ema(close, ia2)
a3 = ta.ema(close, ia3)
a4 = ta.ema(close, ia4)
a5 = ta.ema(close, ia5)

// Layer 3 — Annual Anchor
e_anc = ta.ema(close, i_anc)

// Layer 4 — Macro Anchor
e_mac = ta.ema(close, i_mac)

// ═══ SIGNAL LOGIC ═════════════════════════════════════════════════

// Geometric alignment
geo_bull = g1 > g2 and g2 > g3 and g3 > g4 and g4 > g5
geo_bear = g1 < g2 and g2 < g3 and g3 < g4 and g4 < g5

// Arithmetic alignment
ari_bull = a1 > a2 and a2 > a3 and a3 > a4 and a4 > a5
ari_bear = a1 < a2 and a2 < a3 and a3 < a4 and a4 < a5

// Anchor position
anc_bull = close > e_anc
anc_bear = close < e_anc
mac_bull = close > e_mac
mac_bear = close < e_mac

// Lock scores (0–4)
bull_locks = (geo_bull ? 1 : 0) + (ari_bull ? 1 : 0) + (anc_bull ? 1 : 0) + (mac_bull ? 1 : 0)
bear_locks = (geo_bear ? 1 : 0) + (ari_bear ? 1 : 0) + (anc_bear ? 1 : 0) + (mac_bear ? 1 : 0)

sovereign_bull = bull_locks == 4
sovereign_bear = bear_locks == 4
partial_bull   = bull_locks == 3
partial_bear   = bear_locks == 3

// Stretch from annual anchor
stretch_anc = (close - e_anc) / e_anc * 100

// Compression — price coiled within 1% of annual anchor
annual_coil = math.abs(stretch_anc) < 1.0

// ═══ PLOTS ════════════════════════════════════════════════════════

// Geometric Stack (warm spectrum)
plot(show_geo ? g1 : na, "G · L1 (Geo Seed)",   color=color.new(#ff9900, 30), linewidth=1)
plot(show_geo ? g2 : na, "G · L2 (Geo Fast)",   color=color.new(#ffbb00, 25), linewidth=1)
plot(show_geo ? g3 : na, "G · L3 (Geo Mid)",    color=color.new(#ffdd00, 20), linewidth=1)
plot(show_geo ? g4 : na, "G · L4 (Geo Slow)",   color=color.new(#aadd00, 15), linewidth=1)
plot(show_geo ? g5 : na, "G · L5 (Geo Anchor)", color=color.new(color.lime, 5), linewidth=2)

// Arithmetic Stack (cool spectrum)
plot(show_ari ? a1 : na, "A · L1 (Ari Seed)",   color=color.new(#00ddff, 30), linewidth=1)
plot(show_ari ? a2 : na, "A · L2 (Ari Fast)",   color=color.new(#00aaff, 25), linewidth=1)
plot(show_ari ? a3 : na, "A · L3 (Ari Mid)",    color=color.new(#0077ff, 20), linewidth=1)
plot(show_ari ? a4 : na, "A · L4 (Ari Slow)",   color=color.new(#0044ff, 15), linewidth=1)
plot(show_ari ? a5 : na, "A · L5 (Ari Cap)",    color=color.new(#0022cc, 5),  linewidth=2)

// Annual Anchor — primary daily-chart reference line
plot(show_anc ? e_anc : na, "S · Annual Anchor",
     color=color.new(color.yellow, 0), linewidth=3, style=plot.style_line)

// Macro Anchor
plot(show_mac ? e_mac : na, "S · Macro Anchor",
     color=color.new(color.red, 0), linewidth=3, style=plot.style_line)

// ═══ BACKGROUND ═══════════════════════════════════════════════════

bg_color = sovereign_bull ? color.new(color.green,  55) :
           sovereign_bear ? color.new(color.red,    55) :
           partial_bull   ? color.new(color.teal,   80) :
           partial_bear   ? color.new(color.orange, 80) :
           annual_coil    ? color.new(color.blue,   85) : na

bgcolor(show_bands ? bg_color : na, title="SML Sovereign Background")

// ═══ SIGNAL LABEL ════════════════════════════════════════════════

var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)

    g_tag  = geo_bull  ? "GEO ▲"  : geo_bear  ? "GEO ▼"  : "GEO —"
    a_tag  = ari_bull  ? "ARI ▲"  : ari_bear  ? "ARI ▼"  : "ARI —"
    n_tag  = anc_bull  ? "Anc ▲"  : anc_bear  ? "Anc ▼"  : "Anc —"
    m_tag  = mac_bull  ? "Mac ▲"  : mac_bear  ? "Mac ▼"  : "Mac —"
    layers = g_tag + "  |  " + a_tag + "  |  " + n_tag + "  |  " + m_tag

    sig_txt = sovereign_bull ? "SOVEREIGN BULL (" + str.tostring(bull_locks) + "/4 locks)\n" + str.tostring(stretch_anc, "#.##") + "% above Annual Anchor\n" + layers :
              sovereign_bear ? "SOVEREIGN BEAR (" + str.tostring(bear_locks) + "/4 locks)\n" + str.tostring(stretch_anc, "#.##") + "% below Annual Anchor\n" + layers :
              partial_bull   ? "PARTIAL BULL ("   + str.tostring(bull_locks) + "/4 locks)\n" + layers :
              partial_bear   ? "PARTIAL BEAR ("   + str.tostring(bear_locks) + "/4 locks)\n" + layers :
              annual_coil    ? "ANNUAL COIL\nPrice within 1% of Annual Anchor\n" + layers :
              "NEUTRAL (" + str.tostring(bull_locks) + "B / " + str.tostring(bear_locks) + "Be)\n" + layers

    lbl_col = sovereign_bull or partial_bull ? color.green  :
              sovereign_bear or partial_bear ? color.red    :
              annual_coil                   ? color.blue   : color.gray

    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ═══ ALERTS ══════════════════════════════════════════════════════

alertcondition(sovereign_bull,
    "Sovereign Stack — Full Bull Lock (4/4)",
    "{{ticker}} — SOVEREIGN BULL: All 4 layers aligned. GEO+ARI stacks bull, price above annual and macro anchors.")

alertcondition(sovereign_bear,
    "Sovereign Stack — Full Bear Lock (4/4)",
    "{{ticker}} — SOVEREIGN BEAR: All 4 layers aligned. GEO+ARI stacks bear, price below annual and macro anchors.")

alertcondition(annual_coil,
    "Sovereign Stack — Annual Coil (price pinned to Annual Anchor)",
    "{{ticker}} — ANNUAL COIL: Price within 1% of annual anchor — coil loading.")

alertcondition(ta.crossover(close, e_anc),
    "Sovereign Stack — Price Reclaims Annual Anchor",
    "{{ticker}} — ANNUAL ANCHOR RECLAIM: Price crossed above annual anchor — daily structure flipping bullish.")

alertcondition(ta.crossunder(close, e_anc),
    "Sovereign Stack — Price Loses Annual Anchor",
    "{{ticker}} — ANNUAL ANCHOR LOST: Price crossed below annual anchor — daily structure flipping bearish.")

alertcondition(ta.crossover(close, e_mac),
    "Sovereign Stack — Price Reclaims Macro Anchor",
    "{{ticker}} — MACRO ANCHOR RECLAIM: Price crossed above macro anchor.")
