// © ScriptMasterLabs — SML EMA Suite
// ================================================================
// PRICE PANE ONLY — Macro stretch cascade overlay
//
// Load "SML Volume Kinetics" as a separate volume pane indicator.
//
// Lie Detector trigger: price SUPPRESSED + volume ceiling breach
// firing in the volume pane simultaneously.
// ================================================================
//@version=5
indicator("SML EMA Suite", shorttitle="SML·EMA", overlay=true)

// ── Inputs ────────────────────────────────────────────────────────
show_e1         = input.bool(true,  "Show EMAs",             group="Macro Stretch Cascade")
ignition_thresh = input.float(15.0, "Ignition Stretch %",    group="Macro Stretch Cascade")
stretch_thresh  = input.float(8.0,  "Stretch Alert %",       group="Macro Stretch Cascade")
suppress_thresh = input.float(5.0,  "Suppression Zone %",    group="Macro Stretch Cascade")
show_labels     = input.bool(true,  "Show Signal Labels",    group="Display")
show_bands      = input.bool(true,  "Show Signal Backgrounds", group="Display")

// ── EMAs on price ─────────────────────────────────────────────────
ema24  = ta.ema(close, 24)
ema578 = ta.ema(close, 578)
ema963 = ta.ema(close, 963)

stretch_pct = (close - ema963) / ema963 * 100
bull_stack  = close > ema24 and ema24 > ema578 and ema578 > ema963
bear_stack  = close < ema24 and ema24 < ema578 and ema578 < ema963
suppressed  = not bull_stack and math.abs(stretch_pct) < suppress_thresh
compression = math.abs(stretch_pct) < 1.5

elastic_ignition_bull = math.abs(stretch_pct) > ignition_thresh and bull_stack
elastic_ignition_bear = math.abs(stretch_pct) > ignition_thresh and bear_stack
bull_stretch = math.abs(stretch_pct) > stretch_thresh and bull_stack and not elastic_ignition_bull
bear_stretch = math.abs(stretch_pct) > stretch_thresh and bear_stack and not elastic_ignition_bear

// ── Plots ─────────────────────────────────────────────────────────
plot(show_e1 ? ema24  : na, "Intraday Anchor",
     color=color.new(color.yellow, 15), linewidth=1)
plot(show_e1 ? ema578 : na, "Mid Anchor",
     color=color.new(color.orange, 10), linewidth=2)
plot(show_e1 ? ema963 : na, "Macro Floor",
     color=color.new(color.red,    5),  linewidth=3)

// ── Backgrounds ───────────────────────────────────────────────────
bgcolor(show_bands and elastic_ignition_bull ? color.new(color.green,  75) : na, title="Elastic Ignition Bull")
bgcolor(show_bands and elastic_ignition_bear ? color.new(color.red,    75) : na, title="Elastic Ignition Bear")
bgcolor(show_bands and bull_stretch          ? color.new(color.teal,   88) : na, title="Bull Stretch")
bgcolor(show_bands and bear_stretch          ? color.new(color.orange, 88) : na, title="Bear Stretch")
bgcolor(show_bands and suppressed            ? color.new(color.gray,   90) : na, title="Suppressed — Watch Volume Pane")
bgcolor(show_bands and compression           ? color.new(color.blue,   92) : na, title="Compression")

// ── Signal label ──────────────────────────────────────────────────
var label sig_lbl = na
if show_labels and barstate.islast
    label.delete(sig_lbl)
    sig_txt = elastic_ignition_bull ? "ELASTIC IGNITION BULL\n+" + str.tostring(stretch_pct, "#.##") + "% from macro floor" :
              elastic_ignition_bear ? "ELASTIC IGNITION BEAR\n"  + str.tostring(stretch_pct, "#.##") + "% from macro floor" :
              bull_stretch          ? "BULL STRETCH\n+"           + str.tostring(stretch_pct, "#.##") + "%" :
              bear_stretch          ? "BEAR STRETCH\n"            + str.tostring(stretch_pct, "#.##") + "%" :
              suppressed            ? "SUPPRESSED\nWatch volume pane now" :
              compression           ? "COMPRESSION\nCoil tightening" : "NEUTRAL"
    lbl_col = elastic_ignition_bull ? color.green  :
              elastic_ignition_bear ? color.red     :
              bull_stretch          ? color.teal    :
              bear_stretch          ? color.orange  :
              suppressed            ? color.gray    :
              compression           ? color.blue    : color.gray
    sig_lbl := label.new(bar_index, high * 1.003,
        text=sig_txt, color=lbl_col, textcolor=color.white,
        style=label.style_label_down, size=size.normal)

// ── Alerts ────────────────────────────────────────────────────────
alertcondition(elastic_ignition_bull,
    "Elastic Ignition Bull",
    "{{ticker}} — ELASTIC IGNITION BULL: Price >" + str.tostring(ignition_thresh, "#") + "% above macro floor")

alertcondition(suppressed,
    "Suppression Zone — Monitor Volume",
    "{{ticker}} — SUPPRESSED: Price coiled. Open volume pane for accumulation signal.")

alertcondition(ta.crossover(close, ema578),
    "Price Reclaims Mid Anchor",
    "{{ticker}} — MID ANCHOR RECLAIM: Price crossed above elastic resistance")
