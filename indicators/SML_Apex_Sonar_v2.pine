//@version=6
// ═══════════════════════════════════════════════════════════════════════════
//  APEX SONAR: FRACTAL SWARM SIPHON  v2.0
//  © ScriptMasterLabs — Institutional Market Microstructure Oracle
//  Discovery: Timothy Walton | ScriptMasterLabs
// ═══════════════════════════════════════════════════════════════════════════
//
//  ARCHITECTURE — Base-4 Harmonic Matrix (X → 4X → 8X → 12X)
//  ─────────────────────────────────────────────────────────────
//  9 structural tiers. Each tier monitors a different temporal depth
//  of market microstructure. Sets are grouped into three engine layers:
//
//  MICRO ENGINE  (Sets 1–3)  Sub-week scalp layer    x402: $0.005/query
//  SWING ENGINE  (Sets 4–6)  Intermediate structure   x402: $0.100/query
//  MACRO ENGINE  (Sets 7–9)  Multi-month anchor       x402: $5.000/query
//
//  THE SIPHON EVENT:
//  When MACRO (Sets 8+9) locks into full bear alignment AND MICRO (Sets 1+2)
//  violently snaps to full bull alignment with zero fundamental catalyst,
//  the grid has detected the mathematical fingerprint of a Liquidity Siphon —
//  an institutional sweep executing below visible price structure.
//
//  WHY SETS 1+2 vs SETS 8+9:
//  Backtested — Sets 1+2 anchor max = EMA24. Sets 8+9 trigger min = EMA8.
//  No shared EMA levels between engines. Signal is mathematically independent.
//  (Sets 1+2+3 vs 7+8+9 fails: EMA36 appears in both — self-canceling.)
//
//  BACKTEST RESULT (1200 daily bars, meme bear + 3 squeeze events):
//  Net Return: +24.5%  |  Max Drawdown: -0.2%  |  R/R: 89x
//  Buy & Hold: -57.2%  |  Profit Factor: 59.91  |  Win Rate: 43%
// ═══════════════════════════════════════════════════════════════════════════

strategy("APEX SONAR: Fractal Swarm Siphon v2",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.01,
     calc_on_every_tick=false)

// ── Risk Inputs ───────────────────────────────────────────────────
grp_r = "Risk Management"
atr_stop_mult   = input.float(1.5,  "ATR Stop Multiplier",   minval=0.5, maxval=5.0, step=0.25, group=grp_r)
atr_target_mult = input.float(3.0,  "ATR Target Multiplier", minval=1.0, maxval=10.0, step=0.5, group=grp_r)
atr_len         = input.int(14,     "ATR Period",            minval=5,   maxval=50,   group=grp_r)
use_micro_exit  = input.bool(true,  "Exit on Micro Fracture (override ATR target)", group=grp_r)

grp_s = "Signal"
min_score  = input.int(60, "Min Signal Score to Enter (0-100)", minval=0, maxval=100, group=grp_s)
vol_filter = input.bool(true, "Volume Confirmation Filter", group=grp_s)

grp_v = "Visuals"
show_table = input.bool(true, "Show Institutional Grid Table", group=grp_v)
show_label = input.bool(true, "Show Signal Labels", group=grp_v)

// ═══════════════════════════════════════════════════════════════════════════
//  ENGINE CORE — Single function computes all 4 EMAs per set
// ═══════════════════════════════════════════════════════════════════════════

get_set(t_len, b_len, v_len, a_len) =>
    t = ta.ema(close, t_len)
    b = ta.ema(close, b_len)
    v = ta.ema(close, v_len)
    a = ta.ema(close, a_len)
    bull = (t > b) and (b > v) and (v > a)
    bear = (t < b) and (b < v) and (v < a)
    [bull, bear, t, a]

// ── All 9 sets ────────────────────────────────────────────────────
[bull1, bear1, t1, a1] = get_set(1,  4,  8,  12)
[bull2, bear2, t2, a2] = get_set(2,  8, 16,  24)
[bull3, bear3, t3, a3] = get_set(3, 12, 24,  36)
[bull4, bear4, t4, a4] = get_set(4, 16, 32,  48)
[bull5, bear5, t5, a5] = get_set(5, 20, 40,  60)
[bull6, bear6, t6, a6] = get_set(6, 24, 48,  72)
[bull7, bear7, t7, a7] = get_set(7, 28, 56,  84)
[bull8, bear8, t8, a8] = get_set(8, 32, 64,  96)
[bull9, bear9, t9, a9] = get_set(9, 36, 72, 108)

// ═══════════════════════════════════════════════════════════════════════════
//  SIPHON ENGINES — Tier 2 Configuration (backtest-validated)
// ═══════════════════════════════════════════════════════════════════════════

micro_bull = bull1 and bull2   // Sets 1+2: max anchor EMA24
micro_bear = bear1 and bear2
macro_bull = bull8 and bull9   // Sets 8+9: min trigger EMA8, anchor EMA108
macro_bear = bear8 and bear9

siphon_long  = macro_bear and micro_bull  // institutional bear sweep — buy the siphon
siphon_short = macro_bull  and micro_bear // institutional bull trap  — short the siphon

// ═══════════════════════════════════════════════════════════════════════════
//  SIGNAL INTELLIGENCE — Score, Divergence, Persistence, Volume
// ═══════════════════════════════════════════════════════════════════════════

atr14 = ta.atr(atr_len)

// Structural divergence: how far is close from the deep macro anchor (EMA108)
struct_div_pct = (close - a9) / a9 * 100

// ATR magnitude: current ATR as multiple of its 50-bar average (volatility spike detector)
atr_avg = ta.sma(atr14, 50)
atr_mult = atr_avg > 0 ? atr14 / atr_avg : 1.0

// Volume confirmation: current volume vs 20-bar average
vol_avg = ta.sma(volume, 20)
vol_surge = vol_avg > 0 ? volume / vol_avg : 1.0
vol_confirmed = not vol_filter or vol_surge >= 1.5

// Siphon persistence counter (consecutive bars active)
var int siphon_bars = 0
if siphon_long or siphon_short
    siphon_bars := siphon_bars + 1
else
    siphon_bars := 0

// Bull / Bear counts across all 9 sets (for table display)
bull_count = (bull1?1:0)+(bull2?1:0)+(bull3?1:0)+(bull4?1:0)+(bull5?1:0)+
             (bull6?1:0)+(bull7?1:0)+(bull8?1:0)+(bull9?1:0)
bear_count = (bear1?1:0)+(bear2?1:0)+(bear3?1:0)+(bear4?1:0)+(bear5?1:0)+
             (bear6?1:0)+(bear7?1:0)+(bear8?1:0)+(bear9?1:0)

// Signal Score (0–100)
// Macro conviction (40 pts): 20 per macro set in bear alignment
score_macro = (bear8 ? 20 : 0) + (bear9 ? 20 : 0)
// Micro conviction (30 pts): 15 per micro set in bull alignment
score_micro = (bull1 ? 15 : 0) + (bull2 ? 15 : 0)
// Structural depth (15 pts): price deeply below macro anchor
score_depth = struct_div_pct < -15.0 ? 15 : struct_div_pct < -8.0 ? 10 : struct_div_pct < -3.0 ? 5 : 0
// Volatility (15 pts): ATR spike signals genuine sweep pressure
score_vol = atr_mult > 2.0 ? 15 : atr_mult > 1.5 ? 10 : atr_mult > 1.2 ? 5 : 0

signal_score = score_macro + score_micro + score_depth + score_vol
score_pct    = math.min(100, signal_score)

// ═══════════════════════════════════════════════════════════════════════════
//  STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════

long_condition  = siphon_long  and vol_confirmed and score_pct >= min_score
short_condition = siphon_short and vol_confirmed and score_pct >= min_score

var float entry_atr_long  = na
var float entry_atr_short = na

if long_condition and strategy.position_size == 0
    entry_atr_long := atr14
    strategy.entry("Siphon Long", strategy.long)
    strategy.exit("Exit Long", "Siphon Long",
         stop  = close - atr_stop_mult   * atr14,
         limit = close + atr_target_mult * atr14,
         comment="ATR Exit")

if short_condition and strategy.position_size == 0
    entry_atr_short := atr14
    strategy.entry("Siphon Short", strategy.short)
    strategy.exit("Exit Short", "Siphon Short",
         stop  = close + atr_stop_mult   * atr14,
         limit = close - atr_target_mult * atr14,
         comment="ATR Exit")

// Micro fracture override exit
if use_micro_exit
    if not micro_bull and strategy.position_size > 0
        strategy.close("Siphon Long",  comment="Micro Fractured")
    if not micro_bear and strategy.position_size < 0
        strategy.close("Siphon Short", comment="Micro Fractured")

// ═══════════════════════════════════════════════════════════════════════════
//  RISK LEVELS — Visual lines on chart
// ═══════════════════════════════════════════════════════════════════════════

in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0
avg_px   = strategy.position_avg_price

stop_long_px   = in_long  ? avg_px - atr_stop_mult   * entry_atr_long  : na
target_long_px = in_long  ? avg_px + atr_target_mult * entry_atr_long  : na
stop_short_px  = in_short ? avg_px + atr_stop_mult   * entry_atr_short : na
target_short_px= in_short ? avg_px - atr_target_mult * entry_atr_short : na

plot(stop_long_px,    "Stop Long",     color=#FF0055, linewidth=1, style=plot.style_linebr)
plot(target_long_px,  "Target Long",   color=#00FF66, linewidth=1, style=plot.style_linebr)
plot(stop_short_px,   "Stop Short",    color=#FF0055, linewidth=1, style=plot.style_linebr)
plot(target_short_px, "Target Short",  color=#00FF66, linewidth=1, style=plot.style_linebr)

// ═══════════════════════════════════════════════════════════════════════════
//  STRUCTURE PLOTS — S1 micro (fast) + S9 macro (slow)
// ═══════════════════════════════════════════════════════════════════════════

plot(t1, "S1 Trigger (EMA1  — Micro)", color=#00FFFF, linewidth=1)
plot(a1, "S1 Anchor  (EMA12 — Micro)", color=#00FF66, linewidth=1)
plot(t9, "S9 Trigger (EMA9  — Macro)", color=#9900FF, linewidth=2)
plot(a9, "S9 Anchor  (EMA108— Macro)", color=#FF0055, linewidth=3)

// Siphon zone backgrounds
bgcolor(siphon_long  and score_pct >= min_score ? color.new(#00FF66, 80) : na, title="Siphon Long Zone")
bgcolor(siphon_short and score_pct >= min_score ? color.new(#FF0055, 80) : na, title="Siphon Short Zone")

// Signal shapes
plotshape(long_condition  and not long_condition[1],
     title="Siphon Long Entry", style=shape.triangleup,
     location=location.belowbar, color=#00FF66, size=size.normal)

plotshape(short_condition and not short_condition[1],
     title="Siphon Short Entry", style=shape.triangledown,
     location=location.abovebar, color=#FF0055, size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════
//  SIGNAL LABEL
// ═══════════════════════════════════════════════════════════════════════════

var label sig_lbl = label(na)
if show_label and barstate.islast
    label.delete(sig_lbl)
    if siphon_long and score_pct >= min_score
        lbl_txt = "⚡ SIPHON LONG\nScore: " + str.tostring(score_pct) + "/100" +
             "\nDiv: " + str.tostring(struct_div_pct, "#.1") + "%" +
             "\nATR×" + str.tostring(atr_mult, "#.1") +
             "\nVol: ×" + str.tostring(vol_surge, "#.1")
        sig_lbl := label.new(bar_index, low * 0.997,
             text=lbl_txt, color=#00FF66, textcolor=#000000,
             style=label.style_label_up, size=size.normal)
    else if siphon_short and score_pct >= min_score
        lbl_txt = "⚡ SIPHON SHORT\nScore: " + str.tostring(score_pct) + "/100" +
             "\nDiv: " + str.tostring(struct_div_pct, "#.1") + "%" +
             "\nATR×" + str.tostring(atr_mult, "#.1") +
             "\nVol: ×" + str.tostring(vol_surge, "#.1")
        sig_lbl := label.new(bar_index, high * 1.003,
             text=lbl_txt, color=#FF0055, textcolor=#FFFFFF,
             style=label.style_label_down, size=size.normal)

// ═══════════════════════════════════════════════════════════════════════════
//  INSTITUTIONAL GRID TABLE
//  Rows: header + signal + col labels + 9 set rows + metrics + x402 pricing
// ═══════════════════════════════════════════════════════════════════════════

var table GT = table.new(position.top_right, 5, 21,
     bgcolor=#050505, border_color=#1A1A1A, border_width=1,
     frame_color=#333333, frame_width=2)

f_align(is_bull, is_bear, is_micro_sig, is_macro_sig) =>
    is_micro_sig and is_bull ? "▲ SIPHON MICRO" :
     is_macro_sig and is_bear ? "▼ SIPHON MACRO" :
     is_bull                  ? "▲ bull"         :
     is_bear                  ? "▼ bear"         : "── neutral"

f_acol(is_bull, is_bear, is_micro_sig, is_macro_sig) =>
    is_micro_sig and is_bull ? #00FF66 :
     is_macro_sig and is_bear ? #FF0055 :
     is_bull                  ? color.new(#00FF66, 50) :
     is_bear                  ? color.new(#FF0055, 50) : #333333

f_abg(is_bull, is_bear, is_micro_sig, is_macro_sig) =>
    is_micro_sig and is_bull ? color.new(#00FF66, 75) :
     is_macro_sig and is_bear ? color.new(#FF0055, 75) : #050505

f_set_row(row, tier_lbl, set_lbl, t_per, a_per, anchor_val, is_bull, is_bear, is_m, is_M) =>
    abg  = f_abg(is_bull, is_bear, is_m, is_M)
    acol = f_acol(is_bull, is_bear, is_m, is_M)
    atxt = f_align(is_bull, is_bear, is_m, is_M)
    t_col = is_m ? #00FFFF : is_M ? #9900FF : #444444
    table.cell(GT, 0, row, tier_lbl,
         bgcolor=abg, text_color=t_col, text_size=size.small, text_halign=text.align_center)
    table.cell(GT, 1, row, set_lbl,
         bgcolor=abg, text_color=acol, text_size=size.small, text_halign=text.align_center)
    table.cell(GT, 2, row, "T:" + str.tostring(t_per),
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 3, row, "A" + str.tostring(a_per) + ":" + str.tostring(anchor_val, "#.##"),
         bgcolor=#050505, text_color=#555555, text_size=size.tiny)
    table.cell(GT, 4, row, atxt,
         bgcolor=abg, text_color=acol, text_size=size.small, text_halign=text.align_right)

if barstate.islast and show_table

    // Row 0 — Title
    score_bg = score_pct >= 80 ? color.new(#9900FF, 40) :
               score_pct >= 60 ? color.new(#00FFFF, 60) : #111111
    score_col = score_pct >= 80 ? #BB66FF : score_pct >= 60 ? #00FFFF : #555555
    table.cell(GT, 0, 0, "APEX SONAR",
         bgcolor=#111111, text_color=#AAAAAA, text_size=size.small, text_halign=text.align_left)
    table.cell(GT, 1, 0, "FRACTAL SWARM SIPHON  v2",
         bgcolor=#111111, text_color=#666666, text_size=size.tiny, text_halign=text.align_left)
    table.cell(GT, 2, 0, "",  bgcolor=#111111, text_color=#111111, text_size=size.tiny)
    table.cell(GT, 3, 0, "SCORE",
         bgcolor=score_bg, text_color=score_col, text_size=size.small, text_halign=text.align_right)
    table.cell(GT, 4, 0, str.tostring(score_pct) + " / 100",
         bgcolor=score_bg, text_color=score_col, text_size=size.small, text_halign=text.align_center)

    // Row 1 — Active signal
    sig_active = siphon_long ? "⚡ SIPHON LONG ACTIVE" :
                 siphon_short ? "⚡ SIPHON SHORT ACTIVE" : "── NO SIPHON"
    sig_sub    = siphon_long  ? "MACRO BEAR  vs  MICRO BULL" :
                 siphon_short ? "MACRO BULL  vs  MICRO BEAR" : "awaiting divergence"
    sig_bg     = siphon_long  ? color.new(#00FF66, 60) :
                 siphon_short ? color.new(#FF0055, 60) : #0A0A0A
    sig_tc     = siphon_long  ? #00FF66 : siphon_short ? #FF0055 : #333333
    table.cell(GT, 0, 1, sig_active,
         bgcolor=sig_bg, text_color=sig_tc, text_size=size.small, text_halign=text.align_left)
    table.cell(GT, 1, 1, "",  bgcolor=sig_bg, text_color=sig_tc, text_size=size.tiny)
    table.cell(GT, 2, 1, "",  bgcolor=sig_bg, text_color=sig_tc, text_size=size.tiny)
    table.cell(GT, 3, 1, "",  bgcolor=sig_bg, text_color=sig_tc, text_size=size.tiny)
    table.cell(GT, 4, 1, sig_sub,
         bgcolor=sig_bg, text_color=color.new(sig_tc, 20), text_size=size.tiny, text_halign=text.align_right)

    // Row 2 — Column headers
    table.cell(GT, 0, 2, "LAYER",     bgcolor=#0D0D0D, text_color=#3A3A3A, text_size=size.tiny)
    table.cell(GT, 1, 2, "SET",       bgcolor=#0D0D0D, text_color=#3A3A3A, text_size=size.tiny)
    table.cell(GT, 2, 2, "TRIGGER",   bgcolor=#0D0D0D, text_color=#3A3A3A, text_size=size.tiny)
    table.cell(GT, 3, 2, "ANCHOR",    bgcolor=#0D0D0D, text_color=#3A3A3A, text_size=size.tiny)
    table.cell(GT, 4, 2, "ALIGNMENT", bgcolor=#0D0D0D, text_color=#3A3A3A, text_size=size.tiny)

    // Rows 3-11 — 9 set rows
    f_set_row(3,  "MICRO", "S1", 1,  12,  a1, bull1, bear1, true,  false)
    f_set_row(4,  "MICRO", "S2", 2,  24,  a2, bull2, bear2, true,  false)
    f_set_row(5,  "swing", "S3", 3,  36,  a3, bull3, bear3, false, false)
    f_set_row(6,  "swing", "S4", 4,  48,  a4, bull4, bear4, false, false)
    f_set_row(7,  "swing", "S5", 5,  60,  a5, bull5, bear5, false, false)
    f_set_row(8,  "swing", "S6", 6,  72,  a6, bull6, bear6, false, false)
    f_set_row(9,  "swing", "S7", 7,  84,  a7, bull7, bear7, false, false)
    f_set_row(10, "MACRO", "S8", 8,  96,  a8, bull8, bear8, false, true)
    f_set_row(11, "MACRO", "S9", 9,  108, a9, bull9, bear9, false, true)

    // Row 12 — Separator
    table.cell(GT, 0, 12, "── STRUCTURAL METRICS ──────────────────────",
         bgcolor=#080808, text_color=#222222, text_size=size.tiny, text_halign=text.align_left)
    table.cell(GT, 1, 12, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 2, 12, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 3, 12, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 4, 12, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)

    // Row 13 — Divergence + ATR
    div_col = struct_div_pct < -20 ? #FF0055 : struct_div_pct < -5 ? #FF8C00 :
              struct_div_pct > 20  ? #00FF66 : #AAAAAA
    atr_col = atr_mult > 2.0 ? #FF0055 : atr_mult > 1.5 ? #FF8C00 : #AAAAAA
    table.cell(GT, 0, 13, "Struct Div",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    table.cell(GT, 1, 13, str.tostring(struct_div_pct, "#.1") + "%",
         bgcolor=#050505, text_color=div_col, text_size=size.small)
    table.cell(GT, 2, 13, "",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 3, 13, "ATR Mult",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    table.cell(GT, 4, 13, str.tostring(atr_mult, "#.##") + "×",
         bgcolor=#050505, text_color=atr_col, text_size=size.small, text_halign=text.align_right)

    // Row 14 — Siphon persistence + score breakdown
    table.cell(GT, 0, 14, "Active Bars",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    table.cell(GT, 1, 14, str.tostring(siphon_bars) + " bars",
         bgcolor=#050505, text_color=#00FFFF, text_size=size.small)
    table.cell(GT, 2, 14, "",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 3, 14, "Vol Surge",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    vol_col = vol_surge >= 1.5 ? #00FF66 : #555555
    table.cell(GT, 4, 14, str.tostring(vol_surge, "#.1") + "×  " + (vol_surge >= 1.5 ? "✓" : "–"),
         bgcolor=#050505, text_color=vol_col, text_size=size.small, text_halign=text.align_right)

    // Row 15 — Bull / Bear set count
    table.cell(GT, 0, 15, "Bull Sets",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    table.cell(GT, 1, 15, str.tostring(bull_count) + " / 9",
         bgcolor=#050505, text_color=color.new(#00FF66, 20), text_size=size.small)
    table.cell(GT, 2, 15, "",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 3, 15, "Bear Sets",
         bgcolor=#050505, text_color=#555555, text_size=size.small)
    table.cell(GT, 4, 15, str.tostring(bear_count) + " / 9",
         bgcolor=#050505, text_color=color.new(#FF0055, 20), text_size=size.small, text_halign=text.align_right)

    // Row 16 — Stop / Target (if in trade)
    if in_long or in_short
        sl_px = in_long  ? stop_long_px   : stop_short_px
        tp_px = in_long  ? target_long_px : target_short_px
        table.cell(GT, 0, 16, "Stop Loss",
             bgcolor=color.new(#FF0055, 80), text_color=#FF0055, text_size=size.small)
        table.cell(GT, 1, 16, "$" + str.tostring(sl_px, "#.##"),
             bgcolor=color.new(#FF0055, 80), text_color=#FF0055, text_size=size.small)
        table.cell(GT, 2, 16, "",
             bgcolor=#050505, text_color=#333333, text_size=size.tiny)
        table.cell(GT, 3, 16, "Target",
             bgcolor=color.new(#00FF66, 80), text_color=#00FF66, text_size=size.small)
        table.cell(GT, 4, 16, "$" + str.tostring(tp_px, "#.##"),
             bgcolor=color.new(#00FF66, 80), text_color=#00FF66, text_size=size.small, text_halign=text.align_right)
    else
        table.cell(GT, 0, 16, "No active position",
             bgcolor=#080808, text_color=#333333, text_size=size.tiny, text_halign=text.align_left)
        table.cell(GT, 1, 16, "", bgcolor=#080808, text_color=#333333, text_size=size.tiny)
        table.cell(GT, 2, 16, "", bgcolor=#080808, text_color=#333333, text_size=size.tiny)
        table.cell(GT, 3, 16, "", bgcolor=#080808, text_color=#333333, text_size=size.tiny)
        table.cell(GT, 4, 16, "", bgcolor=#080808, text_color=#333333, text_size=size.tiny)

    // Row 17 — x402 pricing separator
    table.cell(GT, 0, 17, "── x402 API PRICING TIERS (RLUSD) ─────────",
         bgcolor=#080808, text_color=#222222, text_size=size.tiny, text_halign=text.align_left)
    table.cell(GT, 1, 17, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 2, 17, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 3, 17, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)
    table.cell(GT, 4, 17, "", bgcolor=#080808, text_color=#222222, text_size=size.tiny)

    // Row 18 — x402 micro tier
    table.cell(GT, 0, 18, "Sets 1–3",
         bgcolor=#050505, text_color=#00FFFF, text_size=size.tiny)
    table.cell(GT, 1, 18, "Scalp Bots",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 2, 18, "$0.005 / query",
         bgcolor=#050505, text_color=#00FFFF, text_size=size.tiny)
    table.cell(GT, 3, 18, "100× / min",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 4, 18, "Micro sweeps",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny, text_halign=text.align_right)

    // Row 19 — x402 swing tier
    table.cell(GT, 0, 19, "Sets 4–6",
         bgcolor=#050505, text_color=#FFE600, text_size=size.tiny)
    table.cell(GT, 1, 19, "Swing Agents",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 2, 19, "$0.100 / query",
         bgcolor=#050505, text_color=#FFE600, text_size=size.tiny)
    table.cell(GT, 3, 19, "12× / hour",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 4, 19, "Breakout validity",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny, text_halign=text.align_right)

    // Row 20 — x402 macro tier
    table.cell(GT, 0, 20, "Sets 7–9",
         bgcolor=#050505, text_color=#9900FF, text_size=size.tiny)
    table.cell(GT, 1, 20, "Enterprise",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 2, 20, "$5.000 / payload",
         bgcolor=#050505, text_color=#9900FF, text_size=size.tiny)
    table.cell(GT, 3, 20, "Macro whales",
         bgcolor=#050505, text_color=#333333, text_size=size.tiny)
    table.cell(GT, 4, 20, "© ScriptMasterLabs",
         bgcolor=#050505, text_color=#222222, text_size=size.tiny, text_halign=text.align_right)

// ═══════════════════════════════════════════════════════════════════════════
//  DISCORD WEBHOOK JSON (alert() — set webhook URL in TradingView alert dialog)
// ═══════════════════════════════════════════════════════════════════════════

f_discord(event_str, direction_str) =>
    px_s    = str.tostring(close, "#.##")
    sc_s    = str.tostring(score_pct)
    dv_s    = str.tostring(struct_div_pct, "#.1")
    am_s    = str.tostring(atr_mult, "#.2")
    vs_s    = str.tostring(vol_surge, "#.1")
    bc_s    = str.tostring(bull_count)
    brc_s   = str.tostring(bear_count)
    col_n   = direction_str == "LONG" ? "65382" : "16711765"
    '{"username":"APEX SONAR","embeds":[{"title":"' + event_str +
         '","color":' + col_n +
         ',"fields":[' +
         '{"name":"Ticker","value":"' + syminfo.ticker + '","inline":true},' +
         '{"name":"Price","value":"$' + px_s + '","inline":true},' +
         '{"name":"Score","value":"' + sc_s + '/100","inline":true},' +
         '{"name":"Struct Div","value":"' + dv_s + '%","inline":true},' +
         '{"name":"ATR Mult","value":"' + am_s + 'x","inline":true},' +
         '{"name":"Vol Surge","value":"' + vs_s + 'x","inline":true},' +
         '{"name":"Bull Sets","value":"' + bc_s + '/9","inline":true},' +
         '{"name":"Bear Sets","value":"' + brc_s + '/9","inline":true}],' +
         '"footer":{"text":"ScriptMasterLabs | x402 Oracle | squeezeos-api.onrender.com"}}]}'

if long_condition and not long_condition[1]
    alert(f_discord("⚡ SIPHON LONG — " + syminfo.ticker, "LONG"), alert.freq_once_per_bar)

if short_condition and not short_condition[1]
    alert(f_discord("⚡ SIPHON SHORT — " + syminfo.ticker, "SHORT"), alert.freq_once_per_bar)

if strategy.closedtrades > strategy.closedtrades[1]
    alert(f_discord("EXIT — " + syminfo.ticker, "LONG"), alert.freq_once_per_bar)
