// Basic alertcondition (const string messages)
alertcondition(buySignal, title="SML WRB Buy Signal", message="SML War Room Beast: Buy signal triggered")
alertcondition(sellSignal, title="SML WRB Sell Signal", message="SML War Room Beast: Sell signal triggered")
alertcondition(buyConf, title="SML WRB High Conf Buy", message="SML War Room Beast: High confluence buy signal")
alertcondition(sellConf, title="SML WRB High Conf Sell", message="SML War Room Beast: High confluence sell signal")
alertcondition(bullTrap, title="SML WRB Bull Trap", message="SML War Room Beast: Bull trap detected")
alertcondition(bearTrap, title="SML WRB Bear Trap", message="SML War Room Beast: Bear trap detected")
alertcondition(sqzOn, title="SML WRB Squeeze On", message="SML War Room Beast: Squeeze compression active")
alertcondition(sqzOff, title="SML WRB Squeeze Release", message="SML War Room Beast: Squeeze released")
alertcondition(bullDivFlag, title="SML WRB Bull Divergence", message="SML War Room Beast: Bullish RSI divergence")
alertcondition(bearDivFlag, title="SML WRB Bear Divergence", message="SML War Room Beast: Bearish RSI divergence")
alertcondition(liqSweepHi, title="SML WRB Upper Sweep", message="SML War Room Beast: Upper liquidity sweep")
alertcondition(liqSweepLo, title="SML WRB Lower Sweep", message="SML War Room Beast: Lower liquidity sweep")

// Rich JSON alerts for Discord webhooks
if alertsOn and buySignal
    alert('{"indicator":"SML War Room Beast","signal":"BUY","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","bias":"' + bias + '","grade":"' + grade + '","conf":' + str.tostring(confidence, "#.0") + ',"edge":' + str.tostring(edgeScore, "#.0") + ',"rvol":' + str.tostring(rv, "#.00") + ',"structure":"' + structState + '","accel":"' + accelState + '","price":' + str.tostring(close) + ',"trigger":' + str.tostring(longTrig) + ',"t1":' + str.tostring(lT1) + ',"t2":' + str.tostring(lT2) + ',"t3":' + str.tostring(lT3) + ',"quality":"' + buySigQ + '"}', alert.freq_once_per_bar)

if alertsOn and sellSignal
    alert('{"indicator":"SML War Room Beast","signal":"SELL","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","bias":"' + bias + '","grade":"' + grade + '","conf":' + str.tostring(confidence, "#.0") + ',"edge":' + str.tostring(edgeScore, "#.0") + ',"rvol":' + str.tostring(rv, "#.00") + ',"structure":"' + structState + '","accel":"' + accelState + '","price":' + str.tostring(close) + ',"trigger":' + str.tostring(shortTrig) + ',"t1":' + str.tostring(sT1) + ',"t2":' + str.tostring(sT2) + ',"t3":' + str.tostring(sT3) + ',"quality":"' + sellSigQ + '"}', alert.freq_once_per_bar)

if alertsOn and bullTrap
    alert('{"indicator":"SML War Room Beast","signal":"BULL_TRAP","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar)

if alertsOn and bearTrap
    alert('{"indicator":"SML War Room Beast","signal":"BEAR_TRAP","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar)

if alertsOn and bullDivFlag
    alert('{"indicator":"SML War Room Beast","signal":"BULL_DIVERGENCE","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","rsi":' + str.tostring(rsiVal, "#.0") + ',"price":' + str.tostring(close) + '}', alert.freq_once_per_bar)

if alertsOn and bearDivFlag
    alert('{"indicator":"SML War Room Beast","signal":"BEAR_DIVERGENCE","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","rsi":' + str.tostring(rsiVal, "#.0") + ',"price":' + str.tostring(close) + '}', alert.freq_once_per_bar)

if alertsOn and liqSweepHi
    alert('{"indicator":"SML War Room Beast","signal":"UPPER_SWEEP","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar)

if alertsOn and liqSweepLo
    alert('{"indicator":"SML War Room Beast","signal":"LOWER_SWEEP","ticker":"' + syminfo.tickerid + '","tf":"' + timeframe.period + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar)
