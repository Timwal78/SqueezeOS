# Relay API — Environment Configuration
# Copy to .env and fill in values

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://relay:password@localhost:5432/relay_db

# ─── XRPL ──────────────────────────────────────────────────────────────────
XRPL_NETWORK=xrpl_testnet
# Override node if needed (defaults to xrplcluster.com for mainnet, altnet for testnet)
# XRPL_NODE=wss://xrplcluster.com

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ─── Relay Fee Address (receives optional 0.5% split, self-custody) ─────────
# This is the ONLY private key ever touched by Relay infrastructure.
# Used only for receiving pre-signed fee splits — never for fund control.
RELAY_FEE_ADDRESS=

# ─── Redis (optional — for rate limiting and session caching) ───────────────
# REDIS_URL=redis://localhost:6379

# ─── IPFS (for evidence storage) ────────────────────────────────────────────
# IPFS_PROVIDER=pinata          # pinata | local
# PINATA_API_KEY=
# PINATA_SECRET_KEY=
# IPFS_GATEWAY_URL=https://ipfs.io/ipfs
# IPFS_LOCAL_NODE_URL=http://localhost:5001

# ─── VRF (evaluator selection randomness) ───────────────────────────────────
# In production: Chainlink VRF or XRPL oracle
# VRF_ENDPOINT=
