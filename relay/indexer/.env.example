# Relay Indexer — Environment Configuration
# Copy to .env and fill in values

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://relay:password@localhost:5432/relay_db

# ─── XRPL ──────────────────────────────────────────────────────────────────
XRPL_NETWORK=xrpl_testnet
# Override node if needed
# XRPL_NODE=wss://xrplcluster.com

# ─── Indexer ───────────────────────────────────────────────────────────────
# Ledger index to replay from on startup (set to 0 to replay from genesis,
# leave unset to skip replay and only process live transactions)
# INDEXER_REPLAY_FROM=40000000

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
