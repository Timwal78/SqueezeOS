# ============================================================
# SQUEEZE OS — API Configuration
# Copy this file to .env and fill in your keys.
# Provider priority: Tradier → Alpaca → Polygon → Alpha Vantage
# ============================================================

# ============================================================
# TRADIER — preferred market data + options chain provider
# Sign up: https://developer.tradier.com/
# Sandbox: 15-min delayed data, $100K paper account
# Production: real-time, requires Tradier brokerage account
# ============================================================
TRADIER_API_KEY=
TRADIER_ENV=sandbox
# TRADIER_BASE_URL=                        # optional, auto-resolved from TRADIER_ENV

# Sandbox account (for paper trading via Tradier sandbox)
# TRADIER_SANDBOX_ACCOUNT=

# Production keys — required ONLY if TRADIER_LIVE=true (live CEO Trader)
# TRADIER_PRODUCTION_API_KEY=
# TRADIER_PRODUCTION_ACCOUNT=

# ============================================================
# FALLBACK DATA PROVIDERS
# ============================================================
# POLYGON.IO — Free tier: 5 calls/min — https://polygon.io/
POLYGON_API_KEY=

# ALPACA — Free tier: real-time IEX data — https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=
# ALPACA_PAPER=true                        # true = paper trading endpoint

# ALPHA VANTAGE — Free tier: 25 calls/day — https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=

# FRED — Federal Reserve Economic Data, free — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ============================================================
# DISCORD WEBHOOKS — Get alerts in your Discord channel
# Create webhooks: Server Settings → Integrations → Webhooks
# ============================================================
DISCORD_WEBHOOK_ALL=
# Per-channel overrides (optional)
# DISCORD_WEBHOOK_SQUEEZE=
# DISCORD_WEBHOOK_FLOW=
# DISCORD_WEBHOOK_PAYMENTS=
# DISCORD_WEBHOOK_BEAST=
# DISCORD_WEBHOOK_MMLE=
# DISCORD_WEBHOOK_COUNCIL=

# Alert tuning (defaults: 40 / 15 / True)
# DISCORD_ALERT_MIN_SCORE=40
# DISCORD_FLOW_MIN_SCORE=15
# DISCORD_TRUST_ENV=True                   # set False if behind a corp proxy

# ============================================================
# PAYMENT INFRASTRUCTURE — 402Proof + XRPL
# ============================================================
# 402Proof server (payment firewall for premium /api/* endpoints)
PROOF402_SERVER_URL=https://four02proof.onrender.com

# HMAC-SHA256 secret shared with 402Proof — MUST match TOKEN_SECRET on the
# 402Proof server. Rotate with `openssl rand -hex 32` and apply the SAME value
# on both services. NEVER commit the real secret.
PROOF402_TOKEN_SECRET=

# Self-referencing base URL used by MCP proxy
SQUEEZEOS_BASE_URL=https://squeezeos-api.onrender.com

# 741 Pure Macro Matrix — all three set in Render, never committed to source
MACRO_STACK_CSV=          # proprietary EMA period sequence (comma-separated integers)
MACRO_GATE_SECRET=        # B2B shared secret — clients pass as X-Macro-Gate header
MACRO_STACK_WARMUP=       # comma-separated tickers to pre-warm on startup (optional)

# Enforce wallet binding on tokens (reject token replay from different wallets)
# ENFORCE_WALLET_BINDING=false

# ============================================================
# x402 PROTOCOL (Coinbase facilitator paywall — USDC on Base)
# Only required if x402_flask paywall is wired up on any routes.
# ============================================================
# X402_NETWORK=base-sepolia                # or "base" for mainnet
# X402_PAY_TO=0x...                        # EVM wallet receiving USDC
# X402_FACILITATOR=https://x402.org/facilitator
# X402_MAX_TIMEOUT=120

# ============================================================
# STRIPE — fiat API key subscriptions (core/api/keys_bp.py)
# ============================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_DEV=price_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...

# ============================================================
# OWNER / OPERATOR ACCESS — bypass payment gate, control autopilot
# Generate strong random keys: openssl rand -hex 32
# ============================================================
# OWNER_API_KEY — bypasses 402 payment on all premium endpoints
# Pass as: X-Owner-Key: <key>
OWNER_API_KEY=

# OPERATOR_API_KEY — required to start/stop/reset Sovereign Autopilot
# Pass as: X-Operator-Key: <key>
# OPERATOR_API_KEY=

# Comma-separated additional bypass keys for agents
# AGENT_API_KEYS=key1,key2,key3

# ============================================================
# STIGMERGY PROTOCOL — XRPL operator wallet
# Leave blank to disable Stigmergy endpoints (they return 503).
# XRPL payment verification is fail-closed — no fake tx_hash bypasses.
# ============================================================
SQUEEZEOS_OPERATOR_WALLET=
# XRPL_RPC_URL=https://xrplcluster.com     # optional override

# ============================================================
# NEO4J (GraphiFY / MarketGraph) — optional
# Omit to disable graph features gracefully (endpoints return 503)
# ============================================================
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ============================================================
# OPENAI — required only for Beastmode endpoints
# /api/scriptmaster/ingest_intel and /api/scriptmaster/ai_brief
# ============================================================
# OPENAI_API_KEY=

# ============================================================
# AUTONOMOUS AGENT — XRPL wallet for agent/sml_agent.py
# Used by .github/workflows/agent.yml (NOT by the API server itself).
# Set these as GitHub Actions secrets, not as Render env vars.
# ============================================================
# AGENT_XRPL_SEED=sEd...
# AGENT_XRPL_ADDRESS=r...
# ANTHROPIC_API_KEY=

# ============================================================
# AEO/GEO INTELLIGENCE SUITE — Stripe + Treasury
# ============================================================
# AEO_STRIPE_SIGNAL_PRICE_ID=price_...     # Signal tier ($49/mo)
# AEO_STRIPE_SOVEREIGN_PRICE_ID=price_...  # Sovereign tier ($149/mo)
# AEO_STRIPE_WEBHOOK_SECRET=whsec_...
#
# Treasury — bookkeeping ledger only, does not move real funds.
# Leave AEO_TREASURY_XRPL_ADDRESS unset until you have a dedicated
# XRPL wallet for this; auto-hire posting stays dormant until then.
# AEO_TREASURY_XRPL_ADDRESS=r...
# AEO_TREASURY_HIRE_THRESHOLD_RLUSD=25.0

# ============================================================
# TRADE DESK — Stripe (swarmagentsintelligence.scriptmasterlabs.com)
# Launch pricing: Free ($0, landing page only), Trader ($19/mo),
# Pro ($49/mo). Frontend dashboard is built externally (Abacus.AI);
# this repo only issues/validates the API key it gates on.
# ============================================================
# TRADE_DESK_STRIPE_TRADER_PRICE_ID=price_...  # Trader tier ($19/mo)
# TRADE_DESK_STRIPE_PRO_PRICE_ID=price_...     # Pro tier ($49/mo)
# TRADE_DESK_STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SECRET_KEY is shared with CASCADE/AEO (see above)
# REDIS_URL is shared with CASCADE/AEO (see above)

# ============================================================
# MARKETING DEPARTMENT — live activity feed (real agent runs only)
# GET /api/marketing/activity is always public. POST requires this
# secret so the feed can't be spammed with fake entries — every line
# in it must be a verifiably real agent event.
# ============================================================
# MARKETING_ACTIVITY_SECRET=

# ============================================================
# STELLAR FORGE — affiliate payout engine (feature-flagged)
# Blueprint registers at /api/forge only when ENABLED=true.
# ============================================================
# STELLAR_FORGE_ENABLED=false
# STELLAR_FORGE_DB=:memory:                # SQLite path or Postgres DSN
# STELLAR_FORGE_LIVE_PAYOUTS=false         # true = real XRPL submissions
# STELLAR_FORGE_UPSTREAM_URL=              # optional inference backend
# STELLAR_FORGE_WORKERS=4
# STELLAR_FORGE_ROUTE_TIMEOUT=60

# ============================================================
# INSTITUTIONAL ALPHA FACTORS (ScriptMasterLabs Law 2)
# Signal sensitivity tuning — all have sensible defaults
# ============================================================
GEX_SHORT_GAMMA_AMP=1.3      # Amplification in short gamma (+30%)
GEX_LONG_GAMMA_DAMP=0.7      # Dampening in long gamma (-30%)
GEX_DTE_DECAY_FACTOR=0.1     # Time weighting decay (exponential)

# MM Intelligence (Kalman/HJB) sensitivities
MM_KALMAN_GAIN=0.65          # Speed of inventory adaptation (0.0 - 1.0)
MM_KALMAN_LAMBDA=0.15        # Mean reversion speed of flow
MM_INV_HOLD_COST=0.1         # Holding cost penalty in HJB optimization
MM_MARKET_IMPACT=0.5         # Kappa (market impact coefficient)
MM_ATR_PROXY_MULT=0.02       # % of price used as ATR proxy if data missing

# Minimum premium threshold for institutional discovery ($)
MIN_PREMIUM_THRESHOLD=1000000.0

# ============================================================
# SOVEREIGN AUTOPILOT — CEO TRADER
# ============================================================
# Master live-trading switch. Set to true ONLY when you have
# TRADIER_PRODUCTION_API_KEY and TRADIER_PRODUCTION_ACCOUNT set above.
TRADIER_LIVE=false

# Watchlist — comma-separated, no spaces
AUTOPILOT_SYMBOLS=GME,AMC,IWM,SPY,QQQ,MSTR,NVDA,TSLA,PLTR

# Minimum Oracle confidence score to fire (0-100). 82 = IGNITION grade.
AUTOPILOT_MIN_CONFIDENCE=82

# Fractional Kelly — use 25% of full Kelly (conservative institutional default)
AUTOPILOT_KELLY_FRACTION=0.25

# Max position size as % of live account equity per trade
AUTOPILOT_MAX_POSITION_PCT=0.05

# Hard $ cap per order — Kelly is further capped at this value
AUTOPILOT_MAX_ORDER_VALUE=500

# Max concurrent open positions
AUTOPILOT_MAX_CONCURRENT=3

# Minimum seconds between any new entry (cooldown)
AUTOPILOT_COOLDOWN_SECONDS=300

# Seconds between full watchlist sweeps
AUTOPILOT_SCAN_INTERVAL=30

# Allowed regimes — only fire in these conditions
# Options: ALPHA_EXPANSION, NEUTRAL, MACRO_COLLAPSE, SHIELD
AUTOPILOT_REGIME_WHITELIST=ALPHA_EXPANSION,NEUTRAL

# ============================================================
# SALES AGENT — SMTP (tools/sales_agent.py auto-email)
# All four required to enable email outreach. Without them, the agent
# falls back to Discord-only.
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=                             # Gmail: use an App Password
# SMTP_FROM=                                 # defaults to SMTP_USERNAME
# SQUEEZEOS_PRICING_URL=https://squeezeos-api.onrender.com/pricing

# ============================================================
# RUNTIME
# ============================================================
PORT=8182
# VERCEL=1                                 # set automatically on Vercel
# FORCE_SSL=false                          # true requires cert files

# CORS allowed origins — comma-separated list of allowed frontend origins.
# Defaults to the canonical SqueezeOS dashboard origins.
# Set to * for local development only — never in production.
# CORS_ORIGINS=https://scriptmasterlabs.com,https://www.scriptmasterlabs.com,https://signal-auction-loom.vercel.app

# ============================================================
# SMTP OUTREACH ENGINE — Automated Sales Outreach
# ============================================================
# SMTP_HOST=smtp.gmail.com                 # SMTP server address
# SMTP_PORT=587                            # 587 (TLS) or 465 (SSL)
# SMTP_USER=your-email@gmail.com           # SMTP username
# SMTP_PASS=your-app-password              # SMTP password/app key
# SMTP_FROM=SqueezeOS Sales <your-email@gmail.com> # Optional custom sender header

# ============================================================
# IAM AUTO-EXECUTION — Inevitable Action Model trading
# ============================================================
# IAM_AUTO_TRADING=false          # Master arm switch. Set true to enable.
# IAM_EXECUTION_MODE=alert        # alert (Discord only) | tradier | both
# IAM_INSTRUMENT=equity           # equity | options | auto
# IAM_PAPER_MODE=true             # true=log only, false=live orders
# IAM_MIN_CONFIDENCE=70           # Minimum IAM resolution_confidence % to execute
# IAM_MAX_SHARES=5                # Max shares per equity order
# IAM_MAX_ORDER_USD=500           # Max notional USD per order
# IAM_MAX_ORDERS_PER_DAY=5        # Hard daily execution cap
# IAM_MAX_NOTIONAL_PER_DAY=2000   # Total $ deployed per day ceiling
# IAM_DAILY_LOSS_LIMIT=300        # Auto-disarm when realized loss hits this
# IAM_COOLDOWN_SECONDS=3600       # Min seconds between same-symbol orders
# IAM_OPTION_EXPIRY_DAYS=1        # Target DTE for option orders (0=0DTE)
# IAM_OPTION_CONTRACT_QTY=1       # Number of option contracts per order
# IAM_ODTE_ONLY_SYMBOLS=IWM       # Comma-separated; these ALWAYS execute as same-day
#                                  # (0DTE) options only, never equity, never next-day+
#                                  # expiry — regardless of IAM_INSTRUMENT/IAM_OPTION_EXPIRY_DAYS.
#                                  # Still fully eligible for the dynamic scan universe.
# TRADIER_ACCOUNT_ID=             # Required for Tradier order placement

# ============================================================
# SLACK APP — App Directory integration
# ============================================================
# Get these from https://api.slack.com/apps after creating your app
# SLACK_SIGNING_SECRET=          # Used to verify incoming slash command requests
# SLACK_BOT_TOKEN=xoxb-          # Bot OAuth token (install app to workspace first)
# SLACK_CLIENT_ID=               # OAuth 2.0 client ID (for multi-workspace installs)
# SLACK_CLIENT_SECRET=           # OAuth 2.0 client secret

# ============================================================
# CASCADE ACCUMULATOR — Stripe + Redis
# ============================================================
# Stripe secret key (sk_live_... or sk_test_...)
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret (whsec_...)
# Get from: https://dashboard.stripe.com/webhooks (add endpoint: /api/cascade/stripe/webhook)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price ID for CASCADE ACCUMULATOR $149/mo subscription
# Create at: https://dashboard.stripe.com/products → add product → add $149/mo recurring price
# CASCADE_STRIPE_PRICE_ID=price_...

# Redis URL for API key storage (required for Stripe-issued keys)
# Render: add a Redis instance and copy the Internal Redis URL
# REDIS_URL=redis://...
