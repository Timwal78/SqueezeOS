# ============================================================
# SQUEEZE OS v4.1 — API Configuration
# Copy this file to .env and fill in your keys.
# Priority: Schwab → Alpaca → Polygon → Alpha Vantage
# ============================================================

# SCHWAB (configured via the UI Settings panel)
# SCHWAB_CLIENT_ID=your_app_key
# SCHWAB_CLIENT_SECRET=your_app_secret
# SCHWAB_REDIRECT_URI=https://127.0.0.1:8182/

# TRADIER — preferred option-chain provider for MMLE
# Sign up: https://developer.tradier.com/
# Sandbox: 15-min delayed data, $100K paper account, no streaming
# Production: real-time, requires Tradier brokerage account
TRADIER_API_KEY=
TRADIER_ENV=sandbox

# POLYGON.IO — Free tier: 5 calls/min
# Sign up: https://polygon.io/
POLYGON_API_KEY=

# ALPACA — Free tier: real-time IEX data
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ALPHA VANTAGE — Free tier: 25 calls/day
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ============================================================
# DISCORD WEBHOOKS — Get alerts in your Discord channel
# Create webhooks: Server Settings → Integrations → Webhooks
# You can use one URL for all, or separate channels.
# ============================================================

# All-in-one (squeeze + flow + system alerts)
DISCORD_WEBHOOK_ALL=

# Or separate channels:
# DISCORD_WEBHOOK_SQUEEZE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_FLOW=https://discord.com/api/webhooks/...

# ============================================================
# STIGMERGY PROTOCOL — XRPL operator wallet
# The XRPL wallet address where /stake and /drop payments are received.
# Every stake and pheromone drop payment must arrive at this address.
# Leave blank to disable Stigmergy Protocol (endpoints return 503).
# XRPL payment verification is fail-closed — no fake tx_hash bypasses work.
# ============================================================
SQUEEZEOS_OPERATOR_WALLET=

# ============================================================
# PAYMENT INFRASTRUCTURE — 402Proof + XRPL
# ============================================================
# 402Proof server (payment firewall for premium /api/* endpoints)
PROOF402_SERVER_URL=https://four02proof.onrender.com
# HMAC-SHA256 secret shared with 402Proof — must match TOKEN_SECRET on 402Proof
PROOF402_TOKEN_SECRET=
# Self-referencing base URL used by MCP proxy
SQUEEZEOS_BASE_URL=https://squeezeos-api.onrender.com

# ============================================================
# NEO4J (GraphiFY / MarketGraph) — optional
# Omit to disable graph features gracefully
# ============================================================
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# ============================================================
# OPENAI — required only for Beastmode (/api/scriptmaster/ingest_intel)
# ============================================================
# OPENAI_API_KEY=

# ============================================================
# AUTONOMOUS AGENT — XRPL wallet for agent/sml_agent.py
# ============================================================
# AGENT_XRPL_SEED=sEd...
# AGENT_XRPL_ADDRESS=r...
# ANTHROPIC_API_KEY=

# ============================================================
# OWNER FREE ACCESS — bypass payment gate on all premium endpoints
# Generate a strong random key: openssl rand -hex 32
# Pass as header: X-Owner-Key: <your key>
# Also bypasses XRPL tx verification on Stigmergy endpoints.
# ============================================================
OWNER_API_KEY=

# ============================================================
# INSTITUTIONAL ALPHA FACTORS (ScriptMasterLabs Law 2)
# ============================================================
# Tune These to Adjust Signal Sensitivity
# ============================================================

# Probability/GEX Thresholds
GEX_SHORT_GAMMA_AMP=1.3   # Amplification in short gamma (e.g. 1.3 = +30%)
GEX_LONG_GAMMA_DAMP=0.7    # Dampening in long gamma (e.g. 0.7 = -30%)
GEX_DTE_DECAY_FACTOR=0.1   # Time weighting decay (exponential)

# MM Intelligence (Kalman/HJB) Sensitivities
MM_KALMAN_GAIN=0.65       # Speed of inventory adaptation (0.0 - 1.0)
MM_KALMAN_LAMBDA=0.15     # Mean reversion speed of flow
MM_INV_HOLD_COST=0.1      # Holding cost penalty in HJB optimization
MM_MARKET_IMPACT=0.5      # Kappa (market impact coefficient)
MM_ATR_PROXY_MULT=0.02    # % of price used as ATR proxy if data missing

# Minimum premium threshold for institutional discovery
MIN_PREMIUM_THRESHOLD=1000000.0
