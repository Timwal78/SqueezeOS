# ============================================================
# SQUEEZE OS v4.1 — API Configuration
# Copy this file to .env and fill in your keys.
# Priority: Schwab → Alpaca → Polygon → Alpha Vantage
# ============================================================

# SCHWAB (configured via the UI Settings panel)
# SCHWAB_CLIENT_ID=your_app_key
# SCHWAB_CLIENT_SECRET=your_app_secret
# SCHWAB_REDIRECT_URI=https://127.0.0.1:8182/

# POLYGON.IO — Free tier: 5 calls/min
# Sign up: https://polygon.io/
POLYGON_API_KEY=

# ALPACA — Free tier: real-time IEX data
# Sign up: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=

# ALPHA VANTAGE — Free tier: 25 calls/day
# Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ============================================================
# DISCORD WEBHOOKS — Get alerts in your Discord channel
# Create webhooks: Server Settings → Integrations → Webhooks
# You can use one URL for all, or separate channels.
# ============================================================

# All-in-one (squeeze + flow + system alerts)
DISCORD_WEBHOOK_ALL=

# Or separate channels:
# DISCORD_WEBHOOK_SQUEEZE=https://discord.com/api/webhooks/...
# DISCORD_WEBHOOK_FLOW=https://discord.com/api/webhooks/...

# ============================================================
# INSTITUTIONAL ALPHA FACTORS (ScriptMasterLabs Law 2)
# ============================================================
# Tune These to Adjust Signal Sensitivity
# ============================================================

# Probability/GEX Thresholds
GEX_SHORT_GAMMA_AMP=1.3   # Amplification in short gamma (e.g. 1.3 = +30%)
GEX_LONG_GAMMA_DAMP=0.7    # Dampening in long gamma (e.g. 0.7 = -30%)
GEX_DTE_DECAY_FACTOR=0.1   # Time weighting decay (exponential)

# MM Intelligence (Kalman/HJB) Sensitivities
MM_KALMAN_GAIN=0.65       # Speed of inventory adaptation (0.0 - 1.0)
MM_KALMAN_LAMBDA=0.15     # Mean reversion speed of flow
MM_INV_HOLD_COST=0.1      # Holding cost penalty in HJB optimization
MM_MARKET_IMPACT=0.5      # Kappa (market impact coefficient)
MM_ATR_PROXY_MULT=0.02    # % of price used as ATR proxy if data missing

# Minimum premium threshold for institutional discovery
MIN_PREMIUM_THRESHOLD=1000000.0
