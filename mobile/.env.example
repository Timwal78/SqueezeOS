# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values before running `npm run build`
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# WalletConnect Project ID
# Get from: cloud.walletconnect.com → Projects → ScriptMasterLabs → Project ID
VITE_WC_PROJECT_ID=

# Alchemy API Key (used for ETH Mainnet + Base RPC)
# Get from: dashboard.alchemy.com → Apps → your app → API Key
VITE_ALCHEMY_KEY=

# Stripe Publishable Key (pk_live_... for production, pk_test_... for testing)
# Get from: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PK=

# Your wallet address — receives crypto subscription payments
VITE_BILLING_WALLET=
